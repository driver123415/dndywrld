-- Tombol Copy CFrame Part
local copyCFrameButton = Instance.new("TextButton")
copyCFrameButton.Size = UDim2.new(1, 0, 0.2, 0)
copyCFrameButton.Position = UDim2.new(0, 0, 0.9, 0)
copyCFrameButton.Text = "Copy CFrame"
copyCFrameButton.TextScaled = true
copyCFrameButton.Parent = frame

-- Fungsi untuk copy text ke clipboard
local function copyToClipboard(text, label)
    setclipboard(text)
    label.BackgroundColor3 = Color3.new(0, 1, 0) -- Ganti warna jadi hijau
    wait(1) -- Tunggu 1 detik
    label.BackgroundColor3 = Color3.new(1, 1, 1) -- Kembalikan ke warna asli
end

-- Update GUI saat mouse menunjuk ke part dan di-klik
mouse.Button1Down:Connect(function()
    local target = mouse.Target
    if target and target:IsA("BasePart") then
        -- Update label nama part dan CFrame
        partNameLabel.Text = "Part Name: " .. target.Name
        cframeLabel.Text = "CFrame: " .. tostring(target.CFrame)

        -- Hubungkan tombol untuk copy nama part dan CFrame
        copyPartNameButton.MouseButton1Click:Connect(function()
            copyToClipboard(target.Name, partNameLabel)
            print("Nama Part tercopy: " .. target.Name)
        end)

        copyCFrameButton.MouseButton1Click:Connect(function()
            copyToClipboard(tostring(target.CFrame), cframeLabel)
            print("CFrame Part tercopy: " .. tostring(target.CFrame))
        end)
    else
        partNameLabel.Text = "Tidak ada part yang ditunjuk."
        cframeLabel.Text = ""
    end
end)

-- Fungsi untuk tombol close
closeButton.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

-- Dragging functionality
local isDragging = false
local dragStart = nil
local startPos = nil

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)
