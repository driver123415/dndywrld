-- ==========================================
-- LOGIKA INSPECTOR & COPY
-- ==========================================
local currentTargetName = ""
local currentTargetCFrame = ""

-- Fungsi visual saat copy berhasil
local function flashButton(btn, text)
	local oriColor = btn.BackgroundColor3
	local oriText = btn.Text
	btn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
	btn.Text = text
	task.wait(1)
	btn.BackgroundColor3 = oriColor
	btn.Text = oriText
end

-- Update data saat klik part (TIDAK menyambungkan tombol copy di sini untuk mencegah bug)
mouse.Button1Down:Connect(function()
	local target = mouse.Target
	if target and target:IsA("BasePart") then
		currentTargetName = target.Name
		currentTargetCFrame = tostring(target.CFrame)
		
		PartNameLabel.Text = "Name: " .. currentTargetName
		CFrameLabel.Text = "CFrame: " .. currentTargetCFrame
	end
end)

-- Koneksi tombol copy (Hanya dibuat 1 kali, membaca dari variabel di atas)
CopyNameBtn.MouseButton1Click:Connect(function()
	if currentTargetName ~= "" then
		local success = pcall(function() setclipboard(currentTargetName) end)
		if success then
			flashButton(CopyNameBtn, "Copied!")
		else
			flashButton(CopyNameBtn, "Error!")
		end
	end
end)

CopyCFrameBtn.MouseButton1Click:Connect(function()
	if currentTargetCFrame ~= "" then
		local success = pcall(function() setclipboard(currentTargetCFrame) end)
		if success then
			flashButton(CopyCFrameBtn, "Copied!")
		else
			flashButton(CopyCFrameBtn, "Error!")
		end
	end
end)

-- ==========================================
-- LOGIKA TELEPORT
-- ==========================================
TeleportBtn.MouseButton1Click:Connect(function()
	local inputText = CoordInput.Text
	inputText = string.gsub(inputText, " ", "") -- Hapus spasi
	local coords = string.split(inputText, ",")
	
	if #coords >= 3 then
		local x = tonumber(coords[1])
		local y = tonumber(coords[2])
		local z = tonumber(coords[3])
		
		if x and y and z then
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			
			if hrp then
				hrp.CFrame = CFrame.new(x, y, z)
				flashButton(TeleportBtn, "Success!")
			end
		else
			CoordInput.Text = "Gunakan angka/format salah!"
			task.wait(1.5)
			CoordInput.Text = ""
		end
	else
		CoordInput.Text = "Butuh minimal X, Y, Z!"
		task.wait(1.5)
		CoordInput.Text = ""
	end
end)
