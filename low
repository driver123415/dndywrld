local function checkLocalPlayerMachines()
    local currentRoom = Workspace:FindFirstChild("CurrentRoom")
    if not currentRoom then return end
    
    local map = currentRoom:FindFirstChildWhichIsA("Model")
    if not map then return end

    local generators = map:FindFirstChild("Generators")
    if generators then
        for _, gen in ipairs(generators:GetChildren()) do
            if gen:IsA("Model") and not countedGenerators[gen] then
                local pCompletion = gen:FindFirstChild("PlayerCompletion")
                if pCompletion and pCompletion:FindFirstChild(player.Name) then
                    stats.Machines = stats.Machines + 1
                    countedGenerators[gen] = true 
                end
            end
        end
    end
end

local function updateStatsVariables()
    local igp = Workspace:FindFirstChild("InGamePlayers")
    if igp then
        local myCharInfo = igp:FindFirstChild(player.Name)
        if myCharInfo then
            local conf = myCharInfo:FindFirstChild("Config")
            if conf and conf:FindFirstChild("CharacterName") and conf.CharacterName:IsA("StringValue") then
                stats.Toon = conf.CharacterName.Value
            end
        end
    end

    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local sGui = pGui:FindFirstChild("ScreenGui")
        if sGui then
            local cFrames = sGui:FindFirstChild("CurrencyFrames")
            if cFrames then
                local ichor = cFrames:FindFirstChild("IchorFrame")
                if ichor and ichor:FindFirstChild("Margin") and ichor.Margin:FindFirstChild("TextLabel") then
                    stats.Ichor = ichor.Margin.TextLabel.Text
                end
                local holiday = cFrames:FindFirstChild("HolidayFrame")
                if holiday and holiday:FindFirstChild("Margin") and holiday.Margin:FindFirstChild("TextLabel") then
                    stats.Holiday = holiday.Margin.TextLabel.Text
                end
            end
        end

        for _, ui in ipairs(pGui:GetDescendants()) do
            if ui:IsA("TextLabel") and string.find(string.lower(ui.Text), "floor") then
                local match = string.match(ui.Text, "FLOOR%s*(%d+)") or string.match(ui.Text, "Floor:%s*(%d+)")
                if match then stats.Floor = match; break end
            end
        end

        local masteryFrame = sGui and sGui:FindFirstChild("MasteryFrame")
        if masteryFrame then
            local compText = masteryFrame:FindFirstChild("CompletedText")
            local progText = masteryFrame:FindFirstChild("ProgressText") or masteryFrame:FindFirstChild("Percentage")
            if compText and compText.Visible then stats.Mastery = compText.Text 
            elseif progText and progText.Visible then stats.Mastery = progText.Text 
            else stats.Mastery = "In Progress" end
        else
            stats.Mastery = "Not Found / Hidden"
        end
    end
end

