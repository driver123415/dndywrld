-- ==================== FUNGSI TOGGLE ====================
local function toggleOptimizer(state)
    isOptimized = state
    if isOptimized then
        toggleBtn.Text = "OPTIMIZER: ON"
        toggleBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        blackScreen.Visible = true
        applyLowGraphics()
    else
        toggleBtn.Text = "OPTIMIZER: OFF"
        toggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        blackScreen.Visible = false
        if setfpscap then setfpscap(60) end -- Kembalikan FPS cap normal
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    toggleOptimizer(not isOptimized)
end)

-- ==================== STATS UPDATER LOOP ====================
task.spawn(function()
    while true do
        if isOptimized then
            local playerGui = player:FindFirstChild("PlayerGui")
            if playerGui then
                -- 1. Deteksi Lantai (Mencari UI bertuliskan "Floor X")
                for _, ui in ipairs(playerGui:GetDescendants()) do
                    if ui:IsA("TextLabel") and string.find(string.lower(ui.Text), "floor") then
                        local match = string.match(ui.Text, "FLOOR%s*(%d+)") or string.match(ui.Text, "Floor:%s*(%d+)")
                        if match then
                            stats.Floor = match
                            break
                        end
                    end
                end

                -- 2. Deteksi Mastery (Sesuai path gambar Dex Explorer)
                local masteryFrame = playerGui:FindFirstChild("ScreenGui") and playerGui.ScreenGui:FindFirstChild("MasteryFrame")
                if masteryFrame then
                    local compText = masteryFrame:FindFirstChild("CompletedText")
                    local progText = masteryFrame:FindFirstChild("ProgressText") or masteryFrame:FindFirstChild("Percentage")
                    
                    if compText and compText.Visible then
                        stats.Mastery = compText.Text -- Akan menjadi "COMPLETED!"
                    elseif progText and progText.Visible then
                        stats.Mastery = progText.Text -- Akan menampilkan progress misal "45%"
                    else
                        stats.Mastery = "In Progress"
                    end
                else
                    stats.Mastery = "Not Found / Hidden"
                end
            end

            -- Update Teks di Layar Hitam
            statsLabel.Text = string.format(
                "=== DANDY'S WORLD AFK OPTIMIZER ===\n\n" ..
                "🏢 Current Floor : %s\n" ..
                "🎒 Items Taken   : %d\n" ..
                "🍔 Items Consumed: %d\n" ..
                "⭐ Mastery Status: %s\n\n" ..
                "===================================\n" ..
                "Tinggalkan perangkat dengan tenang.",
                stats.Floor, stats.Taken, stats.Consumed, stats.Mastery
            )
        end
        task.wait(1)
    end
end)

