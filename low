                            stats.Floor = match
                            break
                        end
                    end
                end

                -- Deteksi Mastery 
                local masteryFrame = playerGui:FindFirstChild("ScreenGui") and playerGui.ScreenGui:FindFirstChild("MasteryFrame")
                if masteryFrame then
                    local compText = masteryFrame:FindFirstChild("CompletedText")
                    local progText = masteryFrame:FindFirstChild("ProgressText") or masteryFrame:FindFirstChild("Percentage")
                    
                    if compText and compText.Visible then
                        stats.Mastery = compText.Text 
                    elseif progText and progText.Visible then
                        stats.Mastery = progText.Text 
