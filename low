end)

-- ==================== STATS UPDATER LOOP ====================
-- Deteksi progress mesin dari notifikasi UI (SpectatorGui/InfoFrame)
local lastTotalMachines = 0
local function checkMachines()
    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local specGui = pGui:FindFirstChild("SpectatorGui")
        if specGui then
            local info = specGui:FindFirstChild("InfoFrame")
            if info then
                local genFrame = info:FindFirstChild("GeneratorFrame")
                if genFrame then
                    local msg = genFrame:FindFirstChild("Message")
                    if msg and msg:IsA("TextLabel") then
                        local cur, tot = string.match(msg.Text, "Machines Completed: (%d+)/(%d+)")
                        if cur then
                            local currentNum = tonumber(cur)
                            -- Jika ada penambahan mesin selesai, catat
                            if currentNum > lastTotalMachines then
                                stats.Machines = stats.Machines + (currentNum - lastTotalMachines)
                                lastTotalMachines = currentNum
                            elseif currentNum == 0 and lastTotalMachines > 0 then
                                -- Reset jika pindah lantai
                                lastTotalMachines = 0
                            end
                        end
                    end
                end
            end
        end
    end
end

-- Deteksi Inventory dengan Delta Check (Jumlah isi tas)
local function checkInventory()
    local char = player.Character
    if not char then return end
    local inv = char:FindFirstChild("Inventory")
    if not inv then return end

    local currentCount = 0
    for i = 1, 4 do
        local slot = inv:FindFirstChild("Slot" .. i)
        if slot and slot.Value ~= "" and slot.Value ~= "None" then
            currentCount = currentCount + 1
        end
    end

    if currentCount > lastInventoryCount then
        stats.Taken = stats.Taken + (currentCount - lastInventoryCount)
    elseif currentCount < lastInventoryCount then
        stats.Consumed = stats.Consumed + (lastInventoryCount - currentCount)
    end
    lastInventoryCount = currentCount
end

task.spawn(function()
    while true do
        if isOptimized then
            local playerGui = player:FindFirstChild("PlayerGui")
            
            checkInventory()
            checkMachines()
            
            if playerGui then
                -- 1. Deteksi Lantai
                for _, ui in ipairs(playerGui:GetDescendants()) do
                    if ui:IsA("TextLabel") and string.find(string.lower(ui.Text), "floor") then
                        local match = string.match(ui.Text, "FLOOR%s*(%d+)") or string.match(ui.Text, "Floor:%s*(%d+)")
