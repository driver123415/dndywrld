--[[
    THE ULTIMATE AUTO PARRY V1.8 (STABILITY EDITION)
    Fix: Mengembalikan stabilitas Parry dari V1.6 (Menghapus MoveTo yang merusak animasi).
    Fix: Mengoptimalkan sistem pergerakan agar tetap menjauh tanpa mengunci input parry.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local CoreGui = game:GetService("CoreGui")

local Player = Players.LocalPlayer

-- ==========================================
-- BAGIAN SETTINGS (UBAH RADIUS DI SINI)
-- ==========================================
local SETTINGS = {
    AutoParry = false,
    Visuals = false,
    OptimizerOn = false,
    AutoDistance = false,    
    KeepDistance = 70,       -- <--- UBAH RADIUS JAGA JARAK DI SINI (Default 35 studs)
    PingBasedOffset = 2.5,   
    BaseDistanceToParry = 1.0, 
    EmergencyRadius = 15     
}

local LastClick = 0
local LastBallHit = nil
local IsParrying = false
local frameCounter = 0
local VisualPart, VisualMesh
local DistVisualPart, DistVisualMesh
local MainConnection

local NetworkStats = Stats:FindFirstChild("Network") 
    and Stats.Network:FindFirstChild("ServerStatsItem") 
    and Stats.Network.ServerStatsItem:FindFirstChild("Data Ping")

-- ==========================================
-- 1. SISTEM VISUALIZER PARRY (BOLA)
-- ==========================================
local function CreateVisualizer()
    if VisualPart then return end
    VisualPart = Instance.new("Part")
    VisualPart.Name = "ParrySmartCircle"
    VisualPart.Parent = workspace
    VisualPart.Anchored = true
    VisualPart.CanCollide = false
    VisualPart.Transparency = 1
    VisualPart.Material = Enum.Material.Neon
    VisualPart.Size = Vector3.new(1, 1, 1)
    
    VisualMesh = Instance.new("SpecialMesh", VisualPart)
    VisualMesh.MeshId = "rbxassetid://3270017"
    VisualMesh.Scale = Vector3.new(0, 0, 0)
end

local function DestroyVisualizer()
    if VisualPart then
        VisualPart:Destroy()
        VisualPart = nil
        VisualMesh = nil
    end
end

local function UpdateVisuals(root, distance, state)
    if not SETTINGS.Visuals or not VisualPart then 
        if VisualPart then VisualPart.Transparency = 1 end
        return 
    end
    
    VisualPart.CFrame = root.CFrame * CFrame.new(0, -2.6, 0) * CFrame.Angles(math.rad(90), 0, 0)
    local targetSize = math.clamp(distance * 0.8, 5, 80)
    VisualMesh.Scale = VisualMesh.Scale:Lerp(Vector3.new(targetSize, targetSize, 0.5), 0.5)

    if state == "danger" then
        VisualPart.Color = Color3.fromRGB(255, 0, 0)
        VisualPart.Transparency = 0.05
    elseif state == "target" then
        VisualPart.Color = Color3.fromRGB(0, 255, 255)
        VisualPart.Transparency = 0.1
    else
        VisualPart.Color = Color3.fromRGB(150, 240, 255)
        VisualPart.Transparency = 0.5
    end
end

-- ==========================================
-- 2. SISTEM VISUALIZER AUTO DISTANCE (MUSUH)
-- ==========================================
local function CreateDistVisualizer()
    if DistVisualPart then return end
    DistVisualPart = Instance.new("Part")
    DistVisualPart.Name = "DistanceSmartCircle"
    DistVisualPart.Parent = workspace
    DistVisualPart.Anchored = true
    DistVisualPart.CanCollide = false
    DistVisualPart.Transparency = 1
    DistVisualPart.Material = Enum.Material.Neon
    DistVisualPart.Color = Color3.fromRGB(255, 150, 0) 
    DistVisualPart.Size = Vector3.new(1, 1, 1)
    
    DistVisualMesh = Instance.new("SpecialMesh", DistVisualPart)
    DistVisualMesh.MeshId = "rbxassetid://3270017"
    DistVisualMesh.Scale = Vector3.new(SETTINGS.KeepDistance * 2, SETTINGS.KeepDistance * 2, 0.5)
end

local function DestroyDistVisualizer()
    if DistVisualPart then
        DistVisualPart:Destroy()
        DistVisualPart = nil
        DistVisualMesh = nil
    end
end

local function UpdateDistVisuals(root, isActive)
    if not SETTINGS.AutoDistance or not DistVisualPart then 
        if DistVisualPart then DistVisualPart.Transparency = 1 end
        return 
    end
    DistVisualPart.CFrame = root.CFrame * CFrame.new(0, -2.65, 0) * CFrame.Angles(math.rad(90), 0, 0)
    DistVisualPart.Transparency = isActive and 0.2 or 0.8
end

-- ==========================================
-- 3. LOGIKA INTI
-- ==========================================
local function GetBall()
    local BallsFolder = workspace:FindFirstChild("Balls")
    if not BallsFolder then return nil end
    for _, v in ipairs(BallsFolder:GetChildren()) do
        if v:GetAttribute("realBall") == true then return v end
    end
    return nil
end

local function IsTargeted(ball)
    if not Player.Character then return false end
    if ball and ball:GetAttribute("target") == Player.Name then return true end
    return Player.Character:GetAttribute("Targeted") == true 
        or Player.Character:FindFirstChild("Highlight") ~= nil
end

local function SendClick(ball)
    if not SETTINGS.AutoParry or IsParrying then return end
    local now = tick()
    if LastBallHit == ball and (now - LastClick) < 0.15 then return end
    
    IsParrying = true
    LastClick = now
    LastBallHit = ball
    
    task.spawn(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.015) 
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
    
    task.delay(0.1, function() IsParrying = false end)
end

-- ==========================================
-- 4. GUI (SAMA SEPERTI SEBELUMNYA)
-- ==========================================
local ScreenGui = Instance.new("ScreenGui", CoreGui)
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 250, 0, 225)
MainFrame.Position = UDim2.new(0.5, -125, 0.5, -112)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
MainFrame.Active = true
MainFrame.Draggable = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

local Content = Instance.new("Frame", MainFrame)
Content.Size = UDim2.new(1, 0, 1, -30)
Content.Position = UDim2.new(0, 0, 0, 30)
Content.BackgroundTransparency = 1
local UIList = Instance.new("UIListLayout", Content)
UIList.Padding, UIList.HorizontalAlignment = UDim.new(0, 10), Enum.HorizontalAlignment.Center

local function CreateToggle(name, settingKey, onAction, offAction)
    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(0, 200, 0, 35)
    Btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    Btn.Text = name .. ": OFF"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    Btn.MouseButton1Click:Connect(function()
        SETTINGS[settingKey] = not SETTINGS[settingKey]
        Btn.Text = name .. (SETTINGS[settingKey] and ": ON" or ": OFF")
        Btn.BackgroundColor3 = SETTINGS[settingKey] and Color3.fromRGB(50, 150, 80) or Color3.fromRGB(50, 50, 60)
        if SETTINGS[settingKey] and onAction then onAction() elseif not SETTINGS[settingKey] and offAction then offAction() end
    end)
end

CreateToggle("Auto Parry", "AutoParry")
CreateToggle("Smart Visualizer", "Visuals", CreateVisualizer, DestroyVisualizer)
CreateToggle("Auto Distance", "AutoDistance", CreateDistVisualizer, DestroyDistVisualizer)
CreateToggle("FPS Optimizer", "OptimizerOn", function() 
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

-- ==========================================
-- 5. ENGINE LOOP (PENGGABUNGAN STABILITAS)
-- ==========================================
MainConnection = RunService.PreSimulation:Connect(function()
    local Char = Player.Character
    local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    local Hum = Char and Char:FindFirstChild("Humanoid")
    if not Root or not Hum then return end

    -- [SISTEM JAGA JARAK - VERSI STABIL]
    local enemyInZone = false
    if SETTINGS.AutoDistance and Hum.Health > 0 then
        local nearestDist = math.huge
        local targetDir = nil
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = p.Character.HumanoidRootPart
                local dist = (eRoot.Position - Root.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    targetDir = (Root.Position - eRoot.Position).Unit
                end
            end
        end

        if nearestDist < SETTINGS.KeepDistance and targetDir then
            enemyInZone = true
            -- Kembali menggunakan Hum:Move() agar tidak merusak animasi Parry
            local moveVec = Vector3.new(targetDir.X, 0, targetDir.Z).Unit
            Hum:Move(moveVec, false) 
        end
    end

    if SETTINGS.AutoDistance then UpdateDistVisuals(Root, enemyInZone) end

    -- [SISTEM PARRY]
    if not SETTINGS.AutoParry then return end
    local Ball = GetBall()
    if not Ball then return end

    local Speed = Ball.AssemblyLinearVelocity.Magnitude
    local Distance = (Root.Position - Ball.Position).Magnitude
    local Targeted = IsTargeted(Ball)

    if Targeted then
        local Ping = (NetworkStats and NetworkStats.Value / 1000) or 0.04
        local TimeToHit = Distance / math.max(Speed, 1)
        local Prediction = SETTINGS.BaseDistanceToParry + (Ping * SETTINGS.PingBasedOffset) + (Speed / 100)
        
        if TimeToHit <= Prediction or Distance <= SETTINGS.EmergencyRadius then
            SendClick(Ball)
        end
    end
end)
