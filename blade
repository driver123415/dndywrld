-- ==========================================
-- 5. LOOP UTAMA (CORE ENGINE)
-- ==========================================
MainConnection = RunService.PostSimulation:Connect(function()
    local Char = Player.Character
    local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    local Hum = Char and Char:FindFirstChild("Humanoid")
    if not Root or not Hum then return end

    -- [FITUR BARU] SISTEM AUTO JAGA JARAK (ANTI CLOSE COMBAT)
    if SETTINGS.AutoDistance and Hum.Health > 0 then
        local nearestDist = math.huge
        local escapeDir = nil
        
        -- Cari player terdekat
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eHum = p.Character:FindFirstChild("Humanoid")
                if eHum and eHum.Health > 0 then
                    local eRoot = p.Character.HumanoidRootPart
                    local dist = (eRoot.Position - Root.Position).Magnitude
                    
                    if dist < nearestDist then
                        nearestDist = dist
                        -- Hitung arah menjauh (posisi kita dikurangi posisi musuh)
                        escapeDir = (Root.Position - eRoot.Position).Unit
                    end
                end
            end
        end

        -- Eksekusi pergerakan mundur otomatis jika ada musuh yang terlalu dekat
        if nearestDist < SETTINGS.KeepDistance and escapeDir then
            -- Buang sumbu Y agar karakter tidak mencoba terbang/masuk tanah
            local safeDir = Vector3.new(escapeDir.X, 0, escapeDir.Z).Unit
            Hum:Move(safeDir, false) 
        end
    end

    -- SISTEM AUTO PARRY
    if not SETTINGS.AutoParry then 
        if VisualPart then VisualPart.Transparency = 1 end
        return 
    end

    local Ball = GetBall()
    if not Ball then
        if VisualPart then VisualPart.Transparency = 1 end
        return
    end

    local BallPos, PlayerPos = Ball.Position, Root.Position
    local Velocity = Ball.AssemblyLinearVelocity
    local Speed = Velocity.Magnitude
    local Distance = (PlayerPos - BallPos).Magnitude
    
    local directionToPlayer = (PlayerPos - BallPos).Unit
    local velocityDirection = Velocity.Unit
    local dot = directionToPlayer:Dot(velocityDirection)

    if dot < -0.2 then 
        LastBallHit = nil 
        if VisualPart and frameCounter % 2 == 0 then UpdateVisuals(Root, Distance, "neutral") end
        return
    end

    local Targeted = IsTargeted(Ball)
    
    frameCounter = frameCounter + 1
    if VisualPart and frameCounter % 2 == 0 then 
        UpdateVisuals(Root, Distance, Targeted and "danger" or "neutral")
    end

    if Targeted then
        local Ping = (NetworkStats and NetworkStats.Value / 1000) or 0.04
        local TimeToHit = Distance / math.max(Speed, 1)
        
        local SpeedFactor = Speed / 100 
        local PredictionThreshold = SETTINGS.BaseDistanceToParry + (Ping * SETTINGS.PingBasedOffset) + SpeedFactor
        
        if Speed > 150 then
            PredictionThreshold = PredictionThreshold * 1.2
        end

        if TimeToHit <= PredictionThreshold or Distance <= SETTINGS.EmergencyRadius then
            SendClick(Ball)
        end
    end
end)

Player.CharacterAdded:Connect(function()
    LastBallHit = nil
    IsParrying = false
end)
