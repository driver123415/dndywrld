print("BUY RUNN -----------------------------------------------")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- 🔒 FITUR KEAMANAN: CEK PLACE ID
-- ==========================================
local INGAME_PLACE_ID = 16552821455

if game.PlaceId ~= INGAME_PLACE_ID then
    warn("[🛡️ KEAMANAN] Script dibatalkan! Kamu tidak berada di in-game Dandy's World.")
    return 
end

-- ==========================================
-- ⚙️ KONFIGURASI SCRIPT (INSTANT BUILD + SAFE DELAY)
-- ==========================================
local Config = {
    EnableAutoBuy = true,
    
    -- 🟢 DAFTAR PUTIH (Prioritas Tertinggi di Atas)
    PriorityItems = {
        "DandyEasterEggs",
        "ChristmasCookie",
        "Ornament",
        "Basket",
        "Pumpkin",
        "Valve",                  -- Instan kelar 100%
        "Instructions",           -- Speed ekstraksi +100%
        "JumperCable",            -- Nambah 33% progres
        "SmokeBomb",              -- Kabur dari kejaran
        "EjectButton",            -- Speed & Stealth boost
        "HealthKit",              -- Medkit
        "Bandage",                -- Heal kecil
        "ExtractionSpeedCandy",   -- Speed ekstraksi +50%
        "SkillCheckCandy",        -- Boost skill check
        "Stopwatch",              -- Permudah zona putih
        "PopBottle",              -- Full stamina
        "SpeedCandy"              -- Speed boost
    },

    -- 🔴 DAFTAR HITAM (Dilarang keras dibeli)
    BlacklistItems = {
        "AirHorn",                -- Memanggil monster
        "Jawbreaker",             -- Efek random
        "Gumball",                -- Efek random
        "ChocolateBox",
        "Chocolate",
        "StaminaCandy",
        "StealthCandy",
        "ProteinBar",
        "Tape",
        "Pop"
    },
    
    -- [REVISI] Jeda pindah ke barang SELANJUTNYA (diperbesar agar aman)
    BuyDelay = 0.5,

    -- ⏳ [BARU] Sistem Auto-Retry jika gagal beli
    MaxRetries = 3,       -- Maksimal mencoba beli per barang
    RetryDelay = 0.5,     -- Jeda antar percobaan pencet tombol

    -- ⏳ Waktu tunggu animasi meja toko Dandy naik
    StoreLoadDelay = 2.5
}
-- ==========================================

print("==================================================")
print(" ⚡ AUTO BUY DANDY SHOP (AUTO-RETRY V7) AKTIF ⚡")
print("==================================================")

local isShopping = false

-- =========================================================================
-- 🔑 FUNGSI: INTERAKSI PROXIMITY MURNI
-- =========================================================================
local function interactWithPrompt(prompt)
    prompt.RequiresLineOfSight = false
    prompt.MaxActivationDistance = math.huge

    pcall(function()
        if prompt.HoldDuration == 0 then
            prompt:InputHoldBegin()
            task.wait(0.15) 
            prompt:InputHoldEnd()
        else
            prompt:InputHoldBegin()
            task.wait(prompt.HoldDuration + 0.1)
            prompt:InputHoldEnd()
        end
    end)
end
-- =========================================================================

local function isBlacklisted(itemName)
    local nameLower = string.lower(itemName)
    for _, badItem in ipairs(Config.BlacklistItems) do
        if string.find(nameLower, string.lower(badItem)) then return true end
    end
    return false
end

local function getShopPriorityWeight(itemName)
    local nameLower = string.lower(itemName)
    for i, priorityName in ipairs(Config.PriorityItems) do
        if string.find(nameLower, string.lower(priorityName)) then return i end
    end
    return 999 
end

local function executeBuy(dandyStore)
    if not Config.EnableAutoBuy then return end
    
    local availableItems = {}
    
    for _, slot in ipairs(dandyStore:GetChildren()) do
        if string.match(slot.Name, "Slot") then 
            for _, itemModel in ipairs(slot:GetChildren()) do
                if itemModel.Name ~= "Attachment" then
                    if isBlacklisted(itemModel.Name) then continue end
                    
                    local promptPart = itemModel:FindFirstChild("Prompt")
                    if promptPart then
                        local proxPrompt = promptPart:FindFirstChildWhichIsA("ProximityPrompt")
                        if proxPrompt then
                            local weight = getShopPriorityWeight(itemModel.Name)
                            if weight ~= 999 then
                                table.insert(availableItems, {
                                    Name = itemModel.Name,
                                    PromptObj = proxPrompt,
                                    PartCFrame = promptPart.CFrame,
                                    Weight = weight
                                })
                            end
                        end
                    end
                end
            end
        end
    end
    
    table.sort(availableItems, function(a, b) return a.Weight < b.Weight end)
    
    if #availableItems > 0 then
        local character = LocalPlayer.Character
        local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if humanoidRootPart then
            print("[AUTO BUY] Animasi meja selesai. Mengeksekusi " .. #availableItems .. " barang prioritas...")
            
            local platform = Instance.new("Part")
            platform.Size = Vector3.new(10, 1, 10)
            platform.Anchored = true
            platform.CanCollide = true
            platform.Transparency = 1 
            platform.Parent = Workspace
            
            for _, itemData in ipairs(availableItems) do
                print("⚡ [PROSES] Mengamankan: " .. itemData.Name)
                
                local promptPos = itemData.PartCFrame.Position
                platform.CFrame = CFrame.new(promptPos + Vector3.new(0, -3.5, 0))
                
                humanoidRootPart.CFrame = CFrame.new(promptPos)
                humanoidRootPart.AssemblyLinearVelocity = Vector3.zero
                
                task.wait(0.3) 
                
                local successBuy = false
                
                -- ========================================================
                -- 🔄 [SISTEM BARU] LOOP RETRY PEMBELIAN
                -- ========================================================
                for attempt = 1, Config.MaxRetries do
                    
                    -- CEK KEBERHASILAN: Jika prompt hilang/disable, artinya barang sudah kebeli!
                    if not itemData.PromptObj or not itemData.PromptObj.Parent or not itemData.PromptObj.Enabled then
                        print("   ✅ [SUKSES] " .. itemData.Name .. " berhasil dibeli pada percobaan ke-" .. attempt)
                        successBuy = true
                        break -- Langsung hentikan loop retry dan lanjut ke barang berikutnya
                    end
                    
                    print("   🔄 Mencoba memencet... (Percobaan " .. attempt .. "/" .. Config.MaxRetries .. ")")
                    interactWithPrompt(itemData.PromptObj)
                    
                    -- Tunggu server memproses transaksi sebelum mencoba lagi
                    task.wait(Config.RetryDelay)
                end
                
                if not successBuy then
                    print("   ⚠️ [GAGAL] Menyerah pada " .. itemData.Name .. " setelah " .. Config.MaxRetries .. " kali mencoba. (Mungkin koin tidak cukup atau lag parah)")
                end
                -- ========================================================
                
                -- Jeda santai sebelum pindah ke barang selanjutnya
                task.wait(Config.BuyDelay) 
            end
            
            platform:Destroy()
            print("[AUTO BUY] Sapu bersih selesai!")
        end
    else
        print("[AUTO BUY] Tidak ada barang prioritas di etalase ini.")
    end
    
    task.wait(2)
    isShopping = false
end

-- =========================================================================
-- 🛡️ SISTEM PEMANTAU STANDBY
-- =========================================================================
local elevatorsFolder = Workspace:WaitForChild("Elevators", 10)

if elevatorsFolder then
    elevatorsFolder.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("ProximityPrompt") and descendant.Parent.Name == "Prompt" then
            local parentModel = descendant.Parent.Parent
            
            if parentModel and parentModel.Parent and string.match(parentModel.Parent.Name, "Slot") then
                local dandyStore = parentModel.Parent.Parent
                
                if dandyStore and dandyStore.Name == "DandyStore" then
                    if not isShopping then
                        isShopping = true
                        
                        print("🛎️ [AUTO BUY] Toko muncul! Menunggu " .. Config.StoreLoadDelay .. " detik agar animasi meja selesai...")
                        
                        task.delay(Config.StoreLoadDelay, function()
                            executeBuy(dandyStore)
                        end)
                    end
                end
            end
        end
    end)
    
    local activeElevator = elevatorsFolder:FindFirstChild("Elevator")
    if activeElevator then
        local existingStore = activeElevator:FindFirstChild("DandyStore")
        if existingStore then
            isShopping = true
            executeBuy(existingStore)
        end
    end
    
    print("[🛡️ KEAMANAN] Place ID Valid. Menunggu mangsa di mode Standby...")
else
    warn("[AUTO BUY] Folder 'Elevators' tidak ditemukan!")
end
