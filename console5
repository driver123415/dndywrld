-- Logic Tahan (Hold) untuk Scroll Panah
local isScrollingUp = false
local isScrollingDown = false

local function stopScrolling()
	isScrollingUp = false
	isScrollingDown = false
end

scrollUpBtn.MouseButton1Down:Connect(function()
	isScrollingUp = true
	task.spawn(function()
		while isScrollingUp do
			console_2.CanvasPosition = Vector2.new(0, math.max(0, console_2.CanvasPosition.Y - 25))
			task.wait(0.02)
		end
	end)
end)
scrollUpBtn.MouseButton1Up:Connect(stopScrolling)
scrollUpBtn.MouseLeave:Connect(stopScrolling)

scrollDownBtn.MouseButton1Down:Connect(function()
	isScrollingDown = true
	task.spawn(function()
		while isScrollingDown do
			console_2.CanvasPosition = Vector2.new(0, console_2.CanvasPosition.Y + 25)
			task.wait(0.02)
		end
	end)
end)
scrollDownBtn.MouseButton1Up:Connect(stopScrolling)
scrollDownBtn.MouseLeave:Connect(stopScrolling)

