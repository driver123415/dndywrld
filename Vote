-- Drag Logic
local dragging, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true dragStart = input.Position startPos = mainFrame.Position end
end)
mainFrame.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)

toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
end)

-- ==================== AUTO VOTE LOGIC ====================
local function getCardPriorityWeight(cardName)
    local nameLower = string.lower(cardName)
    for i, priorityName in ipairs(Config.PriorityCards) do
        if string.find(nameLower, string.lower(priorityName)) then return i end
    end
    return 999 
end

-- DETEKSI ANTI OFF-SCREEN TRICK
local function isOnScreen(guiObject)
    if not guiObject.Visible then return false end
    
    local pos = guiObject.AbsolutePosition
    local size = guiObject.AbsoluteSize
    local viewport = workspace.CurrentCamera.ViewportSize
    
    -- Kalau ukurannya 0, berarti disembunyikan
    if size.X <= 0 or size.Y <= 0 then return false end
    
    -- Kalau posisinya ada di luar batas resolusi layar (digeser off-screen)
    if pos.X >= viewport.X or pos.Y >= viewport.Y then return false end
    if pos.X + size.X <= 0 or pos.Y + size.Y <= 0 then return false end
    
    return true
end

local function executeForceClick(btnInstance, cardName)
    print("--------------------------------------------------")
    print("🛠️ Eksekusi Klik pada: " .. cardName)
    
    if getconnections then
        local clickConns = getconnections(btnInstance.MouseButton1Click)
        for _, connection in pairs(clickConns) do
            connection:Fire()
        end
        
        if #clickConns == 0 then
            for _, conn in pairs(getconnections(btnInstance.MouseButton1Down)) do conn:Fire() end
            task.wait(0.1)
            for _, conn in pairs(getconnections(btnInstance.MouseButton1Up)) do conn:Fire() end
        end
        print("🎉 [BERHASIL] Kartu diklik!")
    else
        print("❌ Executor TIDAK mendukung getconnections.")
    end
    print("--------------------------------------------------")
end

task.spawn(function()
    while true do
        if Config.EnableAutoVote then
            pcall(function()
                local playerGui = player:WaitForChild("PlayerGui", 5)
                if playerGui then
                    local validVoteFrame = nil
                    
                    for _, gui in pairs(playerGui:GetChildren()) do
                        if gui:IsA("ScreenGui") and gui.Enabled and gui:FindFirstChild("VoteFrame", true) then
                            local vf = gui:FindFirstChild("VoteFrame", true)
                            
                            -- Cek MENGGUNAKAN KOORDINAT ASLI (Bukan cuma .Visible)
                            if isOnScreen(vf) then
                                validVoteFrame = vf
                                break
                            end
                        end
                    end
                    
                    if validVoteFrame and not isVoting then
                        isVoting = true
                        print(">> VOTE FRAME MUNCUL DI LAYAR! <<")
                        task.wait(2) 
                        
                        local bestCardName = nil
                        local bestCardBtn = nil
                        local bestWeight = 999
                        local firstAvailableCardName = nil
                        local firstAvailableCardBtn = nil
                        
                        for _, child in ipairs(validVoteFrame:GetChildren()) do
                            if child:IsA("TextButton") and isOnScreen(child) and not string.find(child.Name, "Template") then
                                local itemNameLabel = child:FindFirstChild("ItemName", true)
                                
                                if itemNameLabel and itemNameLabel:IsA("TextLabel") then
                                    local cardName = itemNameLabel.Text
                                    local weight = getCardPriorityWeight(cardName)
                                    
                                    if not firstAvailableCardName then
                                        firstAvailableCardName = cardName
                                        firstAvailableCardBtn = child
                                    end
                                    
                                    if weight < bestWeight then
                                        bestWeight = weight
                                        bestCardName = cardName
                                        bestCardBtn = child
                                    end
                                end
                            end
                        end
                        
                        if bestCardBtn then
                            executeForceClick(bestCardBtn, bestCardName)
                        elseif Config.VoteRandomIfNotFound and firstAvailableCardBtn then
                            executeForceClick(firstAvailableCardBtn, firstAvailableCardName)
                        end
                        
                        task.wait(10) 
                        isVoting = false
                    end
                end
            end)
        end
        task.wait(1) 
    end
end)

print("✅ SCRIPT AUTO VOTE (ANTI OFF-SCREEN) BERHASIL DIMUAT ✅")
