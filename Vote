-- ==============================================================================
-- AUTO VOTE BEST CARD (DANDY'S WORLD) - ULTIMATE BRUTE FORCE VERSION
-- ==============================================================================

local Config = {
    EnableAutoVote = true, 
    PriorityCards = {
        "Tech Savvy", "TIME'S UP", "Well-Paced", "Endurance",            
        "Spare Change", "Penny Pincher", "Avaricious", "Covetous",             
        "Lost and Found", "Blind Grab", "Frugal", "Rehearsal", "Practice",              
        "Electrician", "Piping Tape", "Air Freshener", "Frost Shield",                       
        "Sparkplug", "First Aid", "Medical Attention", "Suppression", "Decency", "Etiquette"                
    },
    VoteRandomIfNotFound = true 
}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui") or Players.LocalPlayer:WaitForChild("PlayerGui")
local player = Players.LocalPlayer
local isVoting = false

-- ==================== GUI SETUP ====================
if CoreGui:FindFirstChild("AutoVoteGUI_Dandy") then CoreGui.AutoVoteGUI_Dandy:Destroy() end
local screenGui = Instance.new("ScreenGui", CoreGui)
screenGui.Name = "AutoVoteGUI_Dandy"
local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 200, 0, 100)
mainFrame.Position = UDim2.new(0.5, -100, 0.8, -50)
mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 8)
local toggleBtn = Instance.new("TextButton", mainFrame)
toggleBtn.Size = UDim2.new(0.8, 0, 0.4, 0)
toggleBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
toggleBtn.Text = "OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 18
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 6)

toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
end)

-- ==================== FUNGSI INTI ====================
local function isOnScreen(gui)
    return gui.Visible and gui.AbsolutePosition.X < workspace.CurrentCamera.ViewportSize.X and gui.AbsolutePosition.Y < workspace.CurrentCamera.ViewportSize.Y and gui.AbsoluteSize.X > 0
end

local function fireVote(valueObject)
    pcall(function()
        local event = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
        event:FireServer(valueObject)
        print("🎉 [VOTE SUCCESS] Berhasil mengirim objek kartu ke server!")
    end)
end

task.spawn(function()
    while true do
        if Config.EnableAutoVote then
            pcall(function()
                local playerGui = player:WaitForChild("PlayerGui")
                local voteFrame = nil
                for _, g in pairs(playerGui:GetChildren()) do
                    if g:IsA("ScreenGui") and g.Enabled and g:FindFirstChild("VoteFrame", true) then
                        local vf = g:FindFirstChild("VoteFrame", true)
                        if isOnScreen(vf) then voteFrame = vf break end
                    end
                end

                if voteFrame and not isVoting then
                    isVoting = true
                    task.wait(2) 
                    
                    local bestWeight = 999
                    local targetObj = nil
                    local firstName = nil
                    local firstObj = nil

                    for _, card in ipairs(voteFrame:GetChildren()) do
                        if card:IsA("GuiObject") and isOnScreen(card) and not card.Name:find("Template") then
                            local nameLabel = card:FindFirstChild("ItemName", true)
                            local val = card:FindFirstChildWhichIsA("StringValue", true) or card:FindFirstChildWhichIsA("ObjectValue", true)

                            if nameLabel and val then
                                local name = nameLabel.Text
                                local weight = 999
                                for i, p in ipairs(Config.PriorityCards) do
                                    if name:lower():find(p:lower()) then weight = i break end
                                end

                                if not firstObj then firstName = name firstObj = val end
                                if weight < bestWeight then
                                    bestWeight = weight
                                    targetObj = val
                                end
                                print("🔍 Terdeteksi Kartu: " .. name .. " (Weight: " .. weight .. ")")
                            end
                        end
                    end

                    if targetObj then
                        fireVote(targetObj)
                    elseif Config.VoteRandomIfNotFound and firstObj then
                        print("⚠️ Prioritas tidak ada, memilih: " .. firstName)
                        fireVote(firstObj)
                    end

                    task.wait(10)
                    isVoting = false
                end
            end)
        end
        task.wait(1)
    end
end)
