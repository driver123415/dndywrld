-- ==================== DRAGGABLE LOGIC ====================
local dragging, dragInput, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ==================== TOGGLE LOGIC ====================
toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
end)

-- ==================== FUNGSI AUTO VOTE ====================
local function getCardPriorityWeight(cardName)
    local nameLower = string.lower(cardName)
    for i, priorityName in ipairs(Config.PriorityCards) do
        if string.find(nameLower, string.lower(priorityName)) then return i end
    end
    return 999 
end

local function executeVote(cardName, uiElement)
    print("[AUTO VOTE] >>> MEMILIH PRIORITAS: " .. cardName .. " <<<")
    pcall(function()
        local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
        
        -- MENCURI StringValue ASLI DARI UI GAME
        local realStringValue = nil
        
        -- Cek di dalam elemen kartu
        for _, child in pairs(uiElement:GetDescendants()) do
            if child:IsA("StringValue") then
                realStringValue = child
                break
            end
        end
        
        -- Kalau tidak ketemu, cek di parentnya
        if not realStringValue and uiElement.Parent then
            for _, sibling in pairs(uiElement.Parent:GetDescendants()) do
                if sibling:IsA("StringValue") then
                    realStringValue = sibling
                    break
                end
            end
        end
        
        if realStringValue then
            voteEvent:FireServer(realStringValue)
            print("[AUTO VOTE BERHASIL] RemoteEvent dikirim dengan objek StringValue asli: " .. tostring(realStringValue.Value))
        else
            -- Fallback jika game update dan menghapus StringValue
            print("[WARNING] StringValue asli tidak ditemukan! Mencoba bypass klik langsung...")
            local btn = uiElement
            if not btn:IsA("GuiButton") then btn = btn.Parent end
            if btn and btn:IsA("GuiButton") and getconnections then
                for _, conn in pairs(getconnections(btn.MouseButton1Click)) do
                    conn:Fire()
                end
                print("[AUTO VOTE] Bypass klik GUI dieksekusi.")
            end
        end
    end)
end

local function startAutoVote()
    task.spawn(function()
        while true do
            if Config.EnableAutoVote then
                pcall(function()
                    local playerGui = player:WaitForChild("PlayerGui", 5)
                    if playerGui then
                        
                        local validVoteFrame = nil
                        
                        -- Cek semua ScreenGui
                        for _, gui in pairs(playerGui:GetChildren()) do
                            -- ANTI-BOCOR: Pastikan ScreenGui-nya ENABLED dan VoteFrame-nya VISIBLE
                            if gui:IsA("ScreenGui") and gui.Enabled and gui:FindFirstChild("VoteFrame") then
                                if gui.VoteFrame.Visible then
                                    validVoteFrame = gui.VoteFrame
                                    break
                                end
                            end
                        end
                        
                        if validVoteFrame and not isVoting then
                            isVoting = true
                            print("[AUTO VOTE] VoteFrame Valid Terdeteksi!")
                            
                            task.wait(2) -- Jeda dinaikkan sedikit agar semua animasi kartu selesai
                            
                            local bestCardName = nil
                            local bestCardUI = nil
                            local bestWeight = 999
                            local firstAvailableCardName = nil
                            local firstAvailableCardUI = nil
                            
                            for _, item in ipairs(validVoteFrame:GetDescendants()) do
                                -- ANTI-HALUSINASI: Pastikan teks dan parent-nya tidak Invisible (Mencegah baca kartu lama)
                                if item:IsA("TextLabel") and item.Visible and item.Parent and item.Parent.Visible and item.Text ~= "" then
                                    local text = item.Text
                                    
                                    if string.len(text) < 20 and text ~= "Vote" and text ~= "Auto Vote Card" and text ~= "ON" and text ~= "OFF" then
                                        
                                        if not firstAvailableCardName then
                                            firstAvailableCardName = text
                                            firstAvailableCardUI = item
                                        end
                                        
                                        local weight = getCardPriorityWeight(text)
                                        if weight < bestWeight then
                                            bestWeight = weight
                                            bestCardName = text
                                            bestCardUI = item
                                        end
                                    end
                                end
                            end
                            
                            if bestCardName then
                                executeVote(bestCardName, bestCardUI)
                            elseif Config.VoteRandomIfNotFound and firstAvailableCardName then
                                print("[AUTO VOTE] Prioritas tidak ada. Memilih: " .. firstAvailableCardName)
                                executeVote(firstAvailableCardName, firstAvailableCardUI)
                            else
                                print("[AUTO VOTE ERROR] Layar terbuka tapi tidak ada kartu valid ditemukan.")
                            end
                            
                            task.wait(10) 
                            isVoting = false
                        end
                    end
                end)
            end
            task.wait(1) 
        end
    end)
end

