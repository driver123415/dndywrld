-- Drag Logic
local dragging, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true dragStart = input.Position startPos = mainFrame.Position end
end)
mainFrame.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
game:GetService("UserInputService").InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)

toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
end)

-- ==================== FUNGSI INTI ====================
local function isOnScreen(gui)
    if not gui.Visible then return false end
    local pos = gui.AbsolutePosition
    local size = gui.AbsoluteSize
    local viewport = workspace.CurrentCamera.ViewportSize
    if size.X <= 0 or size.Y <= 0 then return false end
    if pos.X >= viewport.X or pos.Y >= viewport.Y then return false end
    if pos.X + size.X <= 0 or pos.Y + size.Y <= 0 then return false end
    return true
end

local function executeVote(internalID)
    print("--------------------------------------------------")
    print("🚀 Mengirim Vote Internal ID: " .. internalID)
    pcall(function()
        local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
        local argString = Instance.new("StringValue")
        argString.Name = internalID
        argString.Value = internalID
        voteEvent:FireServer(argString)
        print("✅ [SUKSES] Server menerima Vote: " .. internalID)
    end)
    print("--------------------------------------------------")
end

task.spawn(function()
    while true do
        if Config.EnableAutoVote then
            pcall(function()
                local playerGui = player:WaitForChild("PlayerGui", 5)
                if playerGui then
                    local validVoteFrame = nil
                    
                    for _, gui in pairs(playerGui:GetChildren()) do
                        if gui:IsA("ScreenGui") and gui.Enabled and gui:FindFirstChild("VoteFrame", true) then
                            local vf = gui:FindFirstChild("VoteFrame", true)
                            if isOnScreen(vf) then
                                validVoteFrame = vf
                                break
                            end
                        end
                    end
                    
                    if validVoteFrame and not isVoting then
                        isVoting = true
                        print(">> VOTE FRAME DI LAYAR! <<")
                        task.wait(2) 
                        
                        local bestWeight = 999
                        local bestInternalID = nil
                        local firstInternalID = nil
                        
                        -- Cek langsung nama foldernya (contoh: "Machine", "PipingTape")
                        for _, child in ipairs(validVoteFrame:GetChildren()) do
                            if child:IsA("GuiObject") and isOnScreen(child) and not string.find(child.Name, "Template") and child.Name ~= "UIListLayout" then
                                local internalID = child.Name
                                
                                if not firstInternalID then firstInternalID = internalID end
                                
                                -- Cocokkan dengan daftar prioritas
                                for i, pID in ipairs(Config.PriorityCards) do
                                    if internalID == pID and i < bestWeight then
                                        bestWeight = i
                                        bestInternalID = internalID
                                        break
                                    end
                                end
                            end
                        end
                        
                        if bestInternalID then
                            executeVote(bestInternalID)
                        elseif Config.VoteRandomIfNotFound and firstInternalID then
                            print("⚠️ Prioritas tidak ada, memilih acak: " .. firstInternalID)
                            executeVote(firstInternalID)
                        end
                        
                        task.wait(10) 
                        isVoting = false
                    end
                end
            end)
        end
        task.wait(1) 
    end
end)

print("✅ SCRIPT AUTO VOTE (MASTER INTERNAL ID) BERHASIL DIMUAT ✅")
