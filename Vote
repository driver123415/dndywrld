-- ==============================================================================
-- AUTO VOTE BEST CARD - VIRTUAL INPUT MANAGER (PHYSICAL CLICK SIMULATION)
-- ==============================================================================

local Config = {
    EnableAutoVote = true, 
    PriorityCards = {
        "Tech Savvy", "TIME'S UP", "Well-Paced", "Endurance",            
        "Spare Change", "Penny Pincher", "Avaricious", "Covetous",             
        "Lost and Found", "Blind Grab", "Frugal", "Rehearsal", "Practice",              
        "Electrician", "Piping Tape", "Air Freshener", "Frost Shield",                       
        "Sparkplug", "First Aid", "Medical Attention", "Suppression", "Decency", "Etiquette"                
    },
    VoteRandomIfNotFound = true 
}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local CoreGui = game:GetService("CoreGui") or Players.LocalPlayer:WaitForChild("PlayerGui")
local player = Players.LocalPlayer
local isVoting = false

-- ==================== GUI SETUP ====================
if CoreGui:FindFirstChild("AutoVoteGUI_Dandy") then CoreGui.AutoVoteGUI_Dandy:Destroy() end
local screenGui = Instance.new("ScreenGui", CoreGui)
screenGui.Name = "AutoVoteGUI_Dandy"
local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 200, 0, 100)
mainFrame.Position = UDim2.new(0.5, -100, 0.8, -50)
mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 8)

local title = Instance.new("TextLabel", mainFrame)
title.Size = UDim2.new(1, 0, 0.4, 0)
title.BackgroundTransparency = 1
title.Text = "Auto Vote Card"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 16

local toggleBtn = Instance.new("TextButton", mainFrame)
toggleBtn.Size = UDim2.new(0.8, 0, 0.4, 0)
toggleBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
toggleBtn.Text = "OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 18
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 6)

-- Drag Logic
local dragging, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true dragStart = input.Position startPos = mainFrame.Position end
end)
mainFrame.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
game:GetService("UserInputService").InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)

toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
end)

-- ==================== FUNGSI INTI ====================
local function isOnScreen(gui)
    if not gui.Visible then return false end
    local pos = gui.AbsolutePosition
    local size = gui.AbsoluteSize
    local viewport = workspace.CurrentCamera.ViewportSize
    if size.X <= 0 or size.Y <= 0 then return false end
    if pos.X >= viewport.X or pos.Y >= viewport.Y then return false end
    return true
end

-- FUNGSI KLIK FISIK DI KOORDINAT LAYAR
local function physicalClick(guiObject, cardName)
    print("--------------------------------------------------")
    print("🤖 Mengeksekusi Klik Fisik pada: " .. cardName)
    
    -- Mencari titik tengah dari kartu tersebut
    local center = guiObject.AbsolutePosition + (guiObject.AbsoluteSize / 2)
    
    -- Menambahkan kompensasi offset Roblox Topbar (biasanya 36 pixel) agar akurat di semua device
    local clickX = center.X
    local clickY = center.Y + 36 
    
    pcall(function()
        -- Mensimulasikan jari menekan layar
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
        task.wait(0.1)
        -- Mensimulasikan jari diangkat dari layar
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
        print("✅ [BERHASIL] Layar ditekan pada kordinat X: " .. math.floor(clickX) .. ", Y: " .. math.floor(clickY))
    end)
    print("--------------------------------------------------")
end

task.spawn(function()
    while true do
        if Config.EnableAutoVote then
            pcall(function()
                local playerGui = player:WaitForChild("PlayerGui", 5)
                if playerGui then
                    local validVoteFrame = nil
                    
                    for _, gui in pairs(playerGui:GetChildren()) do
                        if gui:IsA("ScreenGui") and gui.Enabled and gui:FindFirstChild("VoteFrame", true) then
                            local vf = gui:FindFirstChild("VoteFrame", true)
                            if isOnScreen(vf) then
                                validVoteFrame = vf
                                break
                            end
                        end
                    end
                    
                    if validVoteFrame and not isVoting then
                        isVoting = true
                        print(">> VOTE FRAME MUNCUL DI LAYAR! <<")
                        task.wait(2) -- Jeda biar kartu posisinya pas di tengah layar sebelum diklik
                        
                        local bestCardName = nil
                        local bestCardUI = nil
                        local bestWeight = 999
                        local firstAvailableCardName = nil
                        local firstAvailableCardUI = nil
                        
                        for _, child in ipairs(validVoteFrame:GetChildren()) do
                            if child:IsA("GuiObject") and isOnScreen(child) and not string.find(child.Name, "Template") and child.Name ~= "UIListLayout" then
                                local itemNameLabel = child:FindFirstChild("ItemName", true)
                                
                                if itemNameLabel and itemNameLabel:IsA("TextLabel") then
                                    local cardName = itemNameLabel.Text
                                    local weight = 999
                                    
                                    for i, p in ipairs(Config.PriorityCards) do
                                        if string.find(string.lower(cardName), string.lower(p)) then weight = i break end
                                    end
                                    
                                    if not firstAvailableCardName then
                                        firstAvailableCardName = cardName
                                        firstAvailableCardUI = child
                                    end
                                    
                                    if weight < bestWeight then
                                        bestWeight = weight
                                        bestCardName = cardName
                                        bestCardUI = child
                                    end
                                end
                            end
                        end
                        
                        if bestCardUI then
                            physicalClick(bestCardUI, bestCardName)
                        elseif Config.VoteRandomIfNotFound and firstAvailableCardUI then
                            print("⚠️ Prioritas tidak ada, memilih: " .. firstAvailableCardName)
                            physicalClick(firstAvailableCardUI, firstAvailableCardName)
                        end
                        
                        task.wait(10) 
                        isVoting = false
                    end
                end
            end)
        end
        task.wait(1) 
    end
end)

print("✅ SCRIPT AUTO VOTE (VIRTUAL INPUT CLICK) BERHASIL DIMUAT ✅")
