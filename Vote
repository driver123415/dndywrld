-- ==================== FUNGSI INTI ====================
local function isOnScreen(gui)
    if not gui.Visible then return false end
    local pos = gui.AbsolutePosition
    local size = gui.AbsoluteSize
    local viewport = workspace.CurrentCamera.ViewportSize
    if size.X <= 0 or size.Y <= 0 then return false end
    if pos.X >= viewport.X or pos.Y >= viewport.Y then return false end
    if pos.X + size.X <= 0 or pos.Y + size.Y <= 0 then return false end
    return true
end

-- FUNGSI PENCULIK DARI MEMORI NIL
local function getObjectFromNil(internalID)
    if getnilinstances then
        for _, obj in pairs(getnilinstances()) do
            -- Biasanya developer menyimpan sbg StringValue, ObjectValue, atau Folder di nil
            if obj.Name == internalID then
                return obj
            end
        end
    else
        print("❌ [WARNING] Executor kamu tidak support getnilinstances!")
    end
    return nil
end

local function executeMemoryVote(internalID)
    print("--------------------------------------------------")
    print("🚀 Mencari Objek [" .. internalID .. "] di Memori (Nil)...")
    
    local realObject = getObjectFromNil(internalID)
    
    if realObject then
        print("🔍 DITEMUKAN! Objek asli berhasil diculik dari memori.")
        pcall(function()
            local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
            voteEvent:FireServer(realObject)
            print("✅ [SUKSES] Vote berhasil masuk ke server!")
        end)
    else
        print("⚠️ Objek tidak ada di Nil. Menggunakan Fallback Workspace (Cobalt Method)...")
        -- Fallback ke metode workspace yang kamu temukan sebelumnya
        pcall(function()
            local fallbackObj = workspace:FindFirstChild("Info") and workspace.Info:FindFirstChild("CardVote") and workspace.Info.CardVote:FindFirstChild(internalID)
            local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
            
            if fallbackObj then
                voteEvent:FireServer(fallbackObj)
                print("✅ [SUKSES] Vote pakai objek Workspace berhasil!")
            else
                -- Ultimate Fallback
                local argString = Instance.new("StringValue")
                argString.Name = internalID
                argString.Value = internalID
                voteEvent:FireServer(argString)
                print("✅ [SUKSES] Vote pakai StringValue buatan sendiri!")
            end
        end)
    end
    print("--------------------------------------------------")
end

task.spawn(function()
    while true do
        if Config.EnableAutoVote then
            pcall(function()
