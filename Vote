-- ==================== DRAGGABLE LOGIC ====================
local dragging, dragInput, dragStart, startPos

local function updateInput(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateInput(input)
    end
end)

-- ==================== TOGGLE LOGIC ====================
toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    if Config.EnableAutoVote then
        toggleBtn.Text = "ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 80)
        print("[GUI] Auto Vote: ON")
    else
        toggleBtn.Text = "OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        print("[GUI] Auto Vote: OFF")
    end
end)

-- ==================== FUNGSI AUTO VOTE ====================
local function getCardPriorityWeight(cardName)
    local nameLower = string.lower(cardName)
    for i, priorityName in ipairs(Config.PriorityCards) do
        if string.find(nameLower, string.lower(priorityName)) then
            return i 
        end
    end
    return 999 
end

local function sendVoteToServer(cardName)
    pcall(function()
        local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
        
        local argString = Instance.new("StringValue")
        argString.Name = cardName
        argString.Value = cardName
        
        voteEvent:FireServer(argString)
        print("[AUTO VOTE BERHASIL] Tembakan RemoteEvent untuk: " .. cardName)
    end)
end

local function startAutoVote()
    task.spawn(function()
        while true do
            if Config.EnableAutoVote then
                pcall(function()
                    local playerGui = player:WaitForChild("PlayerGui", 5)
                    if playerGui then
                        
                        local voteFrame = nil
                        for _, gui in pairs(playerGui:GetChildren()) do
                            if gui:IsA("ScreenGui") and gui:FindFirstChild("VoteFrame") then
                                voteFrame = gui.VoteFrame
                                break
                            end
                        end
                        
                        if voteFrame and voteFrame.Visible and not isVoting then
                            isVoting = true
                            print("[AUTO VOTE] VoteFrame terdeteksi!")
                            
                            task.wait(1.5) 
                            
                            local bestCardName = nil
                            local bestWeight = 999
                            local firstAvailableCardName = nil
                            
                            for _, item in ipairs(voteFrame:GetDescendants()) do
                                if item:IsA("TextLabel") and item.Text ~= "" then
                                    local text = item.Text
                                    if string.len(text) < 20 and text ~= "Vote" and text ~= "Auto Vote Card" and text ~= "ON" and text ~= "OFF" then
                                        
                                        if not firstAvailableCardName then
                                            firstAvailableCardName = text
                                        end
                                        
                                        local weight = getCardPriorityWeight(text)
                                        if weight < bestWeight then
                                            bestWeight = weight
                                            bestCardName = text
                                        end
                                    end
                                end
                            end
                            
                            if bestCardName then
                                print("[AUTO VOTE] >>> MEMILIH PRIORITAS: " .. bestCardName .. " <<<")
                                sendVoteToServer(bestCardName)
                            elseif Config.VoteRandomIfNotFound and firstAvailableCardName then
                                print("[AUTO VOTE] >>> PRIORITAS TIDAK ADA. Memilih acak: " .. firstAvailableCardName .. " <<<")
                                sendVoteToServer(firstAvailableCardName)
                            else
                                print("[AUTO VOTE] Gagal mendeteksi nama kartu (mungkin masih loading).")
                            end
                            
                            task.wait(10) 
                            isVoting = false
                        end
                    end
                end)
            end
            task.wait(1) 
        end
    end)
end

-- ==================== EKSEKUSI ====================
print("==================================================")
print(" AUTO VOTE SERVER-SIDED + GUI BERHASIL DIJALANKAN")
print("==================================================")
startAutoVote()
