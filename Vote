-- ==============================================================================
-- AUTO VOTE BEST CARD (DANDY'S WORLD) + GUI (FIXED REMOTE EVENT)
-- Otomatis memilih kartu menggunakan FireServer berdasarkan prioritas
-- ==============================================================================

local Config = {
    EnableAutoVote = true,
    
    PriorityCards = {
        "Skillcheck",       
        "Stamina",          
        "Stealth",          
        "Speed",            
        "Health",           
        "Heal"              
    },
    
    VoteRandomIfNotFound = true 
}

-- ==============================================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui") or Players.LocalPlayer:WaitForChild("PlayerGui")
local player = Players.LocalPlayer

local isVoting = false

-- ==================== GUI SETUP ====================
if CoreGui:FindFirstChild("AutoVoteGUI_Dandy") then
    CoreGui.AutoVoteGUI_Dandy:Destroy()
end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AutoVoteGUI_Dandy"
screenGui.Parent = CoreGui

local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 200, 0, 100)
mainFrame.Position = UDim2.new(0.5, -100, 0.8, -50)
mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Name = "Title"
title.Size = UDim2.new(1, 0, 0.4, 0)
title.BackgroundTransparency = 1
title.Text = "Auto Vote Card"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 16
title.Parent = mainFrame

local toggleBtn = Instance.new("TextButton")
toggleBtn.Name = "ToggleBtn"
toggleBtn.Size = UDim2.new(0.8, 0, 0.4, 0)
toggleBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
toggleBtn.BackgroundColor3 = Config.EnableAutoVote and Color3.fromRGB(40, 200, 80) or Color3.fromRGB(220, 60, 60)
toggleBtn.Text = Config.EnableAutoVote and "ON" or "OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 18
toggleBtn.Parent = mainFrame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 6)
btnCorner.Parent = toggleBtn

-- ==================== DRAGGABLE LOGIC ====================
local dragging, dragInput, dragStart, startPos

local function updateInput(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateInput(input)
    end
end)

-- ==================== TOGGLE LOGIC ====================
toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    if Config.EnableAutoVote then
        toggleBtn.Text = "ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 80)
        print("[GUI] Auto Vote: ON")
    else
        toggleBtn.Text = "OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        print("[GUI] Auto Vote: OFF")
    end
end)

-- ==================== FUNGSI AUTO VOTE ====================
local function getCardPriorityWeight(cardName)
    local nameLower = string.lower(cardName)
    for i, priorityName in ipairs(Config.PriorityCards) do
        if string.find(nameLower, string.lower(priorityName)) then
            return i 
        end
    end
    return 999 
end

-- Fungsi eksekusi RemoteEvent
local function sendVoteToServer(cardName)
    pcall(function()
        local voteEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("CardVoteEvent")
        
        -- Membuat StringValue sesuai format argumen yang dibutuhkan server
        local argString = Instance.new("StringValue")
        argString.Value = cardName
        argString.Name = cardName -- Diset ganda untuk berjaga-jaga
        
        voteEvent:FireServer(argString)
        print("[AUTO VOTE BERHASIL] Mengirim vote untuk: " .. cardName)
    end)
end

local function startAutoVote()
    task.spawn(function()
        while true do
            if Config.EnableAutoVote then
                pcall(function()
                    local playerGui = player:WaitForChild("PlayerGui", 5)
                    if playerGui then
                        
                        -- Mencari VoteFrame di dalam semua ScreenGui
                        local voteFrame = nil
                        for _, gui in pairs(playerGui:GetChildren()) do
                            if gui:IsA("ScreenGui") and gui:FindFirstChild("VoteFrame") then
                                voteFrame = gui.VoteFrame
                                break
                            end
                        end
                        
                        if voteFrame and voteFrame.Visible and not isVoting then
                            isVoting = true
                            print("[AUTO VOTE] VoteFrame terdeteksi!")
                            
                            task.wait(1) -- Beri jeda 1 detik agar nama kartu muncul sempurna di UI
                            
                            local bestCardName = nil
                            local bestWeight = 999
                            local firstAvailableCardName = nil
                            
                            -- Scan semua TextLabel di dalam VoteFrame untuk mencari nama kartu
                            for _, item in ipairs(voteFrame:GetDescendants()) do
                                if item:IsA("TextLabel") and item.Text ~= "" and item.Text ~= "Vote" then
                                    local cardName = item.Text
                                    
                                    if not firstAvailableCardName then
                                        firstAvailableCardName = cardName
                                    end
                                    
                                    local weight = getCardPriorityWeight(cardName)
                                    if weight < bestWeight then
                                        bestWeight = weight
                                        bestCardName = cardName
                                    end
                                end
                            end
                            
                            -- Eksekusi langsung ke Server
                            if bestCardName then
                                print("[AUTO VOTE] >>> MEMILIH PRIORITAS: " .. bestCardName .. " <<<")
                                sendVoteToServer(bestCardName)
                            elseif Config.VoteRandomIfNotFound and firstAvailableCardName then
                                print("[AUTO VOTE] >>> PRIORITAS TIDAK ADA. Memilih acak: " .. firstAvailableCardName .. " <<<")
                                sendVoteToServer(firstAvailableCardName)
                            else
                                print("[AUTO VOTE] Gagal menemukan nama kartu di UI.")
                            end
                            
                            task.wait(10) -- Jeda panjang agar tidak spam RemoteEvent berulang-ulang
                            isVoting = false
                        end
                    end
                end)
            end
            task.wait(1) 
        end
    end)
end

-- ==================== EKSEKUSI ====================
print("==================================================")
print(" AUTO VOTE SERVER-SIDED + GUI BERHASIL DIJALANKAN")
print("==================================================")
startAutoVote()
