                                validVoteFrame = vf
                                break
                            end
                        end
                    end
                    
                    if validVoteFrame and not isVoting then
                        isVoting = true
                        print(">> VOTE FRAME DI LAYAR! <<")
                        task.wait(1.5) 
                        
                        local bestWeight = 999
                        local bestInternalID = nil
                        local firstInternalID = nil
                        
                        for _, child in ipairs(validVoteFrame:GetChildren()) do
                            if child:IsA("GuiObject") and isOnScreen(child) and not string.find(child.Name, "Template") and child.Name ~= "UIListLayout" then
                                local internalID = child.Name
                                
                                if not firstInternalID then firstInternalID = internalID end
                                
                                for i, pID in ipairs(Config.PriorityCards) do
                                    if internalID == pID and i < bestWeight then
                                        bestWeight = i
                                        bestInternalID = internalID
                                        break
                                    end
                                end
                            end
                        end
                        
                        if bestInternalID then
                            executeMemoryVote(bestInternalID)
                        elseif Config.VoteRandomIfNotFound and firstInternalID then
                            print("⚠️ Memilih acak: " .. firstInternalID)
                            executeMemoryVote(firstInternalID)
                        end
                        
                        task.wait(10) 
                        isVoting = false
                    end
                end
            end)
        end
        task.wait(1) 
    end
end)

