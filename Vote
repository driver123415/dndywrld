-- ==================== DRAGGABLE LOGIC ====================
local dragging, dragInput, dragStart, startPos

local function updateInput(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateInput(input)
    end
end)

-- ==================== TOGGLE LOGIC ====================
toggleBtn.MouseButton1Click:Connect(function()
    Config.EnableAutoVote = not Config.EnableAutoVote
    if Config.EnableAutoVote then
        toggleBtn.Text = "ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 80)
        print("[GUI] Auto Vote: ON")
    else
        toggleBtn.Text = "OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        print("[GUI] Auto Vote: OFF")
    end
end)

-- ==================== FUNGSI AUTO VOTE ====================
local function getCardPriorityWeight(cardName)
    local nameLower = string.lower(cardName)
    for i, priorityName in ipairs(Config.PriorityCards) do
        if string.find(nameLower, string.lower(priorityName)) then
            return i 
        end
    end
    return 999 
end

local function startAutoVote()
    task.spawn(function()
        -- Loop sekarang berjalan terus, tapi aksi hanya dilakukan jika EnableAutoVote = true
        while true do
            if Config.EnableAutoVote then
                pcall(function()
                    local playerGui = player:WaitForChild("PlayerGui", 5)
                    if playerGui then
                        local mainUI = playerGui:FindFirstChild("MainUI") or playerGui:FindFirstChild("Main")
                        
                        if mainUI then
                            local cardMenu = mainUI:FindFirstChild("CardVote") or mainUI:FindFirstChild("CardSelection")
                            
                            if cardMenu and cardMenu.Visible and not isVoting then
                                isVoting = true
                                print("[AUTO VOTE] Layar pemilihan kartu terdeteksi!")
                                
                                task.wait(0.5) 
                                
                                local bestCard = nil
                                local bestWeight = 999
                                local firstAvailableCard = nil
                                
                                for _, item in ipairs(cardMenu:GetDescendants()) do
                                    if item:IsA("TextLabel") and (item.Name == "CardName" or item.Name == "Title") then
                                        local cardName = item.Text
                                        local cardButton = item.Parent 
                                        
                                        if cardButton and (cardButton:IsA("TextButton") or cardButton:IsA("ImageButton")) then
                                            if not firstAvailableCard then
                                                firstAvailableCard = cardButton
                                            end
                                            
                                            local weight = getCardPriorityWeight(cardName)
                                            
                                            if weight < bestWeight then
                                                bestWeight = weight
                                                bestCard = cardButton
                                            end
                                        end
                                    end
                                end
                                
                                if bestCard then
                                    print("[AUTO VOTE] >>> MEMILIH KARTU PRIORITAS: " .. bestCard:FindFirstChildWhichIsA("TextLabel").Text .. " <<<")
                                    if getconnections then
                                        for _, connection in pairs(getconnections(bestCard.MouseButton1Click)) do
                                            connection:Fire()
                                        end
                                    else
                                        print("[WARNING] Executor tidak support getconnections.")
                                    end
                                elseif Config.VoteRandomIfNotFound and firstAvailableCard then
                                    print("[AUTO VOTE] >>> PRIORITAS TIDAK ADA. Memilih acak! <<<")
                                    if getconnections then
                                        for _, connection in pairs(getconnections(firstAvailableCard.MouseButton1Click)) do
                                            connection:Fire()
                                        end
                                    end
                                end
                                
                                task.wait(10) 
                                isVoting = false
                            end
                        end
                    end
                end)
            end
            task.wait(1) -- Cek layar setiap 1 detik
        end
    end)
end

-- ==================== EKSEKUSI ====================
print("==================================================")
print(" AUTO VOTE BEST CARD + GUI BERHASIL DIJALANKAN")
