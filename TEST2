local Config = {
    
    -- [1] PENGATURAN AUTO PICKUP
    Pickup = {
        Enable = true,              
        TweenSpeed = 2.00, --ganti kecepatan dragTP       
        AuraRange = 30,             
        
        -- 1. PRIORITAS (Diambil duluan sesuai urutan dari atas ke bawah)
        PriorityList = {
            "ResearchCapsule",
            "HolidayCollectibleItem",
            "Holiday Collectible Item",
            "Tape"
        },
        
        -- 2. DAFTAR HITAM (Item ini TIDAK AKAN PERNAH diambil)
        IgnoreList = {
            "FakeCapsule"
        }
    },

    -- [2] PENGATURAN AUTO USE ITEM 
    AutoUse = {
        Enable = true,              
        UseInterval = 0.5,          -- Jeda 0.5 detik agar tidak lag/spam server
        
        Slots = {
            Slot1 = true,
            Slot2 = true,
            Slot3 = true,
            Slot4 = false           -- Slot 4 tidak akan otomatis terpakai
        }
    }
}
-- ==============================================================================
-- END OF CONFIGURATION (JANGAN UBAH KODE DI BAWAH KECUALI PAHAM)
-- ==============================================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

local isAuraActive = false
local isAutoUseActive = false

-- ==================== FUNGSI CEK DAFTAR HITAM ====================
local function isIgnored(itemName)
    for _, ignoreName in ipairs(Config.Pickup.IgnoreList) do
        if itemName == ignoreName then
            return true
        end
    end
    return false
end

-- ==================== FUNGSI AUTO USE ITEM ====================
local function startAutoUse()
    if not Config.AutoUse.Enable then return end
    isAutoUseActive = true
    
    task.spawn(function()
        print("[INFO] Auto Use Item mulai berjalan...")
        while isAutoUseActive do
            local char = player.Character
            if char and char:FindFirstChild("Inventory") then
                for slotName, isActive in pairs(Config.AutoUse.Slots) do
                    if isActive then
                        local slotItem = char.Inventory:FindFirstChild(slotName)
                        if slotItem then
                            pcall(function()
                                ReplicatedStorage.Events.ItemEvent:InvokeServer(char, slotItem)
                            end)
                        end
                    end
                end
            end
            task.wait(Config.AutoUse.UseInterval)
        end
    end)
end

-- ==================== FUNGSI AUTO PICKUP ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function interactWithPrompt(prompt)
    if prompt.HoldDuration == 0 then
        prompt:InputHoldBegin()
        prompt:InputHoldEnd()
    else
        prompt:InputHoldBegin()
        task.wait(prompt.HoldDuration)
        prompt:InputHoldEnd()
    end
end

local function startItemAura()
    isAuraActive = true
    task.spawn(function()
        while isAuraActive do
            local map = getMap()
            if map and rootPart then
                local itemsFolder = map:FindFirstChild("Items")
                if itemsFolder then
                    for _, item in pairs(itemsFolder:GetChildren()) do
                        -- Cek agar aura TIDAK mengambil item di daftar hitam
                        if not isIgnored(item.Name) then
                            local promptPart = item:FindFirstChild("Prompt")
                            if promptPart then
                                local proximityPrompt = promptPart:FindFirstChild("ProximityPrompt")
                                if proximityPrompt and proximityPrompt.Enabled then
                                    local distance = (promptPart.Position - rootPart.Position).Magnitude
                                    if distance <= Config.Pickup.AuraRange then
                                        interactWithPrompt(proximityPrompt)
                                    end
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.05)
        end
    end)
end

local function tweenToPosition(targetCFrame)
    local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
    local distance = (rootPart.Position - targetCFrame.Position).Magnitude
    local duration = distance / (speed * Config.Pickup.TweenSpeed)
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
    local tween = TweenService:Create(rootPart, tweenInfo, { CFrame = targetCFrame })
    
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    
    tween:Play()
    tween.Completed:Wait()
    
    Workspace.Gravity = originalGravity
end

local function executePickup()
    if not Config.Pickup.Enable then return end
    
    local map = getMap()
    if not map then 
        print("[ERROR] Map tidak ditemukan.") 
        return 
    end

    local itemsFolder = map:FindFirstChild("Items")
    if not itemsFolder or #itemsFolder:GetChildren() == 0 then
        print("[INFO] Tidak ada item tersisa di map ini.")
        return
    end

    print("[START] Menjalankan Auto Pickup...")
    local originalPosition = rootPart.CFrame
    startItemAura()
    
    -- Kumpulkan semua item yang BUKAN blacklist ke dalam antrean
    local validItems = {}
    for _, item in ipairs(itemsFolder:GetChildren()) do
        if item:IsA("Model") and not isIgnored(item.Name) then
            table.insert(validItems, item)
        end
    end

    local itemMendekat = 0

    -- LANGKAH 1: Ambil item PRIORITAS terlebih dahulu
    for _, priorityName in ipairs(Config.Pickup.PriorityList) do
        for i = #validItems, 1, -1 do
            local item = validItems[i]
            -- Cek item.Parent untuk memastikan item belum terhapus dari map
            if item.Name == priorityName and item.Parent then
                print("[PICKUP] Prioritas: " .. item.Name)
                itemMendekat = itemMendekat + 1
                tweenToPosition(item:GetPivot() * CFrame.new(0, -3.3, 0))
                task.wait(0.1)
                table.remove(validItems, i) -- Coret dari antrean karena sudah diambil
            end
        end
    end

    -- LANGKAH 2: Ambil sisa item yang TIDAK ADA di prioritas maupun blacklist
    for _, item in ipairs(validItems) do
        if item.Parent then
            print("[PICKUP] Sisa item: " .. item.Name)
            itemMendekat = itemMendekat + 1
            tweenToPosition(item:GetPivot() * CFrame.new(0, -3.3, 0))
            task.wait(0.1)
        end
    end

    print("[INFO] " .. itemMendekat .. " item diambil. Kembali ke posisi awal...")
    tweenToPosition(originalPosition)
    
    task.wait(0.2)
    isAuraActive = false
    print("[SUCCESS] Auto Pickup selesai!")
end

-- ==================== JALANKAN SCRIPT ====================
startAutoUse()
executePickup()
