local Config = {
    -- [1] PENGATURAN AUTO PICKUP
    Pickup = {
        Enable = true,              
        MovementMode = "Instant",   -- PILIHAN: "Tween" (Aman, meluncur) ATAU "Instant" (Teleport kilat)
        TweenSpeed = 1.25,          
        AuraRange = 30,             
        
        -- 1. PRIORITAS (Wajib diambil paling pertama sebelum item lain)
        PriorityList = {
            "ResearchCapsule",
            "HolidayCollectibleItem",
            "Holiday Collectible Item",
            "Tape"
        },
        
        -- 2. DAFTAR HITAM (Mutlak TIDAK AKAN diambil, dibiarkan saja di map)
        IgnoreList = {
             "FakeCapsule"
        }
    },

    -- [2] PENGATURAN ESP ITEM
    ESP = {
        Enable = true               
    },

    -- [3] PENGATURAN AUTO USE ITEM 
    AutoUse = {
        Enable = true,              
        UseInterval = 0.1,          
        Slots = {
            Slot1 = true,
            Slot2 = true,
            Slot3 = true,
            Slot4 = false            
        }
    }
}
-- ==============================================================================
-- END OF CONFIGURATION
-- ==============================================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

local isAuraActive = false
local isAutoUseActive = false

-- ==================== FUNGSI FILTERING ITEM ====================
-- Mengecek apakah item ada di daftar Blacklist (Abaikan Case & Spasi)
local function isIgnored(itemName)
    local nameLower = string.lower(itemName)
    for _, blackName in ipairs(Config.Pickup.IgnoreList) do
        if string.find(nameLower, string.lower(blackName), 1, true) then
            return true
        end
    end
    return false
end

-- Mengecek apakah item ada di daftar Prioritas
local function isPriority(itemName)
    local nameLower = string.lower(itemName)
    for _, prioName in ipairs(Config.Pickup.PriorityList) do
        if string.find(nameLower, string.lower(prioName), 1, true) then
            return true
        end
    end
    return false
end

-- ==================== FUNGSI ITEM ESP ====================
local function applyItemESP()
    if not Config.ESP.Enable then return end
    
    local map = Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
    if map and map:FindFirstChild("Items") then
        for _, item in ipairs(map.Items:GetChildren()) do
            if item:IsA("Model") and not item:FindFirstChild("ItemESP") then
                
                local highlight = Instance.new("Highlight")
                highlight.Name = "ItemESP"
                highlight.Parent = item
                highlight.FillTransparency = 0.5
                
                -- Set Warna ESP
                if isIgnored(item.Name) then
                    highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Merah (Dibiarkan)
                elseif isPriority(item.Name) then
                    highlight.FillColor = Color3.fromRGB(255, 255, 0) -- Kuning (Prioritas)
                else
                    highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Hijau (Sisa Item / Normal)
                end
                
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ItemESPText"
                billboard.Adornee = item
                billboard.Size = UDim2.new(0, 100, 0, 50)
                billboard.AlwaysOnTop = true
                billboard.Parent = item
                
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = item.Name
                label.TextColor3 = highlight.FillColor
                label.TextStrokeTransparency = 0.5
                label.TextSize = 14
                label.Parent = billboard
            end
        end
    end
end

-- ==================== FUNGSI AUTO USE ITEM ====================
local function startAutoUse()
    if not Config.AutoUse.Enable then return end
    isAutoUseActive = true
    
    task.spawn(function()
        while isAutoUseActive do
            local char = player.Character
            if char and char:FindFirstChild("Inventory") then
                for slotName, isActive in pairs(Config.AutoUse.Slots) do
                    if isActive then
                        local slotItem = char.Inventory:FindFirstChild(slotName)
                        if slotItem then
                            pcall(function()
                                ReplicatedStorage.Events.ItemEvent:InvokeServer(char, slotItem)
                            end)
                        end
                    end
                end
            end
            task.wait(Config.AutoUse.UseInterval)
        end
    end)
end

-- ==================== FUNGSI MOVEMENT & INTERAKSI ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function interactWithPrompt(prompt)
    if prompt.HoldDuration == 0 then
        prompt:InputHoldBegin()
        prompt:InputHoldEnd()
    else
        prompt:InputHoldBegin()
        task.wait(prompt.HoldDuration)
        prompt:InputHoldEnd()
    end
end

-- Aura berjalan di background sebagai backup trigger
local function startItemAura()
    isAuraActive = true
    task.spawn(function()
        while isAuraActive do
            local map = getMap()
            if map and rootPart then
                local itemsFolder = map:FindFirstChild("Items")
                if itemsFolder then
                    for _, item in pairs(itemsFolder:GetChildren()) do
                        if not isIgnored(item.Name) then
                            local promptPart = item:FindFirstChild("Prompt")
                            if promptPart then
                                local proximityPrompt = promptPart:FindFirstChild("ProximityPrompt")
                                if proximityPrompt and proximityPrompt.Enabled then
                                    local distance = (promptPart.Position - rootPart.Position).Magnitude
                                    if distance <= Config.Pickup.AuraRange then
                                        interactWithPrompt(proximityPrompt)
                                    end
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

local function moveToPosition(targetCFrame)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    
    if Config.Pickup.MovementMode == "Instant" then
        rootPart.CFrame = targetCFrame
        task.wait(0.05)
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local distance = (rootPart.Position - targetCFrame.Position).Magnitude
        local duration = distance / (speed * Config.Pickup.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(rootPart, tweenInfo, { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    
    Workspace.Gravity = originalGravity
end

-- ==================== FUNGSI PUSAT (CENTER LOCATOR) ====================
local function getModelCenter(model)
    if not model or not model:IsA("Model") then return nil end
    local parts = {}
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            table.insert(parts, part)
        end
    end
    if #parts == 0 then return nil end
    local totalPosition = Vector3.zero
    for _, part in pairs(parts) do
        totalPosition = totalPosition + part.Position
    end
    return totalPosition / #parts
end

-- ==================== FUNGSI UTAMA AUTO PICKUP ====================
local function executePickup()
    if not Config.Pickup.Enable then return end
    
    local map = getMap()
    if not map then return end

    applyItemESP()
    startItemAura()
    
    local maxLoops = 8 -- Putaran diperbanyak untuk memastikan map benar-benar bersih
    local currentLoop = 1
    local hasCleanedAll = false

    while currentLoop <= maxLoops and not hasCleanedAll do
        local itemsFolder = map:FindFirstChild("Items")
        if not itemsFolder then break end
        
        local priorityItems = {}
        local normalItems = {}

        -- Filter item ke dalam 2 kategori: Prioritas dan Normal (Mengabaikan Blacklist mutlak)
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if item:IsA("Model") and not isIgnored(item.Name) then
                if isPriority(item.Name) then
                    table.insert(priorityItems, item)
                else
                    table.insert(normalItems, item)
                end
            end
        end

        -- Mengecek apakah semua item (Prioritas & Normal) sudah habis
        if #priorityItems == 0 and #normalItems == 0 then
            hasCleanedAll = true
            print("[INFO] Pengecekan Loop " .. currentLoop .. ": Seluruh item di map telah habis dibersihkan!")
            break
        end

        local itemsToProcess = {}
        
        -- LOGIKA 2 TAHAP: Selesaikan Prioritas dulu, baru sisanya
        if #priorityItems > 0 then
            print("[INFO] Ditemukan " .. #priorityItems .. " item PRIORITAS. Membersihkan prioritas terlebih dahulu...")
            itemsToProcess = priorityItems
        else
            print("[INFO] Prioritas habis. Mengambil " .. #normalItems .. " item sisa (NORMAL)...")
            itemsToProcess = normalItems
        end

        -- SORTING JARAK: Mencari item terdekat di dalam kategori yang sedang diproses
        table.sort(itemsToProcess, function(a, b)
            local distA = (rootPart.Position - a:GetPivot().Position).Magnitude
            local distB = (rootPart.Position - b:GetPivot().Position).Magnitude
            return distA < distB
        end)

        -- EKSEKUSI PENGAMBILAN ITEM
        for _, item in ipairs(itemsToProcess) do
            if item and item.Parent and not isIgnored(item.Name) then
                print("[PICKUP] Bergerak ke: " .. item.Name)
                
                local targetCFrame = item:GetPivot() * CFrame.new(0, -3.3, 0)
                
                -- BIKIN PLATFORM ANTI JATUH (Diubah sedikit transparan agar nyaman dilihat)
                local platform = Instance.new("Part")
                platform.Size = Vector3.new(10, 1, 10)
                platform.Anchored = true
                platform.CanCollide = true
                platform.Transparency = 0.5 
                platform.Color = Color3.fromRGB(0, 255, 0)
                platform.CFrame = targetCFrame * CFrame.new(0, -3, 0)
                platform.Parent = Workspace
                
                moveToPosition(targetCFrame)
                
                -- EKSEKUSI INSTAN
                local promptPart = item:FindFirstChild("Prompt")
                if promptPart then
                    local proximityPrompt = promptPart:FindFirstChild("ProximityPrompt")
                    if proximityPrompt and proximityPrompt.Enabled then
                        interactWithPrompt(proximityPrompt)
                    end
                end
                
                -- VALIDASI: Tunggu item hilang sebelum pindah
                local timeout = 15 
                while item.Parent and timeout > 0 do
                    task.wait(0.1)
                    timeout = timeout - 1
                end
                
                -- HANCURKAN PLATFORM SETELAH SELESAI
                if platform then
                    platform:Destroy()
                end
            end
        end
        currentLoop = currentLoop + 1
        task.wait(0.5) -- Jeda nafas sebelum scanning ulang map
    end

    isAuraActive = false

    -- TAHAP AKHIR: TELEPORT KE FAKEELEVATOR (Setelah semua item Prioritas & Normal habis)
    print("[INFO] Semua item telah diambil. Mencari FakeElevator di map...")
    local freeArea = map:FindFirstChild("FreeArea")
    if freeArea then
        local fakeElevator = freeArea:FindFirstChild("FakeElevator")
        if fakeElevator and fakeElevator:IsA("Model") then
            print("[SUCCESS] FakeElevator ditemukan! Memulai Teleportasi...")
            local centerPos = getModelCenter(fakeElevator)
            if centerPos then
                moveToPosition(CFrame.new(centerPos + Vector3.new(0, 4, 0)))
            end
        else
            print("[WARNING] FakeElevator tidak ditemukan di FreeArea!")
        end
    else
        print("[WARNING] FreeArea tidak ditemukan!")
    end

    print("[DONE] Script Eksekusi Selesai!")
end

-- ==================== JALANKAN SCRIPT ====================
startAutoUse()
executePickup()
