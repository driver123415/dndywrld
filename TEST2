local dragging, dragInput, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ==================== FUNGSI BANTUAN ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function getModelCenter(model)
    if not model or not model:IsA("Model") then return nil end
    local parts = {}
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then table.insert(parts, part) end
    end
    if #parts == 0 then return nil end
    local totalPosition = Vector3.zero
    for _, part in pairs(parts) do totalPosition = totalPosition + part.Position end
    return totalPosition / #parts
end

local function forceStop()
    local decoding = character:FindFirstChild("Decoding")
    if decoding and decoding.Value ~= nil then
        pcall(function()
            decoding.Value.Stats.StopInteracting:FireServer("Stop")
        end)
    end
end

-- ==================== REFERENSI ANTI MONSTER & ANTI VOID ====================
local function getFakeElevatorPosition()
    local map = getMap()
    if map then
        local freeArea = map:FindFirstChild("FreeArea")
        if freeArea then
            local fakeElevator = freeArea:FindFirstChild("FakeElevator")
            if fakeElevator and fakeElevator:IsA("Model") then
                return getModelCenter(fakeElevator)
            end
        end
    end
    return nil
end

local function clientinvalidposdetect(playerposition)
    if not playerposition or typeof(playerposition) ~= "Vector3" then return false end
    if playerposition.Magnitude > 2000 then return false end
    if playerposition.Y < 80 then return false end
    if playerposition.X ~= playerposition.X or (playerposition.Y ~= playerposition.Y or playerposition.Z ~= playerposition.Z) then return false end
    return true
end

local function getSproutTantacleCFrames()
    local cframes = {}
    local map = getMap()
    if map then
        local freeArea = map:FindFirstChild("FreeArea")
        if freeArea then
            for _, obj in ipairs(freeArea:GetChildren()) do
                if obj.Name == "SproutTendril" and obj:IsA("Model") then
                    table.insert(cframes, obj:GetPivot())
                end
            end
        end
    end
    return cframes
end

-- ==================== FUNGSI MOVEMENT & PLATFORM ====================
local function moveToPosition(targetCFrame, usePlatform)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.Anchored = false
    
    if activePlatform then
        activePlatform:Destroy()
        activePlatform = nil
    end
    
    if usePlatform then
        activePlatform = Instance.new("Part")
        activePlatform.Size = Vector3.new(15, 1, 15)
        activePlatform.Anchored = true
        activePlatform.CanCollide = true
        activePlatform.Transparency = 0.5
        activePlatform.Color = Color3.fromRGB(0, 255, 0)
        activePlatform.CFrame = targetCFrame * CFrame.new(0, -3.5, 0)
        activePlatform.Parent = Workspace
    end
    
    if Config.Teleport.Mode == "Instant" then
        character:PivotTo(targetCFrame)
        task.wait(0.1) 
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local distance = (rootPart.Position - targetCFrame.Position).Magnitude
        local duration = distance / (speed * Config.Teleport.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(rootPart, tweenInfo, { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    
    if usePlatform then
        rootPart.Anchored = true 
    end
    Workspace.Gravity = 196.2
end

