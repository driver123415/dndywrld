local function updateGeneratorESP()
    local map = getMap()
    if not map then return end
    local genFolder = map:FindFirstChild("Generators")
    if genFolder then
        for _, gen in pairs(genFolder:GetChildren()) do
            if gen:IsA("Model") then
                if not isFarmerToggledON or not Config.ESP.Enable then
                    if gen:FindFirstChild("GenESP") then gen.GenESP:Destroy() end
                    if gen:FindFirstChild("GenText") then gen.GenText:Destroy() end
                    continue
                end
                
                local highlight = gen:FindFirstChild("GenESP")
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "GenESP"
                    highlight.Parent = gen
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.5
                end
                
                local billboard = gen:FindFirstChild("GenText")
                local label
                if not billboard then
                    billboard = Instance.new("BillboardGui")
                    billboard.Name = "GenText"
                    billboard.Adornee = gen
                    billboard.Size = UDim2.new(0, 100, 0, 50)
                    billboard.AlwaysOnTop = true
                    billboard.Parent = gen
                    label = Instance.new("TextLabel")
                    label.Name = "Text"
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Font = Enum.Font.Nunito
                    label.TextStrokeTransparency = 0.5
                    label.TextSize = 16
                    label.Parent = billboard
                else
                    label = billboard.Text
                end

                local stats = gen:FindFirstChild("Stats")
                if stats then
                    local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                    local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                    local current = stats:FindFirstChild("CurrentAmount") and math.floor(stats.CurrentAmount.Value + 0.5) or 0
                    local required = stats:FindFirstChild("RequiredAmount") and stats.RequiredAmount.Value or 0
                    
                    local genName = gen.Name
                    local textColor = Config.ESP.NormalColor
                    if connie then
                        textColor = Config.ESP.PossessedColor
                        genName = genName .. "\n[POSSESSED]"
                        highlight.FillColor = Config.ESP.PossessedColor
                    elseif completed then
                        textColor = Config.ESP.CompletedColor
                        highlight.FillColor = Config.ESP.CompletedColor
                    else
                        textColor = Config.ESP.NormalColor
                        highlight.FillColor = Config.ESP.NormalColor
                    end
                    label.TextColor3 = textColor
                    label.Text = genName .. "\n(" .. current .. " / " .. required .. ")"
                end
            end
        end
    end
end

-- ==================== FIXED ELEVATOR FINDER ====================
local function teleportToRealElevator()
    local map = getMap()
    if map then
        print("[INFO] Mencari Real Elevator...")
        -- Tanpa butuh PrimaryPart, hajar semua model bernama "Elevator"
        for _, child in ipairs(map:GetDescendants()) do
            if child:IsA("Model") then
                local nameLower = string.lower(child.Name)
                if string.find(nameLower, "elevator") and not string.find(nameLower, "fake") then
                    local centerPos = getModelCenter(child)
                    if centerPos then
                        rootPart.Anchored = false 
                        if activePlatform then activePlatform:Destroy() activePlatform = nil end
                        
                        print("[SUCCESS] Real Elevator ditemukan! Meluncur...")
                        moveToPosition(CFrame.new(centerPos + Vector3.new(0, 4, 0)), false)
                        return true
                    end
                end
            end
        end
        print("[WARNING] Elevator tidak ditemukan.")
    end
    return false
end

-- ==================== FUNGSI UTAMA FARMING ====================
local function forceTriggerGenerator(generator)
    for _, descendant in ipairs(generator:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            descendant.RequiresLineOfSight = false
            descendant.MaxActivationDistance = 100 
            pcall(function() descendant:InputHoldBegin() end)
            return true
        end
    end
    return false
end

local function startAutoFarming()
    task.spawn(function()
        while not _G.KillOldFarmer do
            if not isFarmerToggledON or not Config.Teleport.Enable or _G.IsEvading then
                task.wait(1)
                continue
            end
            
            local map = getMap()
            if map then
                local genFolder = map:FindFirstChild("Generators")
                if genFolder then
                    local targetGen = nil
                    local uncompletedCount = 0
                    
                    for _, gen in pairs(genFolder:GetChildren()) do
                        if gen:IsA("Model") and gen.PrimaryPart then
                            local stats = gen:FindFirstChild("Stats")
                            if stats then
                                local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                                local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                                
                                if not completed then
                                    uncompletedCount = uncompletedCount + 1
                                    if not connie and not targetGen then
                                        if not isMachineOccupied(gen, Config.Teleport.PlayerRadius) then
                                            targetGen = gen
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    if uncompletedCount == 0 then
                        teleportToRealElevator()
                        task.wait(5)
                        
                    elseif targetGen then
                        local centerPos = getModelCenter(targetGen)
                        if centerPos and targetGen.PrimaryPart then
                            local hiddenCFrame = CFrame.new(centerPos.X, targetGen.PrimaryPart.Position.Y + Config.Teleport.OffsetHidden, centerPos.Z)
                            local farmingCFrame = CFrame.new(centerPos.X, targetGen.PrimaryPart.Position.Y + Config.Teleport.OffsetFarming, centerPos.Z)
                            
                            moveToPosition(hiddenCFrame, true)
                            task.wait(0.1)
                            
                            -- FIX: Gunakan variabel agar prompt tidak dispam!
                            local promptFired = false 
                            
                            while targetGen.Parent and isFarmerToggledON and not _G.KillOldFarmer and not _G.IsEvading do
                                local stats = targetGen:FindFirstChild("Stats")
                                if stats and stats:FindFirstChild("Completed") and stats.Completed.Value then break end
                                if isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then break end
                                
                                local isDecoding = character:FindFirstChild("Decoding") and character.Decoding.Value ~= nil
                                
                                if isDecoding then
                                    promptFired = false -- Reset state jika nanti putus
                                    rootPart.CFrame = farmingCFrame
                                    if activePlatform then activePlatform.CFrame = farmingCFrame * CFrame.new(0, -3.5, 0) end
                                    rootPart.Anchored = true
                                else
                                    rootPart.CFrame = hiddenCFrame
                                    if activePlatform then activePlatform.CFrame = hiddenCFrame * CFrame.new(0, -3.5, 0) end
                                    rootPart.Anchored = true
                                    
                                    -- FIX: Tembak prompt HANYA 1 KALI, bukan di-spam setiap 0.1 detik
                                    if not promptFired then
                                        forceTriggerGenerator(targetGen)
                                        promptFired = true
                                    end
                                end
                                task.wait(0.1)
                            end
                            
                            if not _G.IsEvading then
                                rootPart.Anchored = false
                                if activePlatform then activePlatform:Destroy() activePlatform = nil end
                                task.wait(Config.Teleport.DelayNext)
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
    
    task.spawn(function()
        while not _G.KillOldFarmer do
            updateGeneratorESP()
            task.wait(0.5)
        end
    end)
end

