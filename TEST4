-- CONFIGURATION: AUTO MACHINE FARMER V13 (BRUTE-FORCE ELEVATOR & FIXED RADIUS)
-- ==============================================================================
local Config = {
    Skillcheck = { Enable = false }, 
    Teleport = {
        Enable = true,          
        Mode = "Instant",       
        TweenSpeed = 1.25,      
        SafeRadius = 30,        -- Jarak aman dari monster
        PlayerRadius = 8,       
        DelayNext = 1.0,        
        UndergroundOffset = 11.5
    },
    ESP = {
        Enable = true,          
        ShowSafeRadius = true,  -- Lingkaran merah penanda batas aman
        NormalColor = Color3.fromRGB(150, 150, 150),   
        CompletedColor = Color3.fromRGB(255, 0, 255),  
        PossessedColor = Color3.fromRGB(0, 255, 255)   
    }
}
-- ==============================================================================
-- END OF CONFIGURATION
-- ==============================================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

local isFarming = false

-- ==================== FUNGSI BANTUAN DASAR ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function getModelCenter(model)
    if not model or not model:IsA("Model") then return nil end
    local parts = {}
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then table.insert(parts, part) end
    end
    if #parts == 0 then return nil end
    local totalPosition = Vector3.zero
    for _, part in pairs(parts) do totalPosition = totalPosition + part.Position end
    return totalPosition / #parts
end

-- ==================== FUNGSI VISUALISASI RADIUS AMAN (DIPERBAIKI) ====================
local safeRadiusAdornment
local function updateSafeRadiusVisual()
    if not Config.ESP.ShowSafeRadius then
        if safeRadiusAdornment then safeRadiusAdornment:Destroy(); safeRadiusAdornment = nil end
        return
    end
    
    if not safeRadiusAdornment and rootPart then
        -- Menggunakan CylinderHandleAdornment agar tidak terpengaruh fisika/tanah
        safeRadiusAdornment = Instance.new("CylinderHandleAdornment")
        safeRadiusAdornment.Name = "SafeRadiusVisual"
        safeRadiusAdornment.Radius = Config.Teleport.SafeRadius
        safeRadiusAdornment.Height = 0.1
        safeRadiusAdornment.Color3 = Color3.fromRGB(255, 50, 50)
        safeRadiusAdornment.Transparency = 0.5
        safeRadiusAdornment.CFrame = CFrame.Angles(math.rad(90), 0, 0)
        safeRadiusAdornment.ZIndex = 0
        safeRadiusAdornment.AlwaysOnTop = true -- Memastikan selalu terlihat menembus tembok/lantai
        safeRadiusAdornment.Adornee = rootPart
        safeRadiusAdornment.Parent = rootPart
    end
end

-- ==================== SISTEM DETEKSI ANCAMAN ====================
local function isTargetedByMonster()
    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                if monster:FindFirstChild("ChasingValue") and monster.ChasingValue.Value == character then
                    return true 
                end
            end
        end
    end
    return false
end

local function isMonsterNear(targetPosition, radius)
    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                if monster:IsA("Model") and monster.PrimaryPart then
                    local distance = (monster.PrimaryPart.Position - targetPosition).Magnitude
                    if distance <= radius then return true end
                end
            end
        end
    end
    return false
end

local function isMachineOccupied(generator, radius)
    local inGamePlayers = Workspace:FindFirstChild("InGamePlayers")
    if inGamePlayers then
        for _, otherPlayer in ipairs(inGamePlayers:GetChildren()) do
            if otherPlayer.Name ~= player.Name then
                local otherRoot = otherPlayer:FindFirstChild("HumanoidRootPart")
                if otherRoot and generator.PrimaryPart then
                    if (otherRoot.Position - generator.PrimaryPart.Position).Magnitude <= radius then return true end
                end
            end
        end
    end
    return false
end

local function forceStop()
    local decoding = character:FindFirstChild("Decoding") and character.Decoding.Value
    if decoding ~= nil then
        pcall(function() decoding.Stats.StopInteracting:FireServer("Stop") end)
    end
end

local function getFakeElevatorPosition()
    local map = getMap()
    if map then
        local freeArea = map:FindFirstChild("FreeArea")
        if freeArea then
            local fakeElevator = freeArea:FindFirstChild("FakeElevator")
            if fakeElevator and fakeElevator:IsA("Model") then
                return getModelCenter(fakeElevator)
            end
        end
    end
    return nil
end

local function teleportplr(cf)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    character:PivotTo(cf)
    Workspace.Gravity = originalGravity
end

-- ==================== FUNGSI ESP GENERATOR ====================
local function updateGeneratorESP()
    if not Config.ESP.Enable then return end
    local map = getMap()
    if not map then return end
    local generatorsFolder = map:FindFirstChild("Generators")
    if generatorsFolder then
        for _, gen in pairs(generatorsFolder:GetChildren()) do
            if gen:IsA("Model") then
                local highlight = gen:FindFirstChild("GenESP")
                if not highlight then
                    highlight = Instance.new("Highlight", gen)
                    highlight.Name = "GenESP"
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.5
                end
                
                local billboard = gen:FindFirstChild("GenText")
                local label
                if not billboard then
                    billboard = Instance.new("BillboardGui", gen)
                    billboard.Name = "GenText"
                    billboard.Size = UDim2.new(0, 100, 0, 50)
                    billboard.AlwaysOnTop = true
                    label = Instance.new("TextLabel", billboard)
                    label.Name = "Text"
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Font = Enum.Font.Nunito
                    label.TextStrokeTransparency = 0.5
                    label.TextSize = 16
                else
                    label = billboard.Text
                end

                local stats = gen:FindFirstChild("Stats")
                if stats then
                    local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                    local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                    local current = stats:FindFirstChild("CurrentAmount") and math.floor(stats.CurrentAmount.Value + 0.5) or 0
                    local required = stats:FindFirstChild("RequiredAmount") and stats.RequiredAmount.Value or 0
                    
                    local genName = gen.Name
                    if connie then
                        label.TextColor3 = Config.ESP.PossessedColor
                        highlight.FillColor = Config.ESP.PossessedColor
                        genName = genName .. "\n[POSSESSED]"
                    elseif completed then
                        label.TextColor3 = Config.ESP.CompletedColor
                        highlight.FillColor = Config.ESP.CompletedColor
                    else
                        label.TextColor3 = Config.ESP.NormalColor
                        highlight.FillColor = Config.ESP.NormalColor
                    end
                    label.Text = genName .. "\n(" .. current .. " / " .. required .. ")"
                end
            end
        end
    end
end

-- ==================== FUNGSI GERAKAN & ELEVATOR (BRUTE FORCE METHOD) ====================
local function forceTriggerGenerator(generator)
    for _, descendant in ipairs(generator:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            descendant.RequiresLineOfSight = false
            descendant.MaxActivationDistance = 100 
            pcall(function() descendant:InputHoldBegin() end)
            return true
        end
    end
    return false
end

local function moveToPosition(targetCFrame, usePlatform)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.Anchored = false
    
    if Config.Teleport.Mode == "Instant" then
        rootPart.CFrame = targetCFrame
        task.wait(0.1) 
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local distance = (rootPart.Position - targetCFrame.Position).Magnitude
        local duration = distance / (speed * Config.Teleport.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    
    if usePlatform then
        rootPart.CFrame = targetCFrame
        rootPart.Anchored = true 
    end
    Workspace.Gravity = originalGravity
end

local function teleportToRealElevator()
    local map = getMap()
    if not map then return false end
    print("[INFO] Semua Mesin Selesai! Mencoba Semua Elevator...")
    rootPart.Anchored = false 
    
    local elevatorList = {}
    
    -- Mengumpulkan semua model bernama Elevator
    for _, descendant in ipairs(map:GetDescendants()) do
        if descendant:IsA("Model") and string.find(string.lower(descendant.Name), "elevator") and not string.find(string.lower(descendant.Name), "fake") then
            table.insert(elevatorList, descendant)
        end
    end
    
    if #elevatorList == 0 then
        print("[WARNING] Tidak ada elevator sama sekali di map ini!")
        return false
    end
    
    -- Mencoba masuk ke setiap Elevator satu per satu
    for index, elev in ipairs(elevatorList) do
        print("[ELEVATOR] Mencoba masuk ke Elevator #" .. index)
        local centerPos = getModelCenter(elev)
        
        if centerPos then
            moveToPosition(CFrame.new(centerPos) * CFrame.new(0, 4, 0), false)
        elseif elev.PrimaryPart then
            moveToPosition(elev.PrimaryPart.CFrame * CFrame.new(0, 4, 0), false)
        end
        
        -- Diam selama 2 detik untuk memastikan apakah gamenya ter-trigger pindah lantai
        task.wait(2)
        
        if not isFarming then break end -- Jika player mematikan script saat mencoba
    end
    
    return true
end

-- ==================== FUNGSI UTAMA FARMING ====================
local function startAutoFarming()
    task.spawn(function()
        while isFarming do
            updateGeneratorESP()
            updateSafeRadiusVisual()
            task.wait(0.1)
        end
        if safeRadiusAdornment then safeRadiusAdornment:Destroy(); safeRadiusAdornment = nil end
    end)

    task.spawn(function()
        while isFarming do
            pcall(function()
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local su = events:FindFirstChild("SkillcheckUpdate")
                    if su then su.OnClientInvoke = function() return true end end
                end
            end)
            task.wait(1)
        end
    end)

    task.spawn(function()
        while isFarming do
            if Config.Teleport.Enable then
                local map = getMap()
                if map then
                    local genFolder = map:FindFirstChild("Generators")
                    if genFolder then
                        local targetGen = nil
                        local uncompletedCount = 0
                        
                        for _, gen in pairs(genFolder:GetChildren()) do
                            if gen:IsA("Model") and gen.PrimaryPart then
                                local stats = gen:FindFirstChild("Stats")
                                if stats then
                                    local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                                    local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                                    
                                    if not completed then
                                        uncompletedCount = uncompletedCount + 1
                                        if not connie and not targetGen then
                                            if not isMonsterNear(gen.PrimaryPart.Position, Config.Teleport.SafeRadius) and not isMachineOccupied(gen, Config.Teleport.PlayerRadius) then
                                                targetGen = gen
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        
                        if uncompletedCount == 0 then
                            teleportToRealElevator()
                            task.wait(3) -- Tunggu sebelum memindai generator lagi
                            
                        elseif targetGen then
                            local centerPos = getModelCenter(targetGen)
                            if centerPos and targetGen.PrimaryPart then
                                local targetCFrame = CFrame.new(centerPos.X, targetGen.PrimaryPart.Position.Y + Config.Teleport.UndergroundOffset, centerPos.Z)
                                moveToPosition(targetCFrame, true)
                                task.wait(0.1)
                                
                                while isFarming and targetGen.Parent do
                                    local stats = targetGen:FindFirstChild("Stats")
                                    if stats and stats:FindFirstChild("Completed") and stats.Completed.Value then
                                        break 
                                    end
                                    
                                    if isTargetedByMonster() or isMonsterNear(rootPart.Position, Config.Teleport.SafeRadius) then
                                        print("[SAFETY] Bahaya! Monster terdeteksi! Mengevakuasi...")
                                        forceStop()
                                        rootPart.Anchored = false
                                        
                                        local safePos = getFakeElevatorPosition()
                                        if safePos then
                                            teleportplr(CFrame.new(safePos))
                                        else
                                            teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0))
                                        end
                                        
                                        task.wait(5)
                                        break
                                    end
                                    
                                    if isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then
                                        forceStop()
                                        break
                                    end
                                    
                                    rootPart.CFrame = targetCFrame
                                    local isDecoding = character:FindFirstChild("Decoding") and character.Decoding.Value ~= nil
                                    if not isDecoding then
                                        forceTriggerGenerator(targetGen)
                                    end
                                    
                                    task.wait(0.1)
                                end
                                
                                rootPart.Anchored = false
                                task.wait(Config.Teleport.DelayNext)
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
end

