toggleBtn.Position = UDim2.new(0.5, -75, 0, 20)
toggleBtn.Text = "START FARMING"
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
