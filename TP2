-- ==========================================
-- LOGIKA DRAGGING (Geser UI)
-- ==========================================
local dragging, dragInput, mousePos, framePos

TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		mousePos = input.Position
		framePos = MainFrame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

TopBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - mousePos
		MainFrame.Position = UDim2.new(
			framePos.X.Scale, framePos.X.Offset + delta.X,
			framePos.Y.Scale, framePos.Y.Offset + delta.Y
		)
	end
end)

-- ==========================================
-- LOGIKA TOMBOL (Min, Close, Teleport)
-- ==========================================
local isMinimized = false
MinButton.MouseButton1Click:Connect(function()
	isMinimized = not isMinimized
	if isMinimized then
		MainFrame:TweenSize(UDim2.new(0, 300, 0, 30), "Out", "Quad", 0.3, true)
		ContentFrame.Visible = false
	else
		MainFrame:TweenSize(UDim2.new(0, 300, 0, 130), "Out", "Quad", 0.3, true)
		ContentFrame.Visible = true
	end
end)

CloseButton.MouseButton1Click:Connect(function()
	ScreenGui:Destroy()
end)

TeleportBtn.MouseButton1Click:Connect(function()
	local inputText = CoordInput.Text
	
	-- Menghapus spasi agar mudah diproses
	inputText = string.gsub(inputText, " ", "")
	
	-- Memecah teks berdasarkan koma
	local coords = string.split(inputText, ",")
	
	-- Mengecek apakah setidaknya ada 3 angka (X, Y, Z)
	if #coords >= 3 then
		local x = tonumber(coords[1])
		local y = tonumber(coords[2])
		local z = tonumber(coords[3])
		
		if x and y and z then
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			
			if hrp then
				hrp.CFrame = CFrame.new(x, y, z)
				
				-- Animasi tombol sukses
				local oriColor = TeleportBtn.BackgroundColor3
				TeleportBtn.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
				TeleportBtn.Text = "Success!"
				task.wait(1)
				TeleportBtn.BackgroundColor3 = oriColor
				TeleportBtn.Text = "Teleport"
			end
		else
			CoordInput.Text = "Format salah! Gunakan angka."
			task.wait(1.5)
			CoordInput.Text = ""
		end
	else
		CoordInput.Text = "Butuh X, Y, Z!"
		task.wait(1.5)
		CoordInput.Text = ""
	end
end)
