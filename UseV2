-- ==============================================================================
-- STANDALONE SCRIPT: SMART AUTO USE ITEM (V28 - ISOLATION TEST)
-- ==============================================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local Config = {
    AutoUse = {
        Enable = true,              
        UseInterval = 0.1, 
        
        EnableAutoBuff = true,      
        
        Slots = { Slot1 = true, Slot2 = true, Slot3 = true, Slot4 = false },
        
        ItemCategories = {
            StaminaAndBuffs = {
                "ProteinBar", "SpeedCandy", "StaminaCandy", "ExtractionSpeedCandy", "StealthCandy",
                "SkillCheckCandy", "Pop", "PopBottle", "Chocolate", "ChocolateBox",
                "Gumball", "Jawbreaker", "BonBon", "ChristmasCookie", "DandyEasterEggs"
            }
        }
    }
}

if not Config.AutoUse.Enable then return end
print("[SYSTEM] V28 Berjalan: Mengetes Filter Kategori (Tanpa UI Check)")

task.spawn(function()
    while true do
        local char = player.Character
        if char and char:FindFirstChild("Inventory") then
            
            for slotName, isActive in pairs(Config.AutoUse.Slots) do
                if isActive then
                    local slotItem = char.Inventory:FindFirstChild(slotName)
                    
                    if slotItem and slotItem:IsA("StringValue") then
                        local val = string.gsub(slotItem.Value, "%s+", "") -- Bersihin spasi
                        
                        -- LOGIKA PINTAR: HANYA CEK KATEGORI BUFF
                        if val ~= "None" and val ~= "" then
                            local shouldUse = false
                            
                            -- Cocokkan dengan kategori StaminaAndBuffs
                            for _, buffName in ipairs(Config.ItemCategories.StaminaAndBuffs) do
                                if string.find(string.lower(val), string.lower(buffName)) then
                                    shouldUse = Config.AutoUse.EnableAutoBuff
                                    break
                                end
                            end

                            -- EKSEKUSI JIKA COCOK
                            if shouldUse then
                                print("[ACTION] 🔥 Menemukan Item Buff! Mengeksekusi: " .. val)
                                pcall(function() 
                                    local args = { char, slotItem }
                                    ReplicatedStorage:WaitForChild("Events"):WaitForChild("ItemEvent"):InvokeServer(unpack(args))
                                end)
                            end
                        end
                        
                    end
                end
            end
        end
        task.wait(Config.AutoUse.UseInterval)
    end
end)
