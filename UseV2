-- ==============================================================================
-- STANDALONE SCRIPT: SMART AUTO USE ITEM (V5 - ANTI SPAM / DEBOUNCE)
-- ==============================================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local Config = {
    AutoUse = {
        Enable = true,      
        UseInterval = 0.2, 
        ItemCooldown = 2.5, -- WAKTU JEDA (Detik). Script akan menunggu 2.5 detik sebelum mencoba memakai item di slot yang sama lagi.
        
        MaxHealth = 3, 
        
        EnableAutoHeal = true,      
        EnableAutoBuff = true,      
        EnableAutoUtility = false,  

        Slots = {
            Slot1 = true,
            Slot2 = true,
            Slot3 = true,
            Slot4 = false            
        },
        
        ItemCategories = {
            SmallHeal = {"Bandage"},
            BigHeal = {"HealthKit"},
            StaminaAndBuffs = {
                "ProteinBar", "SpeedCandy", "StaminaCandy", "ExtractionSpeedCandy", "StealthCandy",
                "SkillCheckCandy", "Pop", "PopBottle", "Chocolate", "ChocolateBox",
                "Gumball", "Jawbreaker", "BonBon", "ChristmasCookie", "DandyEasterEggs"
            },
            UtilityAndTools = {
                "Instructions", "JumperCable", "SmokeBomb", "EjectButton", 
                "Stopwatch", "AirHorn", "Valve", "Tape"
            }
        }
    }
}

if not Config.AutoUse.Enable then return end
print("[SYSTEM] Standalone Auto-Use V5 berjalan! Sistem Anti-Spam (Debounce) Aktif.")

local function getCurrentHealth()
    local PlayerGui = player:FindFirstChild("PlayerGui")
    if not PlayerGui then return nil end
    
    local contentFolder = PlayerGui:FindFirstChild("ScreenGui")
        and PlayerGui.ScreenGui:FindFirstChild("Menu")
        and PlayerGui.ScreenGui.Menu:FindFirstChild("BottomLeftCorner")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner:FindFirstChild("Status")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status:FindFirstChild("Bottom")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom:FindFirstChild("StaminaBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin:FindFirstChild("InfoBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin:FindFirstChild("HealthBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin:FindFirstChild("Bar")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin.Bar:FindFirstChild("Content")

    if not contentFolder then return nil end

    local currentHealth = 0

    for i = 1, Config.AutoUse.MaxHealth do 
        local heart = contentFolder:FindFirstChild("Heart" .. tostring(i))
        if heart then
            local pulse = heart:FindFirstChild("Pulse")
            if pulse and pulse.Visible == true then
                currentHealth = currentHealth + 1
            end
        end
    end

    return currentHealth
end

-- Tabel untuk menyimpan waktu terakhir sebuah slot digunakan
local slotCooldowns = {}

task.spawn(function()
    while true do
        local inGamePlayers = workspace:FindFirstChild("InGamePlayers")
        local char = inGamePlayers and inGamePlayers:FindFirstChild(player.Name) 
        if not char then char = player.Character end 
        
        if char and char:FindFirstChild("Inventory") then
            local currentHealth = getCurrentHealth()
            local missingHealth = 0
            if currentHealth then
                missingHealth = Config.AutoUse.MaxHealth - currentHealth
            end

            for slotName, isActive in pairs(Config.AutoUse.Slots) do
                if isActive then
                    local slotItem = char.Inventory:FindFirstChild(slotName)
                    
                    if slotItem and slotItem:IsA("StringValue") then
                        local itemName = slotItem.Value
                        local currentTime = tick() -- Mengambil waktu komputer saat ini
                        
                        -- Cek apakah item bukan "None" DAN slot ini sedang tidak dalam masa Cooldown
                        if itemName ~= "None" and itemName ~= "" then
                            -- Jika slot belum pernah dipakai ATAU waktu saat ini sudah melewati masa cooldown slot tersebut
                            if not slotCooldowns[slotName] or currentTime > slotCooldowns[slotName] then
                                
                                local shouldUse = false

                                if table.find(Config.ItemCategories.SmallHeal, itemName) then
                                    if Config.AutoUse.EnableAutoHeal and missingHealth >= 1 then
                                        shouldUse = true
                                    end
                                elseif table.find(Config.ItemCategories.BigHeal, itemName) then
                                    if Config.AutoUse.EnableAutoHeal and missingHealth >= 2 then
                                        shouldUse = true
                                    end
                                elseif table.find(Config.ItemCategories.StaminaAndBuffs, itemName) then
                                    if Config.AutoUse.EnableAutoBuff then
                                        shouldUse = true
                                    end
                                elseif table.find(Config.ItemCategories.UtilityAndTools, itemName) then
                                    if Config.AutoUse.EnableAutoUtility then
                                        shouldUse = true
                                    end
                                end

                                if shouldUse then
                                    -- Segera catat waktu cooldown untuk slot ini (Waktu Sekarang + 2.5 Detik)
                                    slotCooldowns[slotName] = currentTime + Config.AutoUse.ItemCooldown
                                    
                                    pcall(function() 
                                        ReplicatedStorage.Events.ItemEvent:InvokeServer(char, slotItem) 
                                        print("[Auto-Use] Menggunakan: " .. itemName .. " di " .. slotName)
                                    end)
                                end
                                
                            end
                        end
                    end
                end
            end
        end
        task.wait(Config.AutoUse.UseInterval)
    end
end)
