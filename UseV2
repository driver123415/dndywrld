print("TESTA1")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

-- KATEGORI ITEM
local Heal    = {"Bandage", "HealthKit"}
local Buff    = {"ProteinBar","SpeedCandy","StaminaCandy","ExtractionSpeedCandy","StealthCandy",
                 "SkillCheckCandy","Pop","PopBottle","Chocolate","ChocolateBox",
                 "Gumball","Jawbreaker","BonBon","ChristmasCookie","DandyEasterEggs"}
local Utility = {"SmokeBomb","EjectButton","AirHorn","Tape"}
local Machine = {"Stopwatch","Valve","JumperCable","Instructions"}

-- SAKLAR
local EnableHeal    = true
local EnableBuff    = true
local EnableUtility = true
local EnableMachine = true  -- hanya aktif saat di mesin
local MaxHealth     = 3     -- total HP maksimal

local function inList(val, list)
    local low = string.lower(val)
    for _, v in ipairs(list) do
        if string.find(low, string.lower(v), 1, true) then return true end
    end
    return false
end

print("[SYSTEM] Smart Auto-Use Berjalan!")

task.spawn(function()
    while true do
        local char = player.Character
        if char and char:FindFirstChild("Inventory") then

            -- Baca HP
            local missingHP    = 0
            local isExtracting = false
            pcall(function()
                local menu = player.PlayerGui.ScreenGui.Menu
                local stopGen = menu:FindFirstChild("StopGenerator")
                if stopGen and stopGen.Visible then isExtracting = true end

                local bar = menu.BottomLeftCorner.Status.Bottom
                    .StaminaBin.InfoBin.HealthBin.Bar.Content
                local hp = 0
                for i = 1, MaxHealth do
                    local heart = bar:FindFirstChild("Heart"..i)
                    if heart and heart.Pulse.Visible then hp += 1 end
                end
                missingHP = MaxHealth - hp
            end)

            -- Loop slot — SAMA PERSIS SCRIPT 1
            for slotName, isActive in pairs({Slot1=true, Slot2=true, Slot3=true, Slot4=false}) do
                if isActive then
                    local slotItem = char.Inventory:FindFirstChild(slotName)
                    if slotItem then
                        local val = slotItem.Value or ""

                        if val ~= "" and val ~= "None" then
                            local use = false

                            if   inList(val, Machine) then use = EnableMachine and isExtracting
                            elseif inList(val, Heal)    then use = EnableHeal and (missingHP >= 1)
                            elseif inList(val, Buff)    then use = EnableBuff
                            elseif inList(val, Utility) then use = EnableUtility
                            else                             use = true  -- item tidak dikenal → pakai saja
                            end

                            -- FIRE — SAMA PERSIS SCRIPT 1
                            if use then
                                pcall(function()
                                    ReplicatedStorage.Events.ItemEvent:InvokeServer(char, slotItem)
                                end)
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)
