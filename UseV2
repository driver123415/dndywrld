local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local Config = {
    AutoUse = {
        Enable = true,      
        UseInterval = 0.2, -- Spam brutal tiap 0.2 detik
        MaxHealth = 3, 
        
        -- SAKLAR KONTROL UTAMA
        EnableAutoHeal = true,      
        EnableAutoBuff = true,      
        EnableAutoUtility = false,  
        EnableAutoMachineItem = true, 

        Slots = {
            Slot1 = true, Slot2 = true, Slot3 = true, Slot4 = false            
        },
        
        ItemCategories = {
            SmallHeal = {"Bandage"},
            BigHeal = {"HealthKit"},
            StaminaAndBuffs = {
                "ProteinBar", "SpeedCandy", "StaminaCandy", "ExtractionSpeedCandy", "StealthCandy",
                "SkillCheckCandy", "Pop", "PopBottle", "Chocolate", "ChocolateBox",
                "Gumball", "Jawbreaker", "BonBon", "ChristmasCookie", "DandyEasterEggs"
            },
            UtilityAndTools = {
                "SmokeBomb", "EjectButton", "AirHorn", "Tape"
            },
            MachineItems = { 
                "Stopwatch", "Valve", "JumperCable", "Instructions"
            }
        }
    }
}

if not Config.AutoUse.Enable then return end
print("[SYSTEM] Smart Auto Use V14 Berjalan! (Fitur Lengkap + Deteksi Value Simpel & Brutal)")

-- ==================== HELPER FUNCTIONS ====================

local function getCurrentHealth()
    local PlayerGui = player:FindFirstChild("PlayerGui")
    
    -- Jalur UI yang 100% sudah Fix sesuai gambar terakhir
    local contentFolder = PlayerGui and PlayerGui:FindFirstChild("ScreenGui")
        and PlayerGui.ScreenGui:FindFirstChild("Menu")
        and PlayerGui.ScreenGui.Menu:FindFirstChild("BottomLeftCorner")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner:FindFirstChild("Status")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status:FindFirstChild("Bottom")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom:FindFirstChild("StaminaBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin:FindFirstChild("InfoBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin:FindFirstChild("HealthBin")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin:FindFirstChild("Bar")
        and PlayerGui.ScreenGui.Menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin.Bar:FindFirstChild("Content")

    if not contentFolder then return nil end

    local currentHealth = 0
    for i = 1, Config.AutoUse.MaxHealth do 
        local heart = contentFolder:FindFirstChild("Heart" .. tostring(i))
        if heart and heart:FindFirstChild("Pulse") and heart.Pulse.Visible == true then 
            currentHealth = currentHealth + 1 
        end
    end
    return currentHealth
end

local function isInteractingUI()
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        local screenGui = playerGui:FindFirstChild("ScreenGui")
        if screenGui and screenGui:FindFirstChild("Menu") then
            local stopGen = screenGui.Menu:FindFirstChild("StopGenerator")
            return stopGen and stopGen.Visible or false
        end
    end
    return false
end

-- ==================== MAIN LOGIC ====================

task.spawn(function()
    while true do
        -- Kita pakai player.Character langsung karena itu yang diminta server di log Cobalt
        local char = player.Character
        
        if char and char:FindFirstChild("Inventory") then
            local currentHealth = getCurrentHealth()
            local missingHealth = 0
            
            if currentHealth then 
                missingHealth = Config.AutoUse.MaxHealth - currentHealth 
            end

            for slotName, isActive in pairs(Config.AutoUse.Slots) do
                if isActive then
                    local slotItem = char.Inventory:FindFirstChild(slotName)
                    
                    if slotItem and slotItem:IsA("StringValue") then
                        -- Ambil nama item, bersihin dari spasi nyasar biar aman
                        local rawName = slotItem.Value
                        local itemName = string.match(rawName, "^%s*(.-)%s*$") or rawName
                        
                        -- LOGIKA SIMPEL: Jika Value bukan "None" dan tidak kosong
                        if itemName ~= "None" and itemName ~= "" then
                            local shouldUse = false

                            -- Filter lewat Otak Pintar (Kategori & Kondisi)
                            if table.find(Config.ItemCategories.MachineItems, itemName) then
                                if Config.AutoUse.EnableAutoMachineItem and isInteractingUI() then shouldUse = true end

                            elseif table.find(Config.ItemCategories.SmallHeal, itemName) then
                                if Config.AutoUse.EnableAutoHeal and missingHealth >= 1 then shouldUse = true end

                            elseif table.find(Config.ItemCategories.BigHeal, itemName) then
                                if Config.AutoUse.EnableAutoHeal and missingHealth >= 2 then shouldUse = true end

                            elseif table.find(Config.ItemCategories.StaminaAndBuffs, itemName) then
                                if Config.AutoUse.EnableAutoBuff then shouldUse = true end

                            elseif table.find(Config.ItemCategories.UtilityAndTools, itemName) then
                                if Config.AutoUse.EnableAutoUtility then shouldUse = true end
                            end

                            -- Eksekusi: SPAM BRUTAL JIKA SYARAT TERPENUHI
                            if shouldUse then
                                task.spawn(function()
                                    pcall(function() 
                                        ReplicatedStorage.Events.ItemEvent:InvokeServer(char, slotItem) 
                                    end)
                                end)
                            end
                        end
                    end
                end
            end
        end
        task.wait(Config.AutoUse.UseInterval)
    end
end)
