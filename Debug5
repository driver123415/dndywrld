local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local Config = {
    AutoUse = {
        Enable = true,
        UseInterval = 0.1,
        MaxHealth = 3,

        EnableAutoHeal = true,
        EnableAutoBuff = true,
        EnableAutoUtility = true,
        EnableAutoMachineItem = true,

        Slots = { "Slot1", "Slot2", "Slot3", "Slot4" },

        ItemCategories = {
            SmallHeal = {"Bandage"},
            BigHeal = {"HealthKit"},
            Buff = {"Candy","Chocolate","Pop"},
            Utility = {"Smoke","Horn","Tape"},
            Machine = {"Valve","Cable","Stopwatch"}
        }
    }
}

if not Config.AutoUse.Enable then return end

local ItemEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("ItemEvent")

-- MATCHER
local function match(name, list)
    name = string.lower(name or "")
    for _, v in ipairs(list) do
        if string.find(name, string.lower(v)) then
            return true
        end
    end
    return false
end

task.spawn(function()
    while true do
        local char = player.Character

        if char and char:FindFirstChild("Inventory") then
            local inv = char.Inventory

            for _, slotName in ipairs(Config.AutoUse.Slots) do
                local slot = inv:FindFirstChild(slotName)

                if slot then
                    local itemName = slot.Value or slot.Name or ""

                    print("[DEBUG]", slotName, itemName)

                    local use = false

                    if match(itemName, Config.ItemCategories.SmallHeal) then
                        use = true

                    elseif match(itemName, Config.ItemCategories.BigHeal) then
                        use = true

                    elseif match(itemName, Config.ItemCategories.Buff) then
                        use = true

                    elseif match(itemName, Config.ItemCategories.Utility) then
                        use = true

                    elseif match(itemName, Config.ItemCategories.Machine) then
                        use = true
                    end

                    -- 🔥 FALLBACK (INI KUNCI BIAR KAYAK SCRIPT 1)
                    if not use then
                        use = true
                    end

                    if use then
                        pcall(function()
                            ItemEvent:InvokeServer(char, slot)
                        end)
                    end
                end
            end
        end

        task.wait(Config.AutoUse.UseInterval)
    end
end)

