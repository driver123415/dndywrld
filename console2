--// Dragging Logic
local UIS = game:GetService("UserInputService")
local dragging, dragInput, dragStart, startPos

console.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = console.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)

console.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		console.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

--// Resizing Logic
local resizing, resizeStart, startSize

resizeHandle.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		resizing = true
		resizeStart = input.Position
		startSize = console.Size
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then resizing = false end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - resizeStart
		console.Size = UDim2.new(startSize.X.Scale, startSize.X.Offset + delta.X, startSize.Y.Scale, startSize.Y.Offset + delta.Y)
	end
end)

--// Hook Print ke Console
task.spawn(function()
	local LineCount = 0

	local CreateMessage = function(...)
		LineCount += 1
		
		-- Batas maksimal log adalah 250 agar game tidak lag
		if LineCount > 250 then
			local oldLog = logs:FindFirstChild("Line: " .. tostring(LineCount - 250))
			if oldLog then oldLog:Destroy() end
		end
		
		local msgText = ...
		local NewFrame = example:Clone()
		NewFrame.Name = "Line: " .. tostring(LineCount)
		NewFrame.LayoutOrder = LineCount
		NewFrame.Visible = true
		
		local line = NewFrame:FindFirstChild("LineLabel")
		local txt = NewFrame:FindFirstChild("LogLabel")
		local copyButton = NewFrame:FindFirstChild("CopyBtn")

		if line and txt and copyButton then
			line.Text = tostring(LineCount) .. " -"
			txt.Text = tostring(msgText)
			
			copyButton.MouseButton1Click:Connect(function()
				if setclipboard then
					setclipboard(tostring(msgText))
				end
			end)
		end

		NewFrame.Parent = logs
		
		-- Memaksa scrollbar untuk selalu turun ke log paling bawah
		task.delay(0.05, function()
			console_2.CanvasPosition = Vector2.new(0, 9999999)
		end)
	end

	local function tableToString(tbl)
		local result = {}
		local function traverseTable(t, indent)
			for k, v in pairs(t) do
				if type(v) == "table" then
					result[#result + 1] = indent .. tostring(k) .. ": {"
					traverseTable(v, indent .. "  ")
					result[#result + 1] = indent .. "}"
				else
					result[#result + 1] = indent .. tostring(k) .. ": " .. tostring(v)
				end
			end
		end
		traverseTable(tbl, "")
		return table.concat(result, "\n")
	end

	local oldPrint
	oldPrint = hookfunction(print, function(...)
		local args = {...}
		local strArgs = {}
		
		for _, v in ipairs(args) do
			if type(v) == "table" then
				table.insert(strArgs, tableToString(v))
			else
				table.insert(strArgs, tostring(v))
			end
		end
		
		local message = table.concat(strArgs, " ")
		CreateMessage(message)
		return oldPrint(...)
	end)
end)
