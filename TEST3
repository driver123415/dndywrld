-- ==================== FUNGSI BANTUAN NOXIOUS ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

-- Logika Elevator Noxious (Mencari di seluruh keturunan map)
local function getElevatorCFrame()
    local map = getMap()
    if not map then return nil end
    
    for _, obj in ipairs(map:GetDescendants()) do
        if obj:IsA("Model") and string.find(string.lower(obj.Name), "elevator") and not string.find(string.lower(obj.Name), "fake") then
            -- Ambil PrimaryPart atau part pertama yang ada di dalamnya
            local basePart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if basePart then
                return basePart.CFrame * CFrame.new(0, 3, 0)
            end
        end
    end
    return nil
end

local function isSafe(targetPos)
    local map = getMap()
    if not map then return false end
    
    -- Cek Monster
    local monstersFolder = map:FindFirstChild("Monsters")
    if monstersFolder then
        for _, monster in pairs(monstersFolder:GetChildren()) do
            -- Jika dikejar, auto tidak aman
            local chasing = monster:FindFirstChild("ChasingValue")
            if chasing and chasing.Value == character then return false end
            
            -- Jika radius monster dekat mesin
            if monster.PrimaryPart then
                if (monster.PrimaryPart.Position - targetPos).Magnitude <= Config.SafeRadius then return false end
            end
        end
    end
    
    -- Cek Player Lain
    local inGamePlayers = Workspace:FindFirstChild("InGamePlayers")
    if inGamePlayers then
        for _, other in ipairs(inGamePlayers:GetChildren()) do
            if other.Name ~= player.Name then
                local otherRoot = other.FindFirstChild(other, "HumanoidRootPart")
                if otherRoot and (otherRoot.Position - targetPos).Magnitude <= Config.PlayerRadius then return false end
            end
        end
    end
    
    return true
end

