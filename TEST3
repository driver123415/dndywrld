-- ==================== CORE: MAIN FARMING LOOP ====================
task.spawn(function()
    while not _G.StopNoxiousFarmer do
        if not isFarming then
            task.wait(1)
            continue
        end
        
        local map = getMap()
        if map then
            local genFolder = map:FindFirstChild("Generators")
            if genFolder then
                local targetGen = nil
                local unfinished = 0
                
                -- Evaluasi Generator
                for _, gen in pairs(genFolder:GetChildren()) do
                    if gen:IsA("Model") and gen.PrimaryPart then
                        local stats = gen:FindFirstChild("Stats")
                        if stats then
                            local isCompleted = stats:FindFirstChild("Completed") and stats.Completed.Value
                            local isPossessed = stats:FindFirstChild("Connie") and stats.Connie.Value
                            
                            if not isCompleted then
                                unfinished = unfinished + 1
                                if not isPossessed and not targetGen then
                                    if isSafe(gen.PrimaryPart.Position) then
                                        targetGen = gen
                                    end
                                end
                            end
                        end
                    end
                end
                
                -- EKSEKUSI
                if unfinished == 0 then
                    -- Semua selesai -> Cari Lift
                    local elevatorCF = getElevatorCFrame()
                    if elevatorCF then
                        print("[NOXIOUS] Menuju Elevator!")
                        rootPart.CFrame = elevatorCF
                        task.wait(5)
                    end
                elseif targetGen then
                    print("[NOXIOUS] Farming: " .. targetGen.Name)
                    
                    -- Cari Prompt-nya dulu
                    local prompt = nil
                    for _, desc in ipairs(targetGen:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") then
                            prompt = desc
                            break
                        end
                    end
                    
                    if prompt and prompt.Parent then
                        -- Bypass Prompt Rules
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = 50
                        
                        -- Teleport ke atas lantai (Normal) dekat mesin
                        local targetPos = prompt.Parent.CFrame
                        rootPart.CFrame = targetPos * CFrame.new(0, 0, 3) 
                        
                        task.wait(0.2)
                        
                        -- Tembak prompt HANYA 1 KALI
                        pcall(function() prompt:InputHoldBegin() end)
                        
                        -- Tunggu sampai mesin selesai ATAU ada bahaya datang
                        while targetGen.Parent and isFarming do
                            local stats = targetGen:FindFirstChild("Stats")
                            if stats and stats:FindFirstChild("Completed") and stats.Completed.Value then
                                break -- Mesin beres!
                            end
                            
                            if not isSafe(targetGen.PrimaryPart.Position) then
                                print("[NOXIOUS] Bahaya Terdeteksi! Membatalkan mesin...")
                                local decoding = character:FindFirstChild("Decoding")
                                if decoding and decoding.Value ~= nil then
                                    pcall(function() decoding.Value.Stats.StopInteracting:FireServer("Stop") end)
                                end
                                break -- Lari!
                            end
                            
                            task.wait(0.5)
                        end
                        
                        task.wait(Config.WaitTime)
                    end
                end
            end
        end
        task.wait(1)
    end
end)

