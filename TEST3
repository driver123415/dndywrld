local function forceStop()
    local decoding = character:FindFirstChild("Decoding")
    if decoding and decoding.Value ~= nil then
        pcall(function()
            decoding.Value.Stats.StopInteracting:FireServer("Stop")
        end)
    end
end

-- ==================== FUNGSI DETEKSI ANCAMAN MONSTER ====================
local function isMonsterThreat(generator, radius)
    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                -- 1. Cek apakah monster sedang mengunci target (mengejar) karakter kita
                local chasingVal = monster:FindFirstChild("ChasingValue")
                if chasingVal and chasingVal.Value == character then
                    return true
                end
                
                -- 2. Cek apakah monster terlalu dekat dengan mesin secara radius
                if monster:IsA("Model") and monster.PrimaryPart and generator.PrimaryPart then
                    local distance = (monster.PrimaryPart.Position - generator.PrimaryPart.Position).Magnitude
                    if distance <= radius then return true end
                end
            end
        end
    end
    return false
end

local function isMachineOccupied(generator, radius)
    local inGamePlayers = Workspace:FindFirstChild("InGamePlayers")
    if inGamePlayers then
        for _, otherPlayer in ipairs(inGamePlayers:GetChildren()) do
            if otherPlayer.Name ~= player.Name then
                local otherRoot = otherPlayer:FindFirstChild("HumanoidRootPart")
                if otherRoot and generator.PrimaryPart then
                    local distance = (otherRoot.Position - generator.PrimaryPart.Position).Magnitude
                    if distance <= radius then return true end
                end
            end
        end
    end
    return false
end

