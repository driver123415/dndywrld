-- ==============================================================================
-- ELEVATOR DETECTOR & ESP DEBUG TOOL
-- ==============================================================================
local CoreGui = game:GetService("CoreGui")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local isDebugging = false
local espFolder = Instance.new("Folder")
espFolder.Name = "ElevatorDebugFolder"
-- Kita simpan di CoreGui agar tidak menumpuk di Workspace
local success = pcall(function() espFolder.Parent = CoreGui end)
if not success then espFolder.Parent = player:WaitForChild("PlayerGui") end

-- ==================== FUNGSI BANTUAN ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model") or Workspace
end

local function clearESP()
    for _, child in pairs(espFolder:GetChildren()) do
        child:Destroy()
    end
end

-- ==================== FUNGSI SCAN ELEVATOR ====================
local function scanAllElevators()
    clearESP()
    local map = getMap()
    
    for _, obj in pairs(map:GetDescendants()) do
        local objName = string.lower(obj.Name)
        local parentName = obj.Parent and obj.Parent.Name or "Unknown"
        
        -- Cari semua benda yang namanya ada unsur Elevator, Exit, atau Lift
        if string.find(objName, "elevator") or string.find(objName, "exit") or string.find(objName, "lift") then
            
            -- Kita hanya buat ESP untuk wujud fisiknya (BasePart) atau Model utamanya
            local targetPart = nil
            if obj:IsA("BasePart") then
                targetPart = obj
            elseif obj:IsA("Model") and obj.PrimaryPart then
                targetPart = obj.PrimaryPart
            end
            
            if targetPart then
                -- Menentukan warna: Merah untuk Fake, Hijau/Kuning untuk yang lain
                local isFake = string.find(objName, "fake") or string.lower(parentName) == "fake"
                local espColor = isFake and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
                
                -- Buat Highlight (Garis luar part)
                local highlight = Instance.new("Highlight")
                highlight.Adornee = targetPart
                highlight.FillColor = espColor
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.FillTransparency = 0.5
                highlight.Parent = espFolder
                
                -- Buat Teks Mengambang (BillboardGui)
                local billboard = Instance.new("BillboardGui")
                billboard.Adornee = targetPart
                billboard.Size = UDim2.new(0, 200, 0, 70)
                billboard.AlwaysOnTop = true
                
                local textLabel = Instance.new("TextLabel")
                textLabel.Parent = billboard
                textLabel.Size = UDim2.new(1, 0, 1, 0)
                textLabel.BackgroundTransparency = 1
                textLabel.Font = Enum.Font.Code
                textLabel.TextSize = 14
                textLabel.TextColor3 = espColor
                textLabel.TextStrokeTransparency = 0
                -- Tampilkan info detail: Nama Part, Tipe, dan Parent-nya
                textLabel.Text = "[ " .. obj.Name .. " ]\nType: " .. obj.ClassName .. "\nParent: " .. parentName
                
                billboard.Parent = espFolder
            end
        end
    end
end

-- ==================== LOOP DEBUG ====================
task.spawn(function()
    while true do
        if isDebugging then
            scanAllElevators()
        else
            clearESP()
        end
        task.wait(2) -- Scan ulang tiap 2 detik agar tidak berat
    end
end)

-- ==================== UI SETUP (DRAGGABLE) ====================
local guiContainer = pcall(function() return CoreGui end) and CoreGui or player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ElevatorDebugUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = guiContainer

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 200, 0, 45)
toggleBtn.Position = UDim2.new(0.5, -100, 0.1, 0)
toggleBtn.Text = "SCAN ELEVATORS (OFF)"
toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.SourceSansBold
toggleBtn.TextSize = 18
toggleBtn.Active = true
toggleBtn.Draggable = true -- Bisa digeser sesuka hati
toggleBtn.Parent = screenGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 8)
uiCorner.Parent = toggleBtn

toggleBtn.MouseButton1Click:Connect(function()
    isDebugging = not isDebugging
    if isDebugging then
        toggleBtn.Text = "SCAN ELEVATORS (ON)"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
        print("[DEBUG] Memulai pemindaian elevator...")
        scanAllElevators()
    else
        toggleBtn.Text = "SCAN ELEVATORS (OFF)"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        print("[DEBUG] Pemindaian dihentikan.")
        clearESP()
    end
end)

