-- ==========================================
-- 1. SISTEM VISUALIZER (SMART CIRCLE - PARRY)
-- ==========================================
local function CreateVisualizer()
    if VisualPart then return end
    VisualPart = Instance.new("Part")
    VisualPart.Name = "UltimateSmartCircle"
    VisualPart.Parent = workspace
    VisualPart.Anchored = true
    VisualPart.CanCollide = false
    VisualPart.Transparency = 1
    VisualPart.Material = Enum.Material.Neon
    VisualPart.Size = Vector3.new(1, 1, 1)

    VisualMesh = Instance.new("SpecialMesh", VisualPart)
    VisualMesh.MeshId = "rbxassetid://3270017"
    VisualMesh.Scale = Vector3.new(0, 0, 0)
end

local function DestroyVisualizer()
    if VisualPart then
        VisualPart:Destroy()
        VisualPart = nil
        VisualMesh = nil
    end
end

local function UpdateVisuals(root, distance, state)
    if not SETTINGS.Visuals or not VisualPart then
        if VisualPart then VisualPart.Transparency = 1 end
        return
    end

    VisualPart.CFrame = root.CFrame * CFrame.new(0, -2.6, 0) * CFrame.Angles(math.rad(90), 0, 0)
    local targetSize = math.clamp(distance * 0.8, 5, 80)
    VisualMesh.Scale = VisualMesh.Scale:Lerp(Vector3.new(targetSize, targetSize, 0.5), 0.5)

    if state == "danger" then
        VisualPart.Color = Color3.fromRGB(255, 0, 0)
        VisualPart.Transparency = 0.05
    elseif state == "target" then
        VisualPart.Color = Color3.fromRGB(0, 255, 255)
        VisualPart.Transparency = 0.1
    else
        VisualPart.Color = Color3.fromRGB(150, 240, 255)
        VisualPart.Transparency = 0.5
    end
end

-- ==========================================
-- 1B. VISUALIZER RADIUS JARAK (DISTANCE KEEPER)
-- ==========================================
local function CreateDistanceVisualizer()
    if DistanceVisualPart then return end
    DistanceVisualPart = Instance.new("Part")
    DistanceVisualPart.Name = "DistanceKeeperCircle"
    DistanceVisualPart.Parent = workspace
    DistanceVisualPart.Anchored = true
    DistanceVisualPart.CanCollide = false
    DistanceVisualPart.Transparency = 1
    DistanceVisualPart.Material = Enum.Material.Neon
    DistanceVisualPart.Size = Vector3.new(1, 1, 1)

    DistanceVisualMesh = Instance.new("SpecialMesh", DistanceVisualPart)
    DistanceVisualMesh.MeshId = "rbxassetid://3270017"
    -- Scale langsung sesuai SafeRadius, statis karena ini adalah zona tetap
    local r = SETTINGS.SafeRadius * 1.0
    DistanceVisualMesh.Scale = Vector3.new(r, r, 0.3)
end

local function DestroyDistanceVisualizer()
    if DistanceVisualPart then
        DistanceVisualPart:Destroy()
        DistanceVisualPart = nil
        DistanceVisualMesh = nil
    end
end

local function UpdateDistanceVisuals(root, enemyNearby)
    if not SETTINGS.AutoDistance or not DistanceVisualPart then
        if DistanceVisualPart then DistanceVisualPart.Transparency = 1 end
        return
    end

    -- Ikuti posisi player, flat di lantai
    DistanceVisualPart.CFrame = root.CFrame * CFrame.new(0, -2.8, 0) * CFrame.Angles(math.rad(90), 0, 0)

    -- Animasi scale: sedikit berdenyut saat ada musuh dekat
    local r = SETTINGS.SafeRadius * 1.0
    if enemyNearby then
        -- Berdenyut / pulse merah
        local pulse = math.sin(tick() * 8) * 2
        DistanceVisualMesh.Scale = Vector3.new(r + pulse, r + pulse, 0.3)
        DistanceVisualPart.Color = Color3.fromRGB(255, 80, 0)
        DistanceVisualPart.Transparency = 0.15
    else
        -- Normal: hijau/kuning tenang
        DistanceVisualMesh.Scale = DistanceVisualMesh.Scale:Lerp(Vector3.new(r, r, 0.3), 0.12)
        DistanceVisualPart.Color = Color3.fromRGB(80, 255, 130)
        DistanceVisualPart.Transparency = 0.45
    end
end

-- ==========================================
-- 2. SISTEM OPTIMIZER FPS
-- ==========================================
local function ApplyOptimizer()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = false
        lighting.FogEnd = 1e10
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                v.Enabled = false
            end
        end
    end)
end

-- ==========================================
-- 3. LOGIKA AUTO PARRY & MATEMATIKA
-- ==========================================
local function GetBall()
    local BallsFolder = workspace:FindFirstChild("Balls")
    if not BallsFolder then return nil end
    for _, v in ipairs(BallsFolder:GetChildren()) do
        if v:GetAttribute("realBall") == true then return v end
    end
    return nil
end

local function IsTargeted(ball)
    if not Player.Character then return false end
    if ball and ball:GetAttribute("target") == Player.Name then
        return true
    end
    return Player.Character:GetAttribute("Targeted") == true
        or Player.Character:FindFirstChild("Highlight") ~= nil
end

local function SendClick(ball)
    if not SETTINGS.AutoParry or IsParrying then return end

    local now = tick()
    local cd = 0.1

    if LastBallHit == ball and (now - LastClick) < 0.15 then return end
    if (now - LastClick) < cd then return end

    IsParrying = true
    LastClick = now
    LastBallHit = ball

    task.spawn(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.015)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)

    task.delay(cd, function() IsParrying = false end)
end

-- ==========================================
-- 3B. LOGIKA AUTO DISTANCE KEEPER
-- ==========================================
--[[
    Cara kerja:
    - Setiap frame, cari semua player lain yang ROOT-nya dalam jarak SafeRadius.
    - Hitung vektor arah rata-rata dari semua musuh terdekat ke local player (escape vector).
    - Gunakan Humanoid:MoveTo() ke titik yang jauh dari mereka.
    - Jika tidak ada musuh dekat, biarkan pemain bergerak bebas (tidak override input).
]]
local lastMoveTime = 0

local function RunAutoDistance(root, humanoid)
    if not SETTINGS.AutoDistance then return end

    local myPos = root.Position
    local escapeVector = Vector3.new(0, 0, 0)
    local countNear = 0
    local closestDist = math.huge

    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer == Player then continue end
        local otherChar = otherPlayer.Character
        local otherRoot = otherChar and otherChar:FindFirstChild("HumanoidRootPart")
        if not otherRoot then continue end

        local diff = myPos - otherRoot.Position
        local dist = diff.Magnitude

        if dist < SETTINGS.SafeRadius and dist > 0.5 then
            -- Timbang berdasarkan kedekatan: semakin dekat, semakin kuat dorongan
            local weight = 1 / math.max(dist, 1)
            escapeVector = escapeVector + (diff.Unit * weight)
            countNear = countNear + 1
            if dist < closestDist then closestDist = dist end
        end
    end

    if countNear > 0 then
        -- Normalisasi dan tentukan titik tujuan lari
        escapeVector = escapeVector.Unit
        -- Jarak lari: setidaknya SafeRadius + sedikit buffer agar tidak terus menerus gerak
        local targetPos = myPos + Vector3.new(escapeVector.X, 0, escapeVector.Z) * (SETTINGS.SafeRadius + 5)
        -- Pertahankan Y dari floor agar tidak terbang
        targetPos = Vector3.new(targetPos.X, myPos.Y, targetPos.Z)

        -- Rate-limit agar tidak spam MoveTo setiap frame (cukup setiap 0.08 detik)
        local now = tick()
        if (now - lastMoveTime) > 0.08 then
            humanoid:MoveTo(targetPos)
            lastMoveTime = now
        end
        return true -- ada musuh dekat
    end

    return false -- aman, tidak ada yang dekat
end

