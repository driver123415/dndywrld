--[[
    THE ULTIMATE AUTO PARRY V1.6
    Fix: AutoDistance berhenti saat bola mengarah ke player (tidak konflik parry)
    Fix: Parry tidak lagi skip/miss karena LastBallHit & IsParrying deadlock
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local Player = Players.LocalPlayer

local SETTINGS = {
    AutoParry       = false,
    Visuals         = false,
    PingBasedOffset = 2.5,
    BaseDistanceToParry = 1.0,
    EmergencyRadius = 15,
    OptimizerOn     = false,
    AutoDistance    = false,
    SafeRadius      = 18
}

-- ============================================================
-- STATE MANAGEMENT (dirombak total agar tidak deadlock)
-- ============================================================
local LastParryTime  = 0
local PARRY_COOLDOWN = 0.12  -- satu-satunya penjaga cooldown, tidak ada flag boolean
local frameCounter   = 0
local lastMoveTime   = 0

-- Bola dianggap "mengarah ke player" jika dot product > threshold ini
local BALL_THREAT_DOT = 0.25

local VisualPart, VisualMesh
local DistanceVisualPart, DistanceVisualMesh
local MainConnection

local NetworkStats = Stats:FindFirstChild("Network")
    and Stats.Network:FindFirstChild("ServerStatsItem")
    and Stats.Network.ServerStatsItem:FindFirstChild("Data Ping")

-- ============================================================
-- VISUALIZER PARRY
-- ============================================================
local function CreateVisualizer()
    if VisualPart then return end
    VisualPart = Instance.new("Part")
    VisualPart.Name        = "UltimateSmartCircle"
    VisualPart.Parent      = workspace
    VisualPart.Anchored    = true
    VisualPart.CanCollide  = false
    VisualPart.Transparency = 1
    VisualPart.Material    = Enum.Material.Neon
    VisualPart.Size        = Vector3.new(1,1,1)
    VisualMesh = Instance.new("SpecialMesh", VisualPart)
    VisualMesh.MeshId = "rbxassetid://3270017"
    VisualMesh.Scale  = Vector3.new(0,0,0)
end

local function DestroyVisualizer()
    if VisualPart then VisualPart:Destroy() VisualPart = nil VisualMesh = nil end
end

local function UpdateVisuals(root, distance, state)
    if not SETTINGS.Visuals or not VisualPart then
        if VisualPart then VisualPart.Transparency = 1 end
        return
    end
    VisualPart.CFrame = root.CFrame * CFrame.new(0,-2.6,0) * CFrame.Angles(math.rad(90),0,0)
    local s = math.clamp(distance * 0.8, 5, 80)
    VisualMesh.Scale = VisualMesh.Scale:Lerp(Vector3.new(s, s, 0.5), 0.5)
    if state == "danger" then
        VisualPart.Color       = Color3.fromRGB(255, 0, 0)
        VisualPart.Transparency = 0.05
    elseif state == "target" then
        VisualPart.Color       = Color3.fromRGB(0, 255, 255)
        VisualPart.Transparency = 0.1
    else
        VisualPart.Color       = Color3.fromRGB(150, 240, 255)
        VisualPart.Transparency = 0.5
    end
end

-- ============================================================
-- VISUALIZER DISTANCE KEEPER
-- ============================================================
local function CreateDistanceVisualizer()
    if DistanceVisualPart then return end
    DistanceVisualPart = Instance.new("Part")
    DistanceVisualPart.Name       = "DistanceKeeperCircle"
    DistanceVisualPart.Parent     = workspace
    DistanceVisualPart.Anchored   = true
    DistanceVisualPart.CanCollide = false
    DistanceVisualPart.Transparency = 1
    DistanceVisualPart.Material   = Enum.Material.Neon
    DistanceVisualPart.Size       = Vector3.new(1,1,1)
    DistanceVisualMesh = Instance.new("SpecialMesh", DistanceVisualPart)
    DistanceVisualMesh.MeshId = "rbxassetid://3270017"
    local r = SETTINGS.SafeRadius
    DistanceVisualMesh.Scale = Vector3.new(r, r, 0.3)
end

local function DestroyDistanceVisualizer()
    if DistanceVisualPart then
        DistanceVisualPart:Destroy()
        DistanceVisualPart  = nil
        DistanceVisualMesh  = nil
    end
end

local function UpdateDistanceVisuals(root, enemyNearby)
    if not SETTINGS.AutoDistance or not DistanceVisualPart then
        if DistanceVisualPart then DistanceVisualPart.Transparency = 1 end
        return
    end
    DistanceVisualPart.CFrame = root.CFrame * CFrame.new(0,-2.8,0) * CFrame.Angles(math.rad(90),0,0)
    local r = SETTINGS.SafeRadius
    if enemyNearby then
        local pulse = math.sin(tick() * 8) * 2
        DistanceVisualMesh.Scale       = Vector3.new(r + pulse, r + pulse, 0.3)
        DistanceVisualPart.Color       = Color3.fromRGB(255, 80, 0)
        DistanceVisualPart.Transparency = 0.15
    else
        DistanceVisualMesh.Scale       = DistanceVisualMesh.Scale:Lerp(Vector3.new(r,r,0.3), 0.12)
        DistanceVisualPart.Color       = Color3.fromRGB(80, 255, 130)
        DistanceVisualPart.Transparency = 0.45
    end
end

-- ============================================================
-- OPTIMIZER
-- ============================================================
local function ApplyOptimizer()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = false
        lighting.FogEnd = 1e10
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                v.Enabled = false
            end
        end
    end)
end

-- ============================================================
-- HELPER
-- ============================================================
local function GetBall()
    local folder = workspace:FindFirstChild("Balls")
    if not folder then return nil end
    for _, v in ipairs(folder:GetChildren()) do
        if v:GetAttribute("realBall") == true then return v end
    end
    return nil
end

local function IsTargeted(ball)
    if not Player.Character then return false end
    if ball and ball:GetAttribute("target") == Player.Name then return true end
    return Player.Character:GetAttribute("Targeted") == true
        or Player.Character:FindFirstChild("Highlight") ~= nil
end

-- Cek apakah bola sedang mengarah ke player (threat)
-- Mengembalikan true + dot value
local function BallIsThreat(ballPos, playerPos, velocity)
    local speed = velocity.Magnitude
    if speed < 1 then return false, 0 end
    local dirToPlayer   = (playerPos - ballPos).Unit
    local velDir        = velocity.Unit
    local dot           = dirToPlayer:Dot(velDir)
    return dot >= BALL_THREAT_DOT, dot
end

-- ============================================================
-- SEND CLICK — tidak pakai flag boolean, hanya cek waktu
-- ============================================================
local function SendClick()
    local now = tick()
    if (now - LastParryTime) < PARRY_COOLDOWN then return false end
    LastParryTime = now

    task.spawn(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true,  game, 0)
        task.wait(0.015)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
    return true
end

-- ============================================================
-- AUTO DISTANCE — hanya jalan kalau bola TIDAK mengancam
-- ============================================================
local MOVE_KEYS = {
    Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
    Enum.KeyCode.Up, Enum.KeyCode.Down, Enum.KeyCode.Left, Enum.KeyCode.Right
}
local function IsPlayerHoldingMove()
    for _, k in ipairs(MOVE_KEYS) do
        if UserInputService:IsKeyDown(k) then return true end
    end
    return false
end

-- ballIsThreat: bool, dikirim dari loop utama
local function RunAutoDistance(root, humanoid, ballIsThreat)
    if not SETTINGS.AutoDistance then return false end

    -- PRIORITAS PARRY: kalau bola mengancam, berhenti gerak sepenuhnya
    if ballIsThreat then
        -- Paksa berhenti agar tidak ada momentum MoveTo yang tersisa
        humanoid:MoveTo(root.Position)
        return false
    end

    -- Juga berhenti kalau player sendiri lagi gerak manual
    if IsPlayerHoldingMove() then
        lastMoveTime = 0
        return false
    end

    local myPos       = root.Position
    local escapeVec   = Vector3.new(0,0,0)
    local countNear   = 0

    for _, other in ipairs(Players:GetPlayers()) do
        if other == Player then continue end
        local oc = other.Character
        local or_ = oc and oc:FindFirstChild("HumanoidRootPart")
        if not or_ then continue end
        local diff = myPos - or_.Position
        local dist = diff.Magnitude
        if dist < SETTINGS.SafeRadius and dist > 0.5 then
            escapeVec = escapeVec + (diff.Unit * (1 / math.max(dist, 1)))
            countNear = countNear + 1
        end
    end

    if countNear > 0 then
        escapeVec = escapeVec.Unit
        local target = myPos + Vector3.new(escapeVec.X, 0, escapeVec.Z) * (SETTINGS.SafeRadius + 5)
        target = Vector3.new(target.X, myPos.Y, target.Z)
        local now = tick()
        if (now - lastMoveTime) > 0.15 then
            humanoid:MoveTo(target)
            lastMoveTime = now
        end
        return true
    end

    humanoid:MoveTo(root.Position)
    return false
end

