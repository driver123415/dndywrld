-- ============================================================
-- LOOP UTAMA
-- ============================================================
MainConnection = RunService.PostSimulation:Connect(function()
    local Char     = Player.Character
    local Root     = Char and Char:FindFirstChild("HumanoidRootPart")
    local Humanoid = Char and Char:FindFirstChildOfClass("Humanoid")
    if not Root or not Humanoid then return end

    local Ball     = GetBall()
    local ballPos  = Ball and Ball.Position
    local playerPos = Root.Position

    -- Tentukan apakah bola mengancam player SEKARANG
    -- Ini dipakai bersama oleh AutoDistance DAN AutoParry
    local isThreat = false
    local dot      = 0
    local distance = math.huge
    local speed    = 0
    local velocity = Vector3.new()

    if Ball then
        velocity = Ball.AssemblyLinearVelocity
        speed    = velocity.Magnitude
        distance = (playerPos - ballPos).Magnitude
        isThreat, dot = BallIsThreat(ballPos, playerPos, velocity)
    end

    -- ---- AUTO DISTANCE (hanya jalan kalau bola tidak mengancam) ----
    local enemyNearby = RunAutoDistance(Root, Humanoid, isThreat)
    UpdateDistanceVisuals(Root, enemyNearby)

    -- ---- AUTO PARRY ----
    if not SETTINGS.AutoParry then
        if VisualPart then VisualPart.Transparency = 1 end
        return
    end

    if not Ball then
        if VisualPart then VisualPart.Transparency = 1 end
        return
    end

    -- Kalau dot sangat negatif (bola jelas menjauh), skip
    if dot < -0.2 then
        frameCounter = frameCounter + 1
        if VisualPart and frameCounter % 2 == 0 then
            UpdateVisuals(Root, distance, "neutral")
        end
        return
    end

    local Targeted = IsTargeted(Ball)

    frameCounter = frameCounter + 1
    if VisualPart and frameCounter % 2 == 0 then
        UpdateVisuals(Root, distance, Targeted and "danger" or "neutral")
    end

    if Targeted then
        local Ping      = (NetworkStats and NetworkStats.Value / 1000) or 0.04
        local timeToHit = distance / math.max(speed, 1)

        local speedFactor = speed / 100
        local threshold   = SETTINGS.BaseDistanceToParry
                          + (Ping * SETTINGS.PingBasedOffset)
                          + speedFactor
        if speed > 150 then threshold = threshold * 1.2 end

        if timeToHit <= threshold or distance <= SETTINGS.EmergencyRadius then
            SendClick()
        end
    end
end)

