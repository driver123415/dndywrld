local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local ScreenGui = PlayerGui:WaitForChild("ScreenGui")
local Menu = ScreenGui:WaitForChild("Menu")
local SpaceBarPromptText = Menu:WaitForChild("SpaceBarPromptText")

local isRunning = false

local function toggleRun(state)
	if state == isRunning then return end 
	isRunning = state

	if state then
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
		print("[Auto-Treadmill] Aktif - Sedang lari otomatis")
	else
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
		print("[Auto-Treadmill] Nonaktif - Lari berhenti")
	end
end

-- Kita jadikan pengecekan teks sebagai fungsi tersendiri
local function checkPromptText()
	local currentText = SpaceBarPromptText.Text
	
	if currentText == "Sprint to run faster!" then
		toggleRun(true)
	else
		toggleRun(false)
	end
end

-- 1. Pantau perubahan teks (untuk generator selanjutnya)
SpaceBarPromptText:GetPropertyChangedSignal("Text"):Connect(checkPromptText)

-- 2. PENGECEKAN AWAL (Ini jawaban untuk pertanyaanmu)
-- Langsung cek teks saat script pertama kali dijalankan!
checkPromptText()

print("[Auto-Treadmill] Script berjalan. Mengecek status saat ini dan memantau perubahan.")
