BtnAutoDuck.MouseButton1Click:Connect(function()
	local oriColor = visualClick(BtnAutoDuck, "1. Auto Duck Collection (Full Route)")
	
	-- Gunakan task.spawn agar GUI tidak freeze
	task.spawn(function()
		print("\n▶️ MEMULAI RUTE DUCK COLLECTION...")
		for _, d in ipairs(allDucks) do touchTeleport(d[2]) end
		
		for _, p in ipairs(pedestals) do
			promptInputResult:FireServer(p[1], p[2])
			task.wait(0.2)
			touchTeleport(p[3])
		end

		local hrp = getHRP()
		if hrp then
			hrp.CFrame = CFrame.new(-243.31, 66.23, -730.58)
			task.wait(1)
			firePromptsNearMe(15)
			task.wait(0.5)
			pcall(function() cutsceneEvent:FireServer("NPC_FirstTime_All30") end)
			task.wait(2)
			
			print("▶️ Klaim Final Duck UGC...")
			hrp.CFrame = finalDuckUGC[1][2]
			task.wait(1.5)
			firePromptsNearMe(15)
			autoBuyUGC()
		end
		
		print("✅ RUTE DUCK SELESAI!")
		resetBtn(BtnAutoDuck, oriColor, "1. Auto Duck Collection (Full Route)")
	end)
end)

