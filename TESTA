-- FUNGSI OTOMATISASI INTI
-- ==================================================
local function getHRP()
	local char = player.Character
	if char then return char:FindFirstChild("HumanoidRootPart") end
	return nil
end

local function firePromptsNearMe(radius)
	local hrp = getHRP()
	if hrp then
		for _, prompt in ipairs(workspace:GetDescendants()) do
			if prompt:IsA("ProximityPrompt") then
				local pPart = prompt.Parent
				if pPart and pPart:IsA("BasePart") and (hrp.Position - pPart.Position).Magnitude <= radius then
					fireproximityprompt(prompt)
				end
			end
		end
	end
end

local function touchTeleport(targetCFrame)
	local hrp = getHRP()
	if hrp then
		hrp.CFrame = targetCFrame
		task.wait(0.3)
		hrp.CFrame = targetCFrame + Vector3.new(0, 2, 0)
		task.wait(0.3)
	end
end

local function autoBuyUGC()
	local inset = GuiService:GetGuiInset()
	print("⏳ Menunggu pop-up 'Buy'...")
	task.wait(3.5) 
	
	local buyBtn = nil
	for _, v in ipairs(CoreGui:GetDescendants()) do
		if (v:IsA("TextButton") or v:IsA("TextLabel")) and v.Text == "Buy" then
			buyBtn = v:IsA("TextButton") and v or v.Parent
			break
		end
	end

	if buyBtn and buyBtn.AbsolutePosition.X > 0 then
		local bX = buyBtn.AbsolutePosition.X + (buyBtn.AbsoluteSize.X / 2)
		local bY = buyBtn.AbsolutePosition.Y + (buyBtn.AbsoluteSize.Y / 2) + inset.Y
		VirtualInputManager:SendMouseButtonEvent(bX, bY, 0, true, game, 1)
		task.wait(0.1)
		VirtualInputManager:SendMouseButtonEvent(bX, bY, 0, false, game, 1)
		print("🎯 Tombol 'Buy' diklik!")
		
		task.wait(3) 
		print("⏳ Menunggu konfirmasi 'OK'...")
		
		local okBtn = nil
		for _, v in ipairs(CoreGui:GetDescendants()) do
			if (v:IsA("TextButton") or v:IsA("TextLabel")) and (v.Text == "OK" or v.Text == "Ok") then
				okBtn = v:IsA("TextButton") and v or v.Parent
				break
			end
		end
		
		if okBtn then
			local oX = okBtn.AbsolutePosition.X + (okBtn.AbsoluteSize.X / 2)
			local oY = okBtn.AbsolutePosition.Y + (okBtn.AbsoluteSize.Y / 2) + inset.Y
			VirtualInputManager:SendMouseButtonEvent(oX, oY, 0, true, game, 1)
			task.wait(0.1)
			VirtualInputManager:SendMouseButtonEvent(oX, oY, 0, false, game, 1)
			print("✅ Konfirmasi Selesai.")
		end
	else
		print("⚠️ Pop-up tidak ditemukan.")
	end
end

local function visualClick(btn, oriText)
	local oriColor = btn.BackgroundColor3
	btn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
	btn.Text = "Processing..."
	return oriColor
end

local function resetBtn(btn, oriColor, oriText)
	btn.BackgroundColor3 = oriColor
	btn.Text = oriText
end

