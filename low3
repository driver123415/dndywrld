local function checkLocalPlayerMachines()
    local currentRoom = Workspace:FindFirstChild("CurrentRoom")
    if not currentRoom then return end
    
    local map = currentRoom:FindFirstChildWhichIsA("Model")
    if not map then return end

    local generators = map:FindFirstChild("Generators")
    if generators then
        for _, gen in ipairs(generators:GetChildren()) do
            if gen:IsA("Model") and not countedGenerators[gen] then
                local pCompletion = gen:FindFirstChild("PlayerCompletion")
                if pCompletion and pCompletion:FindFirstChild(player.Name) then
                    stats.Machines = stats.Machines + 1
                    countedGenerators[gen] = true 
                end
            end
        end
    end
end

-- ==================== UPDATE STATS & DYNAMIC LOBBY SWITCHER ====================
local function updateStatsVariables()
    local pGui = player:FindFirstChild("PlayerGui")
    if not pGui then return end

    if locationStatus == "IN GAME" then
        local igp = Workspace:FindFirstChild("InGamePlayers")
        if igp then
            local myCharInfo = igp:FindFirstChild(player.Name)
            if myCharInfo then
                local conf = myCharInfo:FindFirstChild("Config")
                if conf and conf:FindFirstChild("CharacterName") and conf.CharacterName:IsA("StringValue") then
                    stats.Toon = conf.CharacterName.Value
                end
            end
        end

        local sGui = pGui:FindFirstChild("ScreenGui")
        if sGui then
            local cFrames = sGui:FindFirstChild("CurrencyFrames")
            if cFrames then
                local ichor = cFrames:FindFirstChild("IchorFrame")
                if ichor and ichor:FindFirstChild("Margin") and ichor.Margin:FindFirstChild("TextLabel") then
                    stats.Ichor = ichor.Margin.TextLabel.Text
                end
                local holiday = cFrames:FindFirstChild("HolidayFrame")
                if holiday and holiday:FindFirstChild("Margin") and holiday.Margin:FindFirstChild("TextLabel") then
                    stats.Holiday = holiday.Margin.TextLabel.Text
                end
            end
        end

        for _, ui in ipairs(pGui:GetDescendants()) do
            if ui:IsA("TextLabel") and string.find(string.lower(ui.Text), "floor") then
                local match = string.match(ui.Text, "FLOOR%s*(%d+)") or string.match(ui.Text, "Floor:%s*(%d+)")
                if match then stats.Floor = match; break end
            end
        end

    elseif locationStatus == "LOBBY" then
        local wsPlayers = Workspace:FindFirstChild("Players")
        if wsPlayers then
            local myChar = wsPlayers:FindFirstChild(player.Name)
            if myChar then
                local conf = myChar:FindFirstChild("Config")
                if conf then
                    local charName = conf:FindFirstChild("CharacterName")
                    if charName and charName:IsA("StringValue") then
                        local fullName = charName.Value
                        local splitName = string.split(fullName, "_")[1]
                        lobbyStats.UsedToon = splitName or fullName
                    end
                end
            end
        end

        local mainGui = pGui:FindFirstChild("MainGui")
        if mainGui then
            local statFrame = mainGui:FindFirstChild("StatFrame")
            if statFrame then
                local scrollFrame = statFrame:FindFirstChild("ScrollingFrame")
                if scrollFrame then
                    local function getStatValue(statName)
                        local statUI = scrollFrame:FindFirstChild(statName)
                        if statUI then
                            local targetText = statUI:IsA("TextLabel") and statUI.Text or ""
                            if statUI:FindFirstChild("StatName") and statUI.StatName:IsA("TextLabel") then
                                targetText = statUI.StatName.Text
                            end
                            local numberOnly = string.match(targetText, "%d+")
                            return numberOnly or targetText
                        end
                        return "0"
                    end
                    
                    lobbyStats.OwnedToons = getStatValue("Towers")
                    lobbyStats.OwnedTrinkets = getStatValue("Trinkets")
                    lobbyStats.OwnedSkins = getStatValue("Skins")
                end
            end

            local infoFrame = mainGui:FindFirstChild("Info")
            if infoFrame then
                lobbyStats.Currencies = {} 
                for _, currFrame in ipairs(infoFrame:GetChildren()) do
                    if currFrame:IsA("Frame") and currFrame.Name ~= "SprintIcon" then
                        local textLabel = currFrame:FindFirstChild("TextLabel")
                        if textLabel then
                            local cleanName = string.gsub(currFrame.Name, "Frame", "")
                            table.insert(lobbyStats.Currencies, {Name = cleanName, Value = textLabel.Text})
                        end
                    end
                end
            end
        end
    end
end

