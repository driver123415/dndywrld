-- ==================== UTILITY FUNCTIONS ====================
local function getMap()
    return Workspace:FindFirstChild("CurrentRoom") and Workspace.CurrentRoom:FindFirstChildWhichIsA("Model")
end

local function getModelCenter(model)
    if not model or not model:IsA("Model") then return nil end
    local parts = {}
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then table.insert(parts, part) end
    end
    if #parts == 0 then return nil end
    local totalPos = Vector3.zero
    for _, part in pairs(parts) do totalPos = totalPos + part.Position end
    return totalPos / #parts
end

local function getCurrentHealth()
    local pGui = player:FindFirstChild("PlayerGui")
    local menu = pGui and pGui:FindFirstChild("ScreenGui") and pGui.ScreenGui:FindFirstChild("Menu")
    if menu then
        local content = menu:FindFirstChild("BottomLeftCorner") 
            and menu.BottomLeftCorner:FindFirstChild("Status")
            and menu.BottomLeftCorner.Status:FindFirstChild("Bottom")
            and menu.BottomLeftCorner.Status.Bottom:FindFirstChild("StaminaBin")
            and menu.BottomLeftCorner.Status.Bottom.StaminaBin:FindFirstChild("InfoBin")
            and menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin:FindFirstChild("HealthBin")
            and menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin:FindFirstChild("Bar")
            and menu.BottomLeftCorner.Status.Bottom.StaminaBin.InfoBin.HealthBin.Bar:FindFirstChild("Content")
        
        if content then
            local hp = 0
            for i = 1, Config.MaxHealth do
                local heart = content:FindFirstChild("Heart"..i)
                if heart and heart:FindFirstChild("Pulse") and heart.Pulse.Visible then
                    hp = i
                end
            end
            return hp
        end
    end
    return Config.MaxHealth
end

local function getSafePlaceCFrame()
    local elevators = Workspace:FindFirstChild("Elevators")
    if elevators then
        for _, el in ipairs(elevators:GetChildren()) do
            if el.Name == "Elevator" and el:IsA("Model") then
                local dandyStore = el:FindFirstChild("DandyStore")
                if dandyStore then
                    local dandyShop = dandyStore:FindFirstChild("DandyShop")
                    if dandyShop then
                        local root = dandyShop:FindFirstChild("RootPart")
                        if root then
                            return root.CFrame * CFrame.new(0, 3, 0)
                        end
                    end
                end
            end
        end
    end
    
    local map = getMap()
    if map then
        local freeArea = map:FindFirstChild("FreeArea")
        if freeArea then
            local fakeElevator = freeArea:FindFirstChild("FakeElevator")
            if fakeElevator and fakeElevator:IsA("Model") then 
                local center = getModelCenter(fakeElevator)
                if center then return CFrame.new(center) end
            end
        end
    end
    return nil
end

local function teleportplr(cf)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    character:PivotTo(cf)
    Workspace.Gravity = originalGravity
end

local function forceStop()
    local decoding = character:FindFirstChild("Decoding") and character.Decoding.Value
    if decoding ~= nil then
        pcall(function() decoding.Stats.StopInteracting:FireServer("Stop") end)
    end
end

-- ==================== HYBRID RADAR ====================
local function isThreatened(targetPosition, radius)
    -- 1. SUPER SAFE UI CHECK (Evasi)
    local isEvasionCheck = rootPart and (targetPosition - rootPart.Position).Magnitude <= 5
    if Config.Teleport.SuperSafeMonsterDetect and isEvasionCheck then
        local pGui = player:FindFirstChild("PlayerGui")
        local screenGui = pGui and pGui:FindFirstChild("ScreenGui")
        local monsterIcon = screenGui and screenGui:FindFirstChild("MonsterIcon")
        
        if monsterIcon and type(monsterIcon.ImageTransparency) == "number" then
            if monsterIcon.ImageTransparency < 1 then
                return true -- INSTAN KABUR! UI Kedip!
            end
        end
    end

    -- 2. SPATIAL MATH CHECK (Pre-Check Jarak Jauh)
    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                if monster:FindFirstChild("ChasingValue") and monster.ChasingValue.Value == character then
                    return true 
                end
                
                if monster:IsA("Model") and monster.PrimaryPart then
                    local distance = (monster.PrimaryPart.Position - targetPosition).Magnitude
                    
                    local isLethal = false
                    for _, lethalName in ipairs(Config.Teleport.AvoidmoreradiusMonsters) do
                        if monster.Name == lethalName then isLethal = true; break end
                    end
                    
                    if isLethal then
                        if distance <= Config.Teleport.LethalRadius then return true end
                        continue 
                    end
                    
                    local isLooseMonster = false
                    for _, looseName in ipairs(Config.Teleport.LooseMonsters) do
                        if monster.Name == looseName then isLooseMonster = true; break end
                    end
                    
                    if isLooseMonster then
                        if distance <= Config.Teleport.LooseRadius then return true end
                    else
                        if distance <= radius then return true end
                    end
                end
            end
        end
    end
    return false
end

-- ==================== PROGRESS CHECKERS ====================
local function getMachineProgress()
    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local specGui = pGui:FindFirstChild("SpectatorGui")
        if specGui then
            local info = specGui:FindFirstChild("InfoFrame")
            if info then
                local genFrame = info:FindFirstChild("GeneratorFrame")
                if genFrame then
                    local msg = genFrame:FindFirstChild("Message")
                    if msg and msg:IsA("TextLabel") then
                        local cur, tot = string.match(msg.Text, "Machines Completed: (%d+)/(%d+)")
                        if cur and tot then
                            return tonumber(cur), tonumber(tot)
                        end
                    end
                end
            end
        end
    end
    return -1, -1
end

local function getEmptyInventorySlots()
    local char = player.Character
    if not char then return 0 end
    local inv = char:FindFirstChild("Inventory")
    if not inv then return 0 end
    
    local emptyCount = 0
    for i = 1, 4 do
        local slot = inv:FindFirstChild("Slot" .. i)
        if slot and (slot.Value == "" or slot.Value == "None") then
            emptyCount = emptyCount + 1
        end
    end
    return emptyCount
end

