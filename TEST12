    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    local trinketsUI = playerGui:FindFirstChild("ScreenGui") and playerGui.ScreenGui:FindFirstChild("Menu") and playerGui.ScreenGui.Menu:FindFirstChild("BottomLeftCorner") and playerGui.ScreenGui.Menu.BottomLeftCorner:FindFirstChild("Trinkets")
    if trinketsUI then
        for i = 1, 2 do
            local slot = trinketsUI:FindFirstChild("TrinketSlot" .. i)
            if slot and slot:FindFirstChild("TextLabel") and slot.TextLabel.Text == "Active" then
