local function isMachineOccupied(generator, radius)
    local inGamePlayers = Workspace:FindFirstChild("InGamePlayers")
    if inGamePlayers then
        for _, otherPlayer in ipairs(inGamePlayers:GetChildren()) do
            if otherPlayer.Name ~= player.Name then
                local otherRoot = otherPlayer:FindFirstChild("HumanoidRootPart")
                if otherRoot and generator.PrimaryPart then
                    if (otherRoot.Position - generator.PrimaryPart.Position).Magnitude <= radius then return true end
                end
            end
        end
    end
    return false
end

local function updateGeneratorESP()
    if not Config.GenESP.Enable then return end
    local map = getMap()
    if not map then return end
    local generatorsFolder = map:FindFirstChild("Generators")
    if generatorsFolder then
        for _, gen in pairs(generatorsFolder:GetChildren()) do
            if gen:IsA("Model") then
                local highlight = gen:FindFirstChild("GenESP")
                if not highlight then
                    highlight = Instance.new("Highlight", gen)
                    highlight.Name = "GenESP"
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.5
                end
                
                local billboard = gen:FindFirstChild("GenText")
                local label
                if not billboard then
                    billboard = Instance.new("BillboardGui", gen)
                    billboard.Name = "GenText"
                    billboard.Size = UDim2.new(0, 100, 0, 50)
                    billboard.AlwaysOnTop = true
                    label = Instance.new("TextLabel", billboard)
                    label.Name = "Text"
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Font = Enum.Font.Nunito
                    label.TextStrokeTransparency = 0.5
                    label.TextSize = 16
                else label = billboard.Text end

                local stats = gen:FindFirstChild("Stats")
                if stats then
                    local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                    local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                    local current = stats:FindFirstChild("CurrentAmount") and math.floor(stats.CurrentAmount.Value + 0.5) or 0
                    local required = stats:FindFirstChild("RequiredAmount") and stats.RequiredAmount.Value or 0
                    
                    local genName = gen.Name
                    if connie then
                        label.TextColor3 = Config.GenESP.PossessedColor
                        highlight.FillColor = Config.GenESP.PossessedColor
                        genName = genName .. "\n[POSSESSED]"
                    elseif completed then
                        label.TextColor3 = Config.GenESP.CompletedColor
                        highlight.FillColor = Config.GenESP.CompletedColor
                    else
                        label.TextColor3 = Config.GenESP.NormalColor
                        highlight.FillColor = Config.GenESP.NormalColor
                    end
                    label.Text = genName .. "\n(" .. current .. " / " .. required .. ")"
                end
            end
        end
    end
end

local function forceTriggerGenerator(generator)
    for _, descendant in ipairs(generator:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            descendant.RequiresLineOfSight = false
            descendant.MaxActivationDistance = math.huge 
            if fireproximityprompt then fireproximityprompt(descendant, 1)
            else pcall(function() descendant:InputHoldBegin() end) end
            return true
        end
    end
    return false
end

local function moveToPositionGen(targetCFrame, usePlatform)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.Anchored = false
    
    if Config.Teleport.Mode == "Instant" then
        rootPart.CFrame = targetCFrame
        task.wait(0.05) 
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local duration = (rootPart.Position - targetCFrame.Position).Magnitude / (speed * Config.Teleport.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    
    if usePlatform then rootPart.CFrame = targetCFrame; rootPart.Anchored = true end
    Workspace.Gravity = originalGravity
end

local function getRealElevatorCFrame()
    local elevatorsFolder = Workspace:FindFirstChild("Elevators")
    if elevatorsFolder then
        for _, obj in ipairs(elevatorsFolder:GetChildren()) do
            if obj.Name == "Elevator" and obj:IsA("Model") and obj.PrimaryPart then return obj.PrimaryPart.CFrame * CFrame.new(0, 3, 0) end
        end
        for _, obj in ipairs(elevatorsFolder:GetDescendants()) do
            if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") then return obj.CFrame * CFrame.new(0, 1.5, 2) end
        end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "ElevatorPrompt" and obj:IsA("BasePart") and not string.find(string.lower(obj.Parent and obj.Parent.Name or ""), "fake") then
            return obj.CFrame * CFrame.new(0, 1.5, 2)
        end
    end
    return nil
end

local function startAutoFarming()
    local inElevatorStandby = false

    task.spawn(function()
        while isMasterFarming do
            updateGeneratorESP()
            updateMonsterESP() 
            updateSafeRadiusVisual()
            task.wait(0.1)
        end
        if safeRadiusAdornment then safeRadiusAdornment:Destroy(); safeRadiusAdornment = nil end
    end)

    task.spawn(function()
        while isMasterFarming do
            pcall(function()
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events and events:FindFirstChild("SkillcheckUpdate") then events.SkillcheckUpdate.OnClientInvoke = function() return true end end
            end)
            task.wait(1)
        end
    end)

    task.spawn(function()
        while isMasterFarming do
            if isItemFarmingActive or isEncounteringActive then
                task.wait(0.2)
                continue
            end

            character = player.Character or player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")

            if Config.Teleport.Enable then
                local map = getMap()
                if map then
                    local genFolder = map:FindFirstChild("Generators")
                    if genFolder then
                        
                        local targetGen = nil
                        local uncompletedCount = 0
                        local anyEmptyGen = nil
                        
                        for _, gen in pairs(genFolder:GetChildren()) do
                            if gen:IsA("Model") and gen.PrimaryPart then
                                local stats = gen:FindFirstChild("Stats")
                                if stats then
                                    local completed = stats:FindFirstChild("Completed") and stats.Completed.Value
                                    local connie = stats:FindFirstChild("Connie") and stats.Connie.Value
                                    
                                    if not completed then
                                        uncompletedCount = uncompletedCount + 1
                                        if not connie then
                                            if not isThreatened(gen.PrimaryPart.Position, Config.Teleport.SafeRadius + 15) then
                                                if not isMachineOccupied(gen, Config.Teleport.PlayerRadius) then
                                                    if not anyEmptyGen then anyEmptyGen = gen end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        
                        targetGen = anyEmptyGen 
                        
                        local curGenUI, totGenUI = getMachineProgress()
                        local isFloorActuallyDone = false
                        
                        if curGenUI ~= -1 and totGenUI ~= -1 then
                            isFloorActuallyDone = (curGenUI >= totGenUI)
                        else
                            isFloorActuallyDone = (uncompletedCount == 0)
                        end
                        
                        -- [ELEVATOR LOCK]
                        if isFloorActuallyDone then
                            if not inElevatorStandby then
                                print("[INFO] Semua Mesin Selesai (Verified)! Mencari Lift...")
                                inElevatorStandby = true
                            end
                            
                            local elevatorTarget = getRealElevatorCFrame()
                            if elevatorTarget then
                                local dist = (rootPart.Position - elevatorTarget.Position).Magnitude
                                if dist > 7 then
                                    moveToPositionGen(elevatorTarget, true)
                                else
                                    if rootPart.Anchored then rootPart.Anchored = false end
                                end
                            else
                                local safePos = getSafePlaceCFrame()
                                if safePos then teleportplr(safePos) end
                                rootPart.Anchored = false
                            end
                            task.wait(0.5) 
                            
                        elseif targetGen then
                            inElevatorStandby = false
                            local centerPos = getModelCenter(targetGen)
                            if centerPos and targetGen.PrimaryPart then
                                local targetCFrame = CFrame.new(centerPos.X, targetGen.PrimaryPart.Position.Y + Config.Teleport.UndergroundOffset, centerPos.Z)
                                moveToPositionGen(targetCFrame, true)
                                
                                local isContested = false
                                local monsterEvade = false
                                local needSync = isTrinketActive()
                                
                                if needSync then
                                    local syncDelay = Config.Teleport.SyncDelayMin + (math.random() * (Config.Teleport.SyncDelayMax - Config.Teleport.SyncDelayMin))
                                    print(string.format("[SYNC] Trinket 'Active'! Menunggu %.2f detik...", syncDelay))
                                    local elapsed = 0
                                    while elapsed < syncDelay do
                                        if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then monsterEvade = true; break end
                                        task.wait(0.1); elapsed = elapsed + 0.1
                                    end
                                    if not monsterEvade and isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then isContested = true end
                                else
                                    if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then monsterEvade = true
                                    elseif isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then isContested = true end
                                end
                                
                                if monsterEvade then
                                    print("[SAFETY] Monster terdeteksi saat mendarat! Evade Instan!")
                                    rootPart.Anchored = false
                                    local safePos = getSafePlaceCFrame()
                                    if safePos then teleportplr(safePos) else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                                    task.wait(1.5)
                                elseif isContested then
                                    print("[SAFETY] Mesin direbut pemain lain. Batal ekstrak.")
                                    rootPart.Anchored = false
                                else
                                    local hasStartedInteracting = false
                                    local instantNext = false
                                    local failTimer = 0 
                                    
                                    while isMasterFarming and targetGen.Parent and not isItemFarmingActive and not isEncounteringActive do
                                        local stats = targetGen:FindFirstChild("Stats")
                                        if stats and stats:FindFirstChild("Completed") and stats.Completed.Value then instantNext = true; break end
                                        
                                        if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then
                                            forceStop(); rootPart.Anchored = false
                                            print("[SAFETY] Evade Instan! Ngungsi...")
                                            local safePos = getSafePlaceCFrame()
                                            if safePos then teleportplr(safePos) else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                                            instantNext = true; break
                                        end
                                        
                                        if isMachineOccupied(targetGen, Config.Teleport.PlayerRadius) then
                                            print("[SAFETY] Pemain lain mendekat. Ngalah cabut."); forceStop(); task.wait(0.1); instantNext = true; break
                                        end
                                        
                                        rootPart.CFrame = targetCFrame
                                        local currentlyInteracting = isInteractingUI()
                                        if currentlyInteracting then
                                            hasStartedInteracting = true; failTimer = 0 
                                        elseif hasStartedInteracting and not currentlyInteracting then
                                            forceStop(); instantNext = true; break
                                        else
                                            forceTriggerGenerator(targetGen)
                                            failTimer = failTimer + 1
                                            if failTimer == 10 then
                                                rootPart.CFrame = targetCFrame * CFrame.new(0, 1.5, 0)
                                                task.wait(0.1); rootPart.CFrame = targetCFrame
                                            elseif failTimer >= 25 then
                                                forceStop(); instantNext = true; break
                                            end
                                        end
                                        task.wait(0.1)
                                    end
                                    rootPart.Anchored = false
                                    if instantNext then task.wait(0.05) else task.wait(Config.Teleport.DelayNext) end
                                end
                            end
                        else
                            local progressText = (curGenUI ~= -1) and (" ("..curGenUI.."/"..totGenUI..")") or ""
                            print("[INFO] Ngungsi sementara ke Safe Place" .. progressText .. "...")
                            rootPart.Anchored = false
                            local safePos = getSafePlaceCFrame()
                            if safePos then teleportplr(safePos) end
                            task.wait(1) 
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

-- ==================== MASTER WATCHER & ENCOUNTER TRIGGER ====================
local hasSweptHeals = false
local lastGenCount = -1
local lastProgressTick = tick()

task.spawn(function()
    while task.wait(0.2) do 
        if not isMasterFarming then 
            lastProgressTick = tick()
            continue 
        end

        local curGen, totGen = getMachineProgress()
        if curGen == 0 then hasSweptHeals = false end
        
        -- [HARD REBOOT FAILSAFE]
        if not isItemFarmingActive and not isEncounteringActive then
            if curGen ~= lastGenCount then
                lastGenCount = curGen
                lastProgressTick = tick() 
            end
            
            if tick() - lastProgressTick >= Config.failsafegenerator then
                print("\n==============================================")
                print("[FAILSAFE] Script stuck/bengong selama " .. Config.failsafegenerator .. " detik! Melakukan HARD REBOOT...")
                print("==============================================")
                
                forceStop()
                if rootPart then rootPart.Anchored = false end
                local safePos = getSafePlaceCFrame()
                if safePos then teleportplr(safePos) 
                else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                
                isMasterFarming = false 
                task.wait(2)
                
                print("[FAILSAFE] Reboot Selesai. Memulai ulang script...")
                lastProgressTick = tick() 
                isMasterFarming = true
                startAutoFarming()
                continue
            end
        else
            lastProgressTick = tick() 
        end

        -- [SMART HEAL SWEEP]
        if curGen > 0 and totGen > 0 and curGen == (totGen - 1) and not hasSweptHeals then
            if getEmptyInventorySlots() > 0 then
                local unblacklistedAny = false
                local map = getMap()
                if map and map:FindFirstChild("Items") then
                    for _, item in ipairs(map.Items:GetChildren()) do
                        if isSecondPriority(item.Name) and item:GetAttribute("BlacklistLimbo") then
                            item:SetAttribute("BlacklistLimbo", nil) 
                            local highlight = item:FindFirstChild("ItemESP")
                            if highlight then highlight.FillColor = Color3.fromRGB(255, 100, 255) end 
                            unblacklistedAny = true
                        end
                    end
                end
                if unblacklistedAny then print("[SMART PICKUP] Sisa 1 Mesin & Tas Kosong! Menghapus Blacklist Healing Item...") end
            end
            hasSweptHeals = true
        end

        local map = getMap()
        if map then
            -- [WATCHER: ITEM PICKUP TRIGGER]
            if map:FindFirstChild("Items") and not isItemFarmingActive and not isEncounteringActive then
                local hasValidItems = false
                for _, item in ipairs(map.Items:GetChildren()) do
                    if item:IsA("Model") and not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                        if not isThreatened(item:GetPivot().Position, Config.Teleport.SafeRadius) then
                            hasValidItems = true; break
                        end
                    end
                end

                if hasValidItems then
                    if isInteractingUI() then
                        while isInteractingUI() and isMasterFarming do task.wait(0.2); lastProgressTick = tick() end
                    end
                    
                    isItemFarmingActive = true 
                    print("\n==============================================")
                    print("[SYSTEM] Mendeteksi Item Baru/Aman di Lantai!")
                    print("==============================================")
                    forceStop()
                    if rootPart then rootPart.Anchored = false end
                    character = player.Character or player.CharacterAdded:Wait()
                    rootPart = character:WaitForChild("HumanoidRootPart")
                    
                    pcall(function() executePickup() end)
                    
                    isItemFarmingActive = false
                    lastProgressTick = tick() 
                end
            end
            
            -- [WATCHER: ENCOUNTER TRIGGER]
            if Config.Teleport.EncounterMonsterDetect and not isItemFarmingActive and not isEncounteringActive then
                local monstersFolder = map:FindFirstChild("Monsters")
                if monstersFolder then
                    local needsEncounter = false
                    for _, monster in pairs(monstersFolder:GetChildren()) do
                        if monster:IsA("Model") and monster.PrimaryPart then
                            local isLethal = false
                            for _, name in ipairs(Config.Teleport.AvoidmoreradiusMonsters) do
                                if monster.Name == name then isLethal = true; break end
                            end
                            if isLethal and Config.Teleport.EncounterBlacklistLethal then continue end
                            if not encounteredMonsters[monster.Name] then needsEncounter = true; break end
                        end
                    end
                    
                    if needsEncounter and getCurrentHealth() > 1 then
                        if isInteractingUI() then
                            while isInteractingUI() and isMasterFarming do task.wait(0.2); lastProgressTick = tick() end
                        end
                        
                        isEncounteringActive = true
                        forceStop()
                        if rootPart then rootPart.Anchored = false end
                        character = player.Character or player.CharacterAdded:Wait()
                        rootPart = character:WaitForChild("HumanoidRootPart")
                        
                        pcall(function() executeEncounter() end)
                        
                        isEncounteringActive = false
                        lastProgressTick = tick() 
                    end
                end
            end
        end
    end
end)

