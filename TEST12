local function applyItemESP()
    if not Config.ItemESP.Enable then return end
    local map = getMap()
    if map and map:FindFirstChild("Items") then
        for _, item in ipairs(map.Items:GetChildren()) do
            if item:IsA("Model") and not item:FindFirstChild("ItemESP") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "ItemESP"
                highlight.Parent = item
                highlight.FillTransparency = 0.5
                
                local nameLower = string.lower(item.Name)
                local isIg, isPr, isSp = false, false, false
                for _, b in ipairs(Config.Pickup.IgnoreList) do if string.find(nameLower, string.lower(b), 1, true) then isIg = true; break end end
                for _, p in ipairs(Config.Pickup.PriorityList) do if string.find(nameLower, string.lower(p), 1, true) then isPr = true; break end end
                for _, s in ipairs(Config.Pickup.SecondPriorityList) do if string.find(nameLower, string.lower(s), 1, true) then isSp = true; break end end
                
                if isIg or item:GetAttribute("BlacklistLimbo") then highlight.FillColor = Color3.fromRGB(255, 0, 0)
                elseif isPr then highlight.FillColor = Color3.fromRGB(255, 255, 0)
                elseif isSp then highlight.FillColor = Color3.fromRGB(255, 100, 255) 
                else highlight.FillColor = Color3.fromRGB(0, 255, 0) end
                
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ItemESPText"
                billboard.Adornee = item
                billboard.Size = UDim2.new(0, 100, 0, 50)
                billboard.AlwaysOnTop = true
                billboard.Parent = item
                
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = item.Name
                label.TextColor3 = highlight.FillColor
                label.TextStrokeTransparency = 0.5
                label.TextSize = 14
                label.Parent = billboard
            end
        end
    end
end

-- ==================== HOVER ENCOUNTER LOGIC (FIXED) ====================
local function executeEncounter()
    if not Config.Teleport.EncounterMonsterDetect then return end
    if getCurrentHealth() <= 1 then 
        print("[ENCOUNTER] Nyawa Sisa 1 (Kritis). Skip demi keamanan.")
        return 
    end

    local map = getMap()
    if not map or not map:FindFirstChild("Monsters") then return end

    -- Amankan diri dulu ke transit sebelum mulai operasi udara
    local safePosInit = getSafePlaceCFrame()
    if safePosInit then teleportplr(safePosInit) end
    task.wait(0.5)

    for _, monster in pairs(map.Monsters:GetChildren()) do
        if not isMasterFarming or getCurrentHealth() <= 1 then break end 
        
        if monster:IsA("Model") and monster.PrimaryPart then
            local mName = monster.Name
            
            local isLethal = false
            for _, name in ipairs(Config.Teleport.AvoidmoreradiusMonsters) do
                if mName == name then isLethal = true; break end
            end

            if isLethal and Config.Teleport.EncounterBlacklistLethal then
                continue
            end

            if not encounteredMonsters[mName] then
                print("[ENCOUNTER] Menuju target: " .. mName)
                local height = 80
                local minHeight = 15 -- Batas bawah biar nggak nempel jidat
                local success = false
                
                -- Turun pelan-pelan sampai 15 stud
                while height >= minHeight and isMasterFarming and getCurrentHealth() > 1 do
                    if not monster.PrimaryPart then break end
                    
                    local targetCF = monster.PrimaryPart.CFrame * CFrame.new(0, height, 0)
                    teleportplr(targetCF)
                    rootPart.Anchored = true
                    
                    local pGui = player:FindFirstChild("PlayerGui")
                    local monsterIcon = pGui and pGui:FindFirstChild("ScreenGui") and pGui.ScreenGui:FindFirstChild("MonsterIcon")
                    
                    if monsterIcon and type(monsterIcon.ImageTransparency) == "number" then
                        if monsterIcon.ImageTransparency < 1 then
                            print("[ENCOUNTER] Kedip sukses di udara! " .. mName .. " terdaftar.")
                            success = true
                            break
                        end
                    end
                    
                    height = height - 5
                    task.wait(0.05)
                end
                
                -- Sistem Nyerah (Give Up) - Nunggu 1.5 detik kalau belum kedip di 15 stud
                if not success and isMasterFarming and monster.PrimaryPart then
                    local waitTime = 0
                    while waitTime < 1.5 and isMasterFarming do
                        local pGui = player:FindFirstChild("PlayerGui")
                        local monsterIcon = pGui and pGui:FindFirstChild("ScreenGui") and pGui.ScreenGui:FindFirstChild("MonsterIcon")
                        
                        if monsterIcon and type(monsterIcon.ImageTransparency) == "number" and monsterIcon.ImageTransparency < 1 then
                            print("[ENCOUNTER] Kedip sukses setelah ditunggu! " .. mName .. " terdaftar.")
                            success = true
                            break
                        end
                        task.wait(0.1)
                        waitTime = waitTime + 0.1
                    end
                    
                    -- Kalau tetep bandel nggak kedip, paksa catat aja
                    if not success then
                        print("[ENCOUNTER] UI Ngebug/Nggak kedip. Maksa nyatet " .. mName .. " (Nyerah).")
                    end
                end
                
                -- Catat ke buku tamu agar tidak infinite loop
                encounteredMonsters[mName] = true
                rootPart.Anchored = false
                
                teleportplr(rootPart.CFrame * CFrame.new(0, 80, 0))
                task.wait(0.2)
            end
        end
    end
end

-- ==================== ITEM PICKUP LOGIC (PLATFORM RESTORED) ====================
local isItemAuraActive = false

local function isIgnored(itemName)
    local nameLower = string.lower(itemName)
    for _, blackName in ipairs(Config.Pickup.IgnoreList) do
        if string.find(nameLower, string.lower(blackName), 1, true) then return true end
    end
    return false
end

local function isPriority(itemName)
    local nameLower = string.lower(itemName)
    for _, prioName in ipairs(Config.Pickup.PriorityList) do
        if string.find(nameLower, string.lower(prioName), 1, true) then return true end
    end
    return false
end

local function isSecondPriority(itemName)
    local nameLower = string.lower(itemName)
    for _, healName in ipairs(Config.Pickup.SecondPriorityList) do
        if string.find(nameLower, string.lower(healName), 1, true) then return true end
    end
    return false
end

local function interactWithPrompt(prompt)
    if prompt.HoldDuration == 0 then
        prompt:InputHoldBegin(); prompt:InputHoldEnd()
    else
        prompt:InputHoldBegin(); task.wait(prompt.HoldDuration); prompt:InputHoldEnd()
    end
end

local function startItemAura()
    isItemAuraActive = true
    task.spawn(function()
        while isItemAuraActive do
            local map = getMap()
            if map and rootPart then
                local itemsFolder = map:FindFirstChild("Items")
                if itemsFolder then
                    for _, item in pairs(itemsFolder:GetChildren()) do
                        if not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                            local promptPart = item:FindFirstChild("Prompt")
                            if promptPart then
                                local proximityPrompt = promptPart:FindFirstChild("ProximityPrompt")
                                if proximityPrompt and proximityPrompt.Enabled then
                                    if (promptPart.Position - rootPart.Position).Magnitude <= Config.Pickup.AuraRange then
                                        interactWithPrompt(proximityPrompt)
                                    end
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

local function moveToPositionItem(targetCFrame)
    local originalGravity = Workspace.Gravity
    Workspace.Gravity = 0
    rootPart.AssemblyLinearVelocity = Vector3.zero
    if Config.Pickup.MovementMode == "Instant" then
        rootPart.CFrame = targetCFrame
        task.wait(0.05)
    else
        local speed = player:GetAttribute("KM_MAX_PLAYER_SPEED") or 16
        local duration = (rootPart.Position - targetCFrame.Position).Magnitude / (speed * Config.Pickup.TweenSpeed)
        if duration <= 0 then duration = 0.1 end
        local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
        tween:Play()
        tween.Completed:Wait()
    end
    Workspace.Gravity = originalGravity
end

local function executePickup()
    if not Config.Pickup.Enable then return end
    local map = getMap()
    if not map then return end

    applyItemESP()
    startItemAura()
    
    local maxLoops = 8 
    local currentLoop = 1
    local hasCleanedAll = false

    while currentLoop <= maxLoops and not hasCleanedAll do
        local itemsFolder = map:FindFirstChild("Items")
        if not itemsFolder then break end
        
        local priorityItems, normalItems = {}, {}
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if item:IsA("Model") and not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                -- [PRE-CHECK MATH] Cek posisi aman sebelum memungut
                if not isThreatened(item:GetPivot().Position, Config.Teleport.SafeRadius) then
                    if isPriority(item.Name) or isSecondPriority(item.Name) then 
                        table.insert(priorityItems, item)
                    else 
                        table.insert(normalItems, item) 
                    end
                end
            end
        end

        if #priorityItems == 0 and #normalItems == 0 then
            hasCleanedAll = true
            break
        end

        local itemsToProcess = (#priorityItems > 0) and priorityItems or normalItems

        table.sort(itemsToProcess, function(a, b)
            return (rootPart.Position - a:GetPivot().Position).Magnitude < (rootPart.Position - b:GetPivot().Position).Magnitude
        end)

        for _, item in ipairs(itemsToProcess) do
            if item and item.Parent and not isIgnored(item.Name) and not item:GetAttribute("BlacklistLimbo") then
                
                if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then
                    print("[SAFETY - ITEM] Monster terdeteksi! Batal ambil item.")
                    local safePos = getSafePlaceCFrame()
                    if safePos then teleportplr(safePos)
                    else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end 
                    task.wait(1)
                    break
                end

                local targetCFrame = item:GetPivot() * CFrame.new(0, -2.5, 0)
                
                -- [REVISI 25] MENGEMBALIKAN PLATFORM PIJAKAN ITEM WARNA HIJAU
                local platform = Instance.new("Part")
                platform.Size = Vector3.new(15, 1, 15) 
                platform.Anchored = true
                platform.CanCollide = true
                platform.Transparency = 0.5 
                platform.Color = Color3.fromRGB(0, 255, 0)
                platform.CFrame = targetCFrame * CFrame.new(0, -3.5, 0)
                platform.Parent = Workspace
                
                moveToPositionItem(targetCFrame)
                task.wait(0.15)
                
                local promptPart = item:FindFirstChild("Prompt")
                if promptPart then
                    local proximityPrompt = promptPart:FindFirstChild("ProximityPrompt")
                    if proximityPrompt and proximityPrompt.Enabled then interactWithPrompt(proximityPrompt) end
                end
                
                local timeout = 15 
                local interrupted = false
                while item.Parent and timeout > 0 do
                    if isThreatened(rootPart.Position, Config.Teleport.SafeRadius) then
                        interrupted = true
                        break
                    end
                    task.wait(0.1)
                    timeout = timeout - 1
                end

                if platform then platform:Destroy() end

                if interrupted then
                    print("[SAFETY - ITEM] Diserang saat memungut item! Kabur ke Safe Place!")
                    local safePos = getSafePlaceCFrame()
                    if safePos then teleportplr(safePos)
                    else teleportplr(rootPart.CFrame * CFrame.new(0, 50, 0)) end
                    task.wait(1)
                    break
                end
                
                if item.Parent then
                    if isPriority(item.Name) then
                        print("[SYSTEM] Item Priority " .. item.Name .. " masih dicoba.")
                    else
                        print("[SYSTEM] Gagal ambil " .. item.Name .. " (Tas Penuh/Gagal). Blacklist sementara.")
                        item:SetAttribute("BlacklistLimbo", true)
                        local highlight = item:FindFirstChild("ItemESP")
                        if highlight then highlight.FillColor = Color3.fromRGB(255, 0, 0) end
                    end
                end
            end
        end
        currentLoop = currentLoop + 1
        task.wait(0.5) 
    end

    isItemAuraActive = false
    print("[DONE] Pengambilan item selesai.")
end


