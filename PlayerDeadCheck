-- ==================== Configuration ====================
local INGAME_PLACE_ID = 16552821455 -- ID Place saat berada di dalam game (Run)
local LOBBY_PLACE_ID = 16116270224  -- ID Place Lobby untuk tempat kabur
-- =======================================================

if game.PlaceId == INGAME_PLACE_ID then
    print("[DEBUG] In-game detected. Memulai pemantauan Kematian/Spectate...")

    local Players = game:GetService("Players")
    local player = Players.LocalPlayer
    local hasTriggered = false -- Kunci agar print tidak spam jika kedua metode terpicu bersamaan

    -- Fungsi simulasi teleportasi (hanya print ke konsol)
    local function triggerTeleport(sumber)
        if hasTriggered then return end
        hasTriggered = true 
        
        print("======================================================")
        print("[SUCCESS] Kematian terdeteksi dari: " .. sumber)
        print("[SUCCESS] --> SEHARUSNYA PLAYER DI-TELEPORT KE LOBBY SEKARANG! <--")
        print("======================================================")
    end

    -- METODE 1: Deteksi kematian lewat Humanoid
    local function setupDeathDetection(character)
        local humanoid = character:WaitForChild("Humanoid", 10)
        if humanoid then
            humanoid.Died:Connect(function()
                print("[DEBUG] Trigger ditarik: Humanoid darahnya habis (Died event).")
                triggerTeleport("Humanoid.Died")
            end)
        end
    end

    -- Pasang deteksi ke karakter yang sedang dipakai saat ini
    if player.Character then
        setupDeathDetection(player.Character)
    end

    -- Pasang ulang jika karakter di-spawn ulang (respawn)
    player.CharacterAdded:Connect(setupDeathDetection)

    -- METODE 2: Deteksi jika game menghapus karaktermu dari InGamePlayers
    task.spawn(function()
        local inGamePlayers = workspace:WaitForChild("InGamePlayers", 10)
        if inGamePlayers then
            inGamePlayers.ChildRemoved:Connect(function(child)
                -- Mengecek apakah yang dihapus dari map adalah model karakter kita
                if child.Name == player.Name then
                    print("[DEBUG] Trigger ditarik: Karakter dihapus dari InGamePlayers.")
                    triggerTeleport("InGamePlayers.ChildRemoved")
                end
            end)
        end
    end)

else
    print("[DEBUG] Not in-game (Place ID mismatch). Script pemantau mati.")
end
