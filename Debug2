local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- ==========================================
-- ⚙️ KONFIGURASI NAMA UI
-- Ganti ini dengan nama persis Frame Vote kamu di DEX Explorer
-- ==========================================
local NAMA_SCREEN_GUI = "ScreenGui"
local NAMA_VOTE_FRAME = "VoteFrame" -- Contoh: "VotePanel", "VoteUI", dll.
-- ==========================================

-- Fungsi Detektif UI (Mengecek sampai ke akar)
local function deepDebugUI(guiElement)
	print("🔍 Menganalisis elemen: " .. guiElement.Name)
	print("   - Properti Visible bawaan : " .. tostring(guiElement.Visible))
	print("   - Ukuran (AbsoluteSize)   : X=" .. tostring(guiElement.AbsoluteSize.X) .. ", Y=" .. tostring(guiElement.AbsoluteSize.Y))
	print("   - Posisi (AbsolutePosition): X=" .. tostring(guiElement.AbsolutePosition.X) .. ", Y=" .. tostring(guiElement.AbsolutePosition.Y))

	-- 1. Cek ukuran fisik
	if guiElement.AbsoluteSize.X == 0 or guiElement.AbsoluteSize.Y == 0 then
		print("   ⚠️ JAWABAN: UI disembunyikan dengan cara dibuat ukurannya 0 (AbsoluteSize 0,0)")
		return false
	end

	-- 2. Cek posisi fisik (apakah dilempar keluar layar?)
	if guiElement.AbsolutePosition.X < -2000 or guiElement.AbsolutePosition.Y < -2000 then
		print("   ⚠️ JAWABAN: UI disembunyikan dengan cara digeser jauh ke luar layar (Off-screen)")
		return false
	end

	-- 3. Cek silsilah keluarga (apakah Parent-nya yang dimatikan?)
	local currentParent = guiElement.Parent
	while currentParent and not currentParent:IsA("ScreenGui") and not currentParent:IsA("PlayerGui") do
		if currentParent:IsA("GuiObject") and currentParent.Visible == false then
			print("   ⚠️ JAWABAN: UI disembunyikan karena Parent-nya (" .. currentParent.Name .. ") berstatus Visible = false")
			return false
		end
		currentParent = currentParent.Parent
	end

	-- 4. Cek dirinya sendiri
	if not guiElement.Visible then
		print("   ⚠️ JAWABAN: UI dimatikan secara normal (Visible = false)")
		return false
	end

	print("   ✅ KESIMPULAN: UI benar-benar MUNCUL dan AKTIF secara fisik di layar!")
	return true
end

-- Fungsi eksekusi utama
local function runDebugger()
	print("\n🛠️ MEMULAI SCANNING VOTE FRAME 🛠️")
	print("=========================================")

	-- Mencari ScreenGui utama
	local TargetScreenGui = PlayerGui:FindFirstChild(NAMA_SCREEN_GUI)

	if TargetScreenGui then
		print(">> SCREEN GUI KETEMU: " .. TargetScreenGui.Name .. " (Enabled: " .. tostring(TargetScreenGui.Enabled) .. ")")

		-- Mencari VoteFrame sampai ke dalam folder/frame terdalam (Recursive Search)
		local TargetVoteFrame = TargetScreenGui:FindFirstChild(NAMA_VOTE_FRAME, true)

		if TargetVoteFrame then
			print(">> VOTE FRAME KETEMU!\n")
			
			-- Jalankan Detektif UI
			local isReallyVisible = deepDebugUI(TargetVoteFrame)

			if isReallyVisible then
				print("\n🚀 HASIL AKHIR: BISA DILAKUKAN AUTO-VOTE SEKARANG!")
			else
				print("\n🛑 HASIL AKHIR: STATUS ASLI FALSE. JANGAN AUTO-VOTE DULU!")
			end
		else
			print(">> ❌ VOTE FRAME TIDAK DITEMUKAN! Pastikan NAMA_VOTE_FRAME di config sudah benar huruf besar/kecilnya.")
		end
	else
		print(">> ❌ SCREEN GUI TIDAK DITEMUKAN! Pastikan NAMA_SCREEN_GUI benar.")
	end
	
	print("=========================================\n")
end

-- Langsung jalankan debug
runDebugger()
