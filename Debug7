local currentTargetName, currentTargetCFrame = "", ""

mouse.Button1Down:Connect(function()
	local target = mouse.Target
	if target and target:IsA("BasePart") then
		currentTargetName = target.Name
		currentTargetCFrame = tostring(target.CFrame)
		PartNameLabel.Text = "Name: " .. currentTargetName
		CFrameLabel.Text = "CFrame: " .. currentTargetCFrame
	end
end)

CopyNameBtn.MouseButton1Click:Connect(function()
	if currentTargetName ~= "" then
		if pcall(function() setclipboard(currentTargetName) end) then flashButton(CopyNameBtn, "Copied!") end
	end
end)

CopyCFrameBtn.MouseButton1Click:Connect(function()
	if currentTargetCFrame ~= "" then
		if pcall(function() setclipboard(currentTargetCFrame) end) then flashButton(CopyCFrameBtn, "Copied!") end
	end
end)

CopyMyPosBtn.MouseButton1Click:Connect(function()
	local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if hrp then
		if pcall(function() setclipboard(tostring(hrp.CFrame)) end) then flashButton(CopyMyPosBtn, "Pos Copied!") end
	end
end)

-- ==========================================
-- LOGIKA NOCLIP
-- ==========================================
local noclipEnabled = false
local noclipConnection

NoclipBtn.MouseButton1Click:Connect(function()
	noclipEnabled = not noclipEnabled
	if noclipEnabled then
		NoclipBtn.Text = "Noclip: ON"
		NoclipBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		
		noclipConnection = RunService.Stepped:Connect(function()
			local char = player.Character
			if char then
				for _, v in pairs(char:GetDescendants()) do
					if v:IsA("BasePart") and v.CanCollide then
						v.CanCollide = false
					end
				end
			end
		end)
	else
		NoclipBtn.Text = "Noclip: OFF"
		NoclipBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
		if noclipConnection then noclipConnection:Disconnect() end
	end
end)

-- ==========================================
-- LOGIKA FLY (SMOOTH & MOBILE SUPPORT)
-- ==========================================
local flying = false
local flySpeed = 1
local flyConnection

SpdMinusBtn.MouseButton1Click:Connect(function()
	if flySpeed > 1 then flySpeed -= 1; SpdLabel.Text = "Spd: " .. flySpeed end
end)
SpdPlusBtn.MouseButton1Click:Connect(function()
	flySpeed += 1; SpdLabel.Text = "Spd: " .. flySpeed
end)

FlyBtn.MouseButton1Click:Connect(function()
	flying = not flying
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildWhichIsA("Humanoid")

	if flying and hrp and hum then
		FlyBtn.Text = "Fly: ON"
		FlyBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		hum.PlatformStand = true

		local bg = Instance.new("BodyGyro", hrp)
		bg.P = 9e4
		bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
		bg.cframe = hrp.CFrame
		local bv = Instance.new("BodyVelocity", hrp)
		bv.velocity = Vector3.new(0, 0, 0)
		bv.maxForce = Vector3.new(9e9, 9e9, 9e9)

		flyConnection = RunService.RenderStepped:Connect(function()
			if not flying or not char or hum.Health <= 0 then
				flying = false
				FlyBtn.Text = "Fly: OFF"
				FlyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
				hum.PlatformStand = false
				if bg then bg:Destroy() end
				if bv then bv:Destroy() end
				if flyConnection then flyConnection:Disconnect() end
				return
			end
			
			-- Menggunakan input bawaan Roblox (Otomatis support WASD & Mobile Joystick)
			local moveDir = hum.MoveDirection
			if moveDir.Magnitude > 0 then
				local camLook = camera.CFrame.LookVector
				-- Campur arah joystick dengan arah kamera untuk bisa terbang ke atas/bawah
				bv.velocity = Vector3.new(moveDir.X, camLook.Y, moveDir.Z).Unit * (flySpeed * 50)
			else
				bv.velocity = Vector3.new(0, 0, 0) -- Berhenti jika tidak bergerak
			end
			bg.cframe = camera.CFrame
		end)
	else
		flying = false
		FlyBtn.Text = "Fly: OFF"
		FlyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
		if hum then hum.PlatformStand = false end
		if hrp then
			local bg = hrp:FindFirstChildOfClass("BodyGyro")
			local bv = hrp:FindFirstChildOfClass("BodyVelocity")
			if bg then bg:Destroy() end
			if bv then bv:Destroy() end
		end
		if flyConnection then flyConnection:Disconnect() end
	end
end)

-- ==========================================
-- LOGIKA TELEPORTER
-- ==========================================
TeleportBtn.MouseButton1Click:Connect(function()
	local inputText = string.gsub(CoordInput.Text, " ", "")
	local coords = string.split(inputText, ",")
	
	if #coords >= 3 then
		local x, y, z = tonumber(coords[1]), tonumber(coords[2]), tonumber(coords[3])
		if x and y and z then
			local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				hrp.CFrame = CFrame.new(x, y, z)
				flashButton(TeleportBtn, "Success!")
			end
		else
			CoordInput.Text = "Gunakan format angka yang benar!"
			task.wait(1.5); CoordInput.Text = ""
		end
	else
		CoordInput.Text = "Butuh minimal X, Y, Z!"
		task.wait(1.5); CoordInput.Text = ""
	end
end)
