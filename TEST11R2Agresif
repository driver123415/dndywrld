local function isThreatened(targetPosition, radius)
    -- Cek apakah targetPosition adalah posisi karakter saat ini (Evade Check)
    local isEvasionCheck = rootPart and (targetPosition - rootPart.Position).Magnitude <= 5

    -- 1. SUPER SAFE UI DETECTION (Diprioritaskan hanya untuk Evasion)
    if Config.Teleport.SuperSafeMonsterDetect and isEvasionCheck then
        local pGui = player:FindFirstChild("PlayerGui")
        local screenGui = pGui and pGui:FindFirstChild("ScreenGui")
        local monsterIcon = screenGui and screenGui:FindFirstChild("MonsterIcon")
        
        if monsterIcon and type(monsterIcon.ImageTransparency) == "number" then
            if monsterIcon.ImageTransparency < 0.99 then
                return true -- INSTAN KABUR KARENA UI BERKEDIP!
            end
        end
    end

    -- 2. SPATIAL DETECTION (Dipakai untuk ngecek Generator jarak jauh & Fallback Evasion)
    local map = getMap()
    if map then
        local monstersFolder = map:FindFirstChild("Monsters")
        if monstersFolder then
            for _, monster in pairs(monstersFolder:GetChildren()) do
                if monster:FindFirstChild("ChasingValue") and monster.ChasingValue.Value == character then
                    return true 
                end
                
                if monster:IsA("Model") and monster.PrimaryPart then
                    local distance = (monster.PrimaryPart.Position - targetPosition).Magnitude
                    
                    local isLethal = false
                    for _, lethalName in ipairs(Config.Teleport.AvoidmoreradiusMonsters) do
                        if monster.Name == lethalName then
                            isLethal = true
                            break
                        end
                    end
                    
                    if isLethal then
                        if distance <= Config.Teleport.LethalRadius then return true end
                        continue 
                    end
                    
                    local isLooseMonster = false
                    for _, looseName in ipairs(Config.Teleport.LooseMonsters) do
                        if monster.Name == looseName then
                            isLooseMonster = true
                            break
                        end
                    end
                    
                    if isLooseMonster then
                        if distance <= Config.Teleport.LooseRadius then return true end
                    else
                        if distance <= radius then return true end
                    end
                end
            end
        end
    end
    return false
end

-- ==================== PROGRESS & INVENTORY CHECKERS ====================
local function getMachineProgress()
    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local specGui = pGui:FindFirstChild("SpectatorGui")
        if specGui then
            local info = specGui:FindFirstChild("InfoFrame")
            if info then
                local genFrame = info:FindFirstChild("GeneratorFrame")
                if genFrame then
                    local msg = genFrame:FindFirstChild("Message")
                    if msg and msg:IsA("TextLabel") then
                        local cur, tot = string.match(msg.Text, "Machines Completed: (%d+)/(%d+)")
                        if cur and tot then
                            return tonumber(cur), tonumber(tot)
                        end
                    end
                end
            end
        end
    end
    return -1, -1
end

local function getEmptyInventorySlots()
    local char = player.Character
    if not char then return 0 end
    local inv = char:FindFirstChild("Inventory")
    if not inv then return 0 end
    
    local emptyCount = 0
    for i = 1, 4 do
        local slot = inv:FindFirstChild("Slot" .. i)
        if slot and (slot.Value == "" or slot.Value == "None") then
            emptyCount = emptyCount + 1
        end
    end
    return emptyCount
end

