--// Logic Copy All
copyAllBtn.MouseButton1Click:Connect(function()
	local allLogs = {}
	-- Loop untuk mengambil semua teks dari log yang ada
	for _, child in ipairs(logs:GetChildren()) do
		if child:IsA("Frame") and child.Name ~= "Example" then
			local logText = child:FindFirstChild("LogLabel")
			if logText then
				table.insert(allLogs, logText.Text)
			end
		end
	end
	
	-- Gabungkan dan masukkan ke clipboard
	if setclipboard then
		local combinedText = table.concat(allLogs, "\n")
		setclipboard(combinedText)
		
		-- Efek visual kecil agar tahu sudah tercopy
		local originalText = copyAllBtn.Text
		copyAllBtn.Text = "Copied!"
		task.delay(1, function()
			copyAllBtn.Text = originalText
		end)
	end
end)

--// Hook & Core Script
task.spawn(function()
	local Logs = logs
	local ExampleFrame = example
	local LineCount = 0

	local CreateMessage = function(...)
		LineCount += 1
		if LineCount >= 250 then
			local oldLog = Logs:FindFirstChild("Line: " .. tostring(LineCount - 250))
			if oldLog then oldLog:Destroy() end
		end
		
		local msgText = ...
		local NewFrame = ExampleFrame:Clone()
		NewFrame.Name = "Line: " .. tostring(LineCount)
		NewFrame.LayoutOrder = LineCount
		NewFrame.Visible = true
		
		local line = NewFrame:FindFirstChild("LineLabel")
		local txt = NewFrame:FindFirstChild("LogLabel")
		local copyBtn = NewFrame:FindFirstChild("CopyBtn")

		if line and txt and copyBtn then
			line.Text = tostring(LineCount) .. " - "
			txt.Text = tostring(msgText)
			
			-- Fungsi Copy individual
			copyBtn.MouseButton1Click:Connect(function()
				if setclipboard then
					setclipboard(tostring(msgText))
					local oldTxt = copyBtn.Text
					copyBtn.Text = "Copied!"
					task.delay(1, function() copyBtn.Text = oldTxt end)
				end
			end)
		end

		NewFrame.Parent = Logs
		-- (Penghitungan CanvasSize manual dihapus dari sini agar scroll wheel normal)
	end

	local function tableToString(tbl)
		local result = {}
		local function traverseTable(t, indent)
			for k, v in pairs(t) do
				if type(v) == "table" then
					result[#result + 1] = indent .. tostring(k) .. ": {"
					traverseTable(v, indent .. "  ")
					result[#result + 1] = indent .. "}"
				else
					result[#result + 1] = indent .. tostring(k) .. ": " .. tostring(v)
				end
			end
		end
		traverseTable(tbl, "")
		return table.concat(result, "\n")
	end

	local prt
	prt = hookfunction(print, function(...)
		local args = ...
		if type(args) == "table" then
			args = tableToString(args)
		elseif type(args) == "function" then
			args = getupvalues(args)
		end
		local message = tostring(args)
		CreateMessage(message)
		return warn(message) -- Sesuai dengan behavior aslinya
	end)
end)
